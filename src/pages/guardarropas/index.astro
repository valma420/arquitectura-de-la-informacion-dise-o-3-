---
import MainLayout from '@layouts/MainLayout.astro';

const portraits = [
  {
    src: '/images/wardrobe/portrait-01.png',
    alt: 'Retrato de Marie Antoinette',
    position: 'marie',
    href: '/guardarropas/marie-antoinette',
    hoverSrc: '/images/wardrobe/hover/hover-01.svg',
  },
  {
    src: '/images/wardrobe/portrait-05.png',
    alt: 'Retrato en blanco y negro de una mujer con vestido de gala',
    position: 'top-small-1',
  },
  {
    src: '/images/wardrobe/portrait-07.png',
    alt: 'Retrato en blanco y negro de una mujer envuelta en una capa',
    position: 'top-small-2',
  },
  {
    src: '/images/wardrobe/portrait-02.png',
    alt: 'Retrato en blanco y negro de una modelo con vestido plisado',
    position: 'center-large',
  },
  {
    src: '/images/wardrobe/portrait-06.png',
    alt: 'Retrato en blanco y negro de una mujer con vestido de novia',
    position: 'top-small-3',
  },
  {
    src: '/images/wardrobe/portrait-08.png',
    alt: 'Retrato en blanco y negro de una mujer con abrigo',
    position: 'top-small-4',
  },
  {
    src: '/images/wardrobe/portrait-11.png',
    alt: 'Retrato de una figura cortesana con vestido de gala',
    position: 'bottom-small-1',
  },
  {
    src: '/images/wardrobe/portrait-09.png',
    alt: 'Retrato en blanco y negro de una mujer sentada',
    position: 'bottom-small-2',
  },
  {
    src: '/images/wardrobe/portrait-03.png',
    alt: 'Retrato en blanco y negro de una mujer con vestido estampado',
    position: 'lower-large-1',
    hoverSrc: '/images/wardrobe/hover/hover-02.svg',
  },
  {
    src: '/images/wardrobe/portrait-12.png',
    alt: 'Retrato en blanco y negro de una diseñadora',
    position: 'bottom-small-3',
    hoverSrc: '/images/wardrobe/hover/hover-03.svg',
  },
  {
    src: '/images/wardrobe/portrait-10.png',
    alt: 'Retrato en blanco y negro de una actriz con vestido de gala',
    position: 'bottom-small-4',
    hoverSrc: '/images/wardrobe/hover/hover-04.svg',
  },
  {
    src: '/images/wardrobe/portrait-04.png',
    alt: 'Retrato en blanco y negro de Frida Kahlo',
    position: 'lower-large-2',
  },
] as const;
---

<MainLayout
  immersive
  title="Guardarropas"
  description="Una galería de guardarropas conservados por el Palais Galliera."
>
  <section class="wardrobe-page">
    <div class="wardrobe-stage">
      <nav class="wardrobe-nav" aria-label="Principal">
        <img src="/images/wardrobe/nav/nav-bar.svg" alt="" aria-hidden="true" />
        <a
          class="wardrobe-nav__hit wardrobe-nav__hit--logo"
          href="/"
          aria-label="Palais Galliera — Inicio"></a>
        <a
          class="wardrobe-nav__hit wardrobe-nav__hit--muestra"
          href="/muestra"
          aria-label="Exposiciones"></a>
        <a
          class="wardrobe-nav__hit wardrobe-nav__hit--coleccion"
          href="/coleccion"
          aria-label="Colecciones"></a>
        <a class="wardrobe-nav__hit wardrobe-nav__hit--agenda" href="/agenda" aria-label="Agenda"
        ></a>
        <a class="wardrobe-nav__hit wardrobe-nav__hit--tickets" href="/agenda" aria-label="Entradas"
        ></a>
        <a
          class="wardrobe-nav__hit wardrobe-nav__hit--search"
          href="/coleccion"
          aria-label="Buscar en la colección"></a>
      </nav>

      <header class="wardrobe-intro">
        <h1>Guardarropas</h1>
        <p>
          Recorré la galería. Cada retrato abre el guardarropa de una figura que el Palais Galliera
          conserva.
        </p>
        <dl class="wardrobe-stats">
          <div><dt>12</dt><dd>figuras</dd></div>
          <div><dt>2</dt><dd>siglos</dd></div>
          <div><dt>7</dt><dd>países</dd></div>
          <div><dt>+178</dt><dd>piezas</dd></div>
        </dl>
      </header>

      <img class="wardrobe-divider" src="/images/wardrobe/dividers/divider.svg" alt="" />

      <div class="portrait-grid" aria-label="Figuras del guardarropa">
        {
          portraits.map((portrait) => {
            const content = (
              <>
                <img class="portrait-card__image" src={portrait.src} alt={portrait.alt} />
                {'hoverSrc' in portrait && (
                  <img class="portrait-card__hover-state" src={portrait.hoverSrc} alt="" />
                )}
              </>
            );

            return 'href' in portrait ? (
              <a
                class:list={['portrait-card', `portrait-card--${portrait.position}`]}
                href={portrait.href}
                aria-label="Ver el guardarropas de Marie Antoinette"
              >
                {content}
              </a>
            ) : (
              <figure
                class:list={['portrait-card', `portrait-card--${portrait.position}`]}
                tabindex="0"
                aria-label={`${portrait.alt}. Guardarropa aún no publicado.`}
              >
                {content}
              </figure>
            );
          })
        }
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .wardrobe-page {
    --wardrobe-purple: #520345;
    --wardrobe-orange: #fd6500;
    --wardrobe-cream: #f3eee1;
    --wardrobe-black: #141414;
    --wardrobe-unit: calc(100cqw / 1920);
    position: relative;
    width: calc(1920 * var(--wardrobe-unit));
    min-height: calc(1549 * var(--wardrobe-unit));
    overflow-x: hidden;
    color: var(--wardrobe-cream);
    background-color: var(--wardrobe-purple);
    background-image: url('/images/wardrobe/pattern.svg');
    background-position: calc(3 * var(--wardrobe-unit)) calc(-17 * var(--wardrobe-unit));
    background-size: calc(1964 * var(--wardrobe-unit)) calc(1963.521 * var(--wardrobe-unit));
  }

  .wardrobe-stage {
    position: absolute;
    top: 0;
    left: 0;
    display: flow-root;
    width: calc(1920 * var(--wardrobe-unit));
    height: calc(1549 * var(--wardrobe-unit));
  }

  .wardrobe-nav {
    position: fixed;
    top: var(--nav-frame-y);
    left: calc((100vw - var(--presentation-width)) / 2 + var(--nav-frame-x));
    z-index: 50;
    width: min(var(--nav-frame-width), calc(100vw - (2 * var(--nav-frame-x))));
    aspect-ratio: var(--nav-frame-width) / var(--nav-frame-height);
  }

  .wardrobe-nav img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .wardrobe-nav__hit {
    position: absolute;
    top: 0;
    height: 100%;
    outline-offset: 3px;
  }

  .wardrobe-nav__hit--logo {
    left: 0;
    width: calc(61 / 1345 * 100%);
  }

  .wardrobe-nav__hit--muestra {
    left: calc(550 / 1345 * 100%);
    width: calc(120 / 1345 * 100%);
  }

  .wardrobe-nav__hit--coleccion {
    left: calc(680 / 1345 * 100%);
    width: calc(130 / 1345 * 100%);
  }

  .wardrobe-nav__hit--agenda {
    left: calc(950 / 1345 * 100%);
    width: calc(95 / 1345 * 100%);
  }

  .wardrobe-nav__hit--tickets {
    left: calc(1118 / 1345 * 100%);
    width: calc(110 / 1345 * 100%);
  }

  .wardrobe-nav__hit--search {
    left: calc(1280 / 1345 * 100%);
    width: calc(42 / 1345 * 100%);
  }

  .wardrobe-intro {
    padding: calc(239 * var(--wardrobe-unit)) calc(24 * var(--wardrobe-unit))
      calc(93 * var(--wardrobe-unit));
    text-align: center;
  }

  .wardrobe-intro h1 {
    color: var(--wardrobe-orange);
    font-size: calc(64 * var(--wardrobe-unit));
    font-style: italic;
    line-height: 1;
    letter-spacing: 0;
  }

  .wardrobe-intro > p {
    width: calc(1245 * var(--wardrobe-unit));
    max-width: none;
    margin: calc(51 * var(--wardrobe-unit)) auto 0;
    font-size: calc(32 * var(--wardrobe-unit));
    font-style: italic;
    line-height: 1;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .wardrobe-stats {
    display: grid;
    grid-template-columns: repeat(4, auto);
    justify-content: center;
    gap: calc(152 * var(--wardrobe-unit));
    margin: calc(40 * var(--wardrobe-unit)) 0 0;
    color: var(--wardrobe-orange);
    font-size: calc(14 * var(--wardrobe-unit));
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
  }

  .wardrobe-stats div {
    display: flex;
    gap: calc(4 * var(--wardrobe-unit));
  }

  .wardrobe-stats dt,
  .wardrobe-stats dd {
    margin: 0;
  }

  .wardrobe-divider {
    width: 100%;
    height: calc(9 * var(--wardrobe-unit));
    object-fit: fill;
  }

  .portrait-grid {
    position: relative;
    width: calc(1920 * var(--wardrobe-unit));
    height: calc(954 * var(--wardrobe-unit));
    margin: calc(52 * var(--wardrobe-unit)) 0 calc(60 * var(--wardrobe-unit));
  }

  .portrait-card {
    position: absolute;
    isolation: isolate;
    margin: 0;
    overflow: hidden;
    outline-offset: 4px;
  }

  .portrait-card__image {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .portrait-card__hover-state {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: fill;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .portrait-card:hover .portrait-card__hover-state,
  .portrait-card:focus-visible .portrait-card__hover-state {
    opacity: 1;
  }

  .portrait-card--marie {
    left: calc(59 * var(--wardrobe-unit));
    top: 0;
    width: calc(433.9917 * var(--wardrobe-unit));
    height: calc(586 * var(--wardrobe-unit));
  }

  .portrait-card--top-small-1 {
    left: calc(515 * var(--wardrobe-unit));
    top: 0;
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--top-small-2 {
    left: calc(741 * var(--wardrobe-unit));
    top: 0;
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--center-large {
    left: calc(972 * var(--wardrobe-unit));
    top: 0;
    width: calc(433.9917 * var(--wardrobe-unit));
    height: calc(586 * var(--wardrobe-unit));
  }

  .portrait-card--top-small-3 {
    left: calc(1428 * var(--wardrobe-unit));
    top: 0;
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--top-small-4 {
    left: calc(1654 * var(--wardrobe-unit));
    top: 0;
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--bottom-small-1 {
    left: calc(59 * var(--wardrobe-unit));
    top: calc(612 * var(--wardrobe-unit));
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--bottom-small-2 {
    left: calc(284 * var(--wardrobe-unit));
    top: calc(612 * var(--wardrobe-unit));
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--lower-large-1 {
    left: calc(516 * var(--wardrobe-unit));
    top: calc(308 * var(--wardrobe-unit));
    width: calc(433.9917 * var(--wardrobe-unit));
    height: calc(586 * var(--wardrobe-unit));
  }

  .portrait-card--bottom-small-3 {
    left: calc(972 * var(--wardrobe-unit));
    top: calc(612 * var(--wardrobe-unit));
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--bottom-small-4 {
    left: calc(1197 * var(--wardrobe-unit));
    top: calc(612 * var(--wardrobe-unit));
    width: calc(208.8492 * var(--wardrobe-unit));
    height: calc(282 * var(--wardrobe-unit));
  }

  .portrait-card--lower-large-2 {
    left: calc(1429 * var(--wardrobe-unit));
    top: calc(308 * var(--wardrobe-unit));
    width: calc(433.9917 * var(--wardrobe-unit));
    height: calc(586 * var(--wardrobe-unit));
  }

  @media (prefers-reduced-motion: reduce) {
    .portrait-card__hover-state {
      transition: none;
    }
  }
</style>
