---
import MainLayout from '@layouts/MainLayout.astro';

const collectionItems = [
  {
    title: 'Robe à la française floral',
    category: 'prendas',
    src: '/images/wardrobe/collection/item-01.png',
    alt: 'Vestido floral de corte con panier del siglo XVIII',
  },
  {
    title: 'Robe à la française floral',
    category: 'prendas',
    src: '/images/wardrobe/collection/item-02.png',
    openSrc: '/images/wardrobe/selection/item-02-open.png',
    alt: 'Vestido floral de corte con panier del siglo XVIII',
  },
  {
    title: 'Figurín de toilette',
    category: 'documentos',
    src: '/images/wardrobe/collection/item-03.png',
    alt: 'Figurín de moda con vestido rayado azul',
  },
  {
    title: 'Robe volante gris perla',
    category: 'prendas',
    src: '/images/wardrobe/collection/item-04.png',
    alt: 'Vestido gris perla montado sobre maniquí',
  },
  {
    title: 'Carta de proveedor real',
    category: 'documentos',
    src: '/images/wardrobe/collection/item-05.png',
    alt: 'Documento manuscrito conservado',
  },
  {
    title: 'Marie Antoinette en robe de cour',
    category: 'retratos',
    src: '/images/wardrobe/collection/item-06.png',
    alt: 'Retrato de Marie Antoinette con vestido de corte',
  },
  {
    title: 'Carta de proveedor real',
    category: 'documentos',
    src: '/images/wardrobe/collection/item-07.png',
    alt: 'Documento manuscrito conservado',
  },
  {
    title: 'Retrato con escritorio',
    category: 'retratos',
    src: '/images/wardrobe/collection/item-08.png',
    alt: 'Retrato histórico de Marie Antoinette sentada junto a un escritorio',
  },
  {
    title: 'Croquis de ornamento',
    category: 'documentos',
    src: '/images/wardrobe/collection/item-09.png',
    alt: 'Croquis de vestido sobre papel',
  },
  {
    title: 'Retrato con escritorio',
    category: 'retratos',
    src: '/images/wardrobe/collection/item-10.png',
    alt: 'Retrato histórico de una figura vinculada al guardarropa',
  },
] as const;

const collectionFilters = [
  { label: 'Todo (10)', value: 'all' },
  { label: 'Prendas (3)', value: 'prendas' },
  { label: 'Documentos (4)', value: 'documentos' },
  { label: 'Retratos (3)', value: 'retratos' },
] as const;
---

<MainLayout
  immersive
  title="Marie Antoinette — Guardarropas"
  description="El guardarropas de Marie Antoinette y el corset de la reina conservado por el Palais Galliera."
>
  <article class="marie-page">
    <header class="marie-hero">
      <a class="back-gallery-button" href="/guardarropas" aria-label="Volver a la galería">
        <img src="/images/wardrobe/buttons/back-gallery.svg" alt="" aria-hidden="true" />
      </a>

      <div class="marie-hero__layout">
        <img
          class="marie-hero__portrait"
          src="/images/wardrobe/marie-antoinette.png"
          alt="Retrato de Marie Antoinette"
        />

        <div class="marie-hero__copy">
          <h1>Marie<br />Antoinette</h1>
          <p class="marie-hero__dates">1755 — 1793</p>
          <p class="marie-hero__summary">
            Reina consorte de Francia entre 1774 y 1792. Reinventó el vestir cortesano, protagonizó
            los escándalos de moda más resonantes de su época, y murió guillotinada con una túnica
            blanca —la misma silueta ligera que había propuesto diez años antes en Versalles.
          </p>
        </div>
      </div>
    </header>

    <section class="history-section" aria-labelledby="history-title">
      <div class="history-section__heading">
        <p class="eyebrow">Su lugar en la historia del vestir</p>
        <h2 id="history-title">La reina que<br />vistió una época</h2>
      </div>

      <div class="history-section__copy">
        <p>
          Marie Antoinette llegó a Versalles en 1770, a los catorce años, y encontró una corte
          gobernada por un rígido protocolo de vestir heredado del siglo XVII. Diez años después
          había demolido ese sistema. Con la ayuda de su modista Rose Bertin —a quien la corte
          llamaba, entre burla y respeto, “ministra de la moda”— empezó a proponer una silueta nueva
          casi cada semana. La corte tuvo que seguirla o quedarse atrás.
        </p>
        <p>
          Su gesto más radical fue la <em>chemise à la reine</em>, una túnica blanca de muselina de
          algodón sin corsé rígido ni panier, presentada en 1783. Cuando Vigée Le Brun expuso un
          retrato de la reina vestida así en el Salón de París, la aristocracia se indignó: la
          acusaron de deshonrar la corona vistiéndose “de lavandera” y —peor aún— de traicionar a la
          industria francesa de la seda al preferir algodón inglés.
        </p>
        <p>
          No entendieron nada. Era el vestido del futuro. Cuando la guillotinaron en 1793, llevaba
          puesta esa misma silueta. Y una década después, sería la moda de toda Europa.
        </p>
      </div>
    </section>

    <section class="icon-piece" aria-labelledby="icon-title">
      <header class="icon-piece__heading">
        <p class="eyebrow eyebrow--blue">La pieza ícono</p>
        <h2 id="icon-title">El corset de la reina</h2>
        <p>C. 1780 · Lino y ballenas · GAL1997.12</p>
      </header>

      <div class="icon-piece__layout">
        <img
          class="icon-piece__image"
          src="/images/wardrobe/corset.png"
          alt="Corset de lino de corte real, hacia 1780"
        />

        <div class="icon-piece__details">
          <h3>Corset de corte real</h3>
          <p>
            Corsé de lino blanco reforzado con ballenas de acero, con costuras curvas propias del
            siglo XVIII. La medida de cintura (52 cm) corresponde a la reina antes de sus embarazos.
            Se conserva junto con los libros de M. Eloffe, proveedor real, donde figura el pago por
            su confección.
          </p>

          <dl class="piece-data">
            <div><dt>N° inv.</dt><dd>GAL1997.12</dd></div>
            <div><dt>Materiales</dt><dd>Lino · ballenas<br />acero + costura</dd></div>
            <div><dt>Medidas</dt><dd>52 cm cintura</dd></div>
            <div><dt>Adquisición</dt><dd>Subasta 1997</dd></div>
          </dl>

          <div class="piece-thumbnails" aria-label="Vistas del corset">
            <img src="/images/wardrobe/corset-detail-01.jpg" alt="Vista posterior del corset" />
            <img src="/images/wardrobe/corset-detail-02.jpg" alt="Vista lateral del corset" />
          </div>

          <a class="ticket-link ticket-link--piece" href="/coleccion">
            <span>Ver ficha completa</span>
            <img src="/images/wardrobe/buttons/ticket-complete.svg" alt="" aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>

    <section
      class="wardrobe-collection"
      id="guardarropas-completo"
      aria-labelledby="collection-title"
      data-filter="all"
    >
      <div class="wardrobe-collection__header">
        <div>
          <p class="eyebrow">Guardarropas completo</p>
          <h2 id="collection-title">Diez piezas conservadas</h2>
        </div>

        <div class="collection-filters" aria-label="Categorías del guardarropas" data-state="all">
          <img
            class="collection-filters__image collection-filters__image--all"
            src="/images/wardrobe/filters/filters-all.svg"
            alt=""
            aria-hidden="true"
          />
          <img
            class="collection-filters__image collection-filters__image--prendas"
            src="/images/wardrobe/filters/filters-prendas.svg"
            alt=""
            aria-hidden="true"
          />
          {
            collectionFilters.map((filter, index) => (
              <button
                class:list={[
                  'collection-filter',
                  `collection-filter--${index + 1}`,
                  filter.value === 'all' && 'is-active',
                ]}
                type="button"
                data-filter={filter.value}
                aria-pressed={filter.value === 'all' ? 'true' : 'false'}
              >
                {filter.label}
              </button>
            ))
          }
        </div>
      </div>

      <img
        class="wardrobe-collection__divider"
        src="/images/wardrobe/dividers/divider.svg"
        alt=""
      />

      <div class="collection-grid">
        {
          collectionItems.map((item) => (
            <button
              class="collection-card"
              type="button"
              data-category={item.category}
              data-title={item.title}
              data-src={item.src}
              data-open-src={'openSrc' in item ? item.openSrc : undefined}
              data-alt={item.alt}
              aria-label={`Ampliar ${item.title}`}
            >
              <img class="collection-card__image" src={item.src} alt={item.alt} loading="lazy" />
            </button>
          ))
        }
      </div>

      <div class="collection-selection" aria-hidden="true">
        <button class="collection-selection__close" type="button" aria-label="Cerrar selección">
        </button>
        <figure class="collection-selection__figure">
          <img class="collection-selection__image" src={collectionItems[1].openSrc} alt="" />
          <figcaption class="sr-only">{collectionItems[0].title}</figcaption>
        </figure>
      </div>
    </section>
  </article>
</MainLayout>

<style>
  .marie-page {
    --marie-purple: #520345;
    --marie-orange: #fd6500;
    --marie-cream: #f3eee1;
    --marie-black: #141414;
    --marie-blue: #b9d6fe;
    overflow-x: clip;
    color: var(--marie-cream);
    background: var(--marie-purple);
  }

  .eyebrow {
    color: var(--marie-orange);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .eyebrow--blue {
    color: var(--marie-blue);
  }

  .ticket-link {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 45px;
    padding-inline: 2.4rem;
    border: 1px solid currentColor;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    transition:
      color 180ms ease,
      background-color 180ms ease;
  }

  .ticket-link:hover,
  .ticket-link:focus-visible {
    color: var(--marie-purple);
    background: var(--marie-cream);
  }

  .back-gallery-button {
    position: absolute;
    top: 57px;
    left: 57px;
    z-index: 2;
    display: block;
    width: 214px;
    height: 44px;
    outline-offset: 4px;
  }

  .back-gallery-button img {
    width: 100%;
    height: 100%;
  }

  .marie-hero {
    position: relative;
    min-height: 1170px;
    padding: 128px 3.125vw 80px;
    background: var(--marie-purple);
  }

  .marie-hero__layout {
    display: grid;
    grid-template-columns: minmax(30rem, 666px) minmax(0, 1fr);
    gap: clamp(4rem, 5.4vw, 6.5rem);
    align-items: start;
    width: min(1608px, 100%);
    margin-inline: auto;
  }

  .marie-hero__portrait {
    width: 666px;
    height: 899px;
    object-fit: fill;
  }

  .marie-hero__copy {
    min-width: 0;
    padding-top: 88px;
  }

  .marie-hero h1 {
    color: var(--marie-orange);
    font-size: clamp(7.5rem, 9.4vw, 11.25rem);
    line-height: 0.84;
    letter-spacing: -0.055em;
  }

  .marie-hero__dates {
    margin-top: 55px;
    font-family: var(--font-display);
    font-size: clamp(7.2rem, 10.4vw, 12.5rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.055em;
    white-space: nowrap;
  }

  .marie-hero__summary {
    max-width: 872px;
    margin-top: 46px;
    color: var(--marie-orange);
    font-size: 32px;
    font-style: italic;
    line-height: 1.15;
    letter-spacing: -0.045em;
  }

  .history-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(34rem, 0.94fr);
    gap: 3rem;
    min-height: 565px;
    padding: 112px 3.125vw 90px;
    color: var(--marie-black);
    background: var(--marie-cream);
  }

  .history-section h2 {
    margin-top: 34px;
    font-size: clamp(6rem, 7.3vw, 8.75rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .history-section__copy {
    max-width: 897px;
    padding-top: 59px;
    color: var(--marie-orange);
    font-size: 18px;
    line-height: 1.08;
  }

  .history-section__copy p + p {
    margin-top: 1.5rem;
  }

  .icon-piece {
    min-height: 1639px;
    padding: 111px 3.125vw 165px;
    color: var(--marie-cream);
    background: var(--marie-black);
  }

  .icon-piece__heading {
    text-align: center;
  }

  .icon-piece__heading h2 {
    margin-top: 41px;
    color: var(--marie-orange);
    font-size: clamp(6rem, 9.5vw, 11.25rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .icon-piece__heading > p:last-child {
    margin-top: 52px;
    color: var(--marie-blue);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .icon-piece__layout {
    display: grid;
    grid-template-columns: minmax(31rem, 818px) minmax(28rem, 623px);
    gap: 6px;
    align-items: start;
    width: min(1526px, 100%);
    margin: 68px auto 0;
  }

  .icon-piece__image {
    width: 818px;
    height: 1095px;
    object-fit: contain;
  }

  .icon-piece__details {
    min-width: 0;
    padding-top: 306px;
  }

  .icon-piece__details h3 {
    font-size: 64px;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .icon-piece__details > p {
    max-width: 623px;
    margin-top: 31px;
    font-size: 18px;
    line-height: 1.16;
  }

  .piece-data {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 44px 5rem;
    margin: 74px 0 0;
  }

  .piece-data dt {
    color: var(--marie-blue);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .piece-data dd {
    margin: 10px 0 0;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .piece-thumbnails {
    display: flex;
    gap: 45px;
    margin-top: 59px;
  }

  .piece-thumbnails img {
    width: 118px;
    height: 137px;
    object-fit: cover;
  }

  .ticket-link--piece {
    width: 263px;
    height: 46px;
    margin-top: 85px;
    padding: 0;
    color: var(--marie-blue);
    border: 0;
  }

  .ticket-link--piece span {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .ticket-link--piece img {
    width: 100%;
    height: 100%;
  }

  .wardrobe-collection {
    position: relative;
    min-height: 2291px;
    padding: 95px 59px 120px;
    overflow: hidden;
    background-color: var(--marie-purple);
    background-image: url('/images/wardrobe/pattern.svg');
    background-position: center bottom;
    background-size: max(102.3vw, 1228px) auto;
    transition: background-color 180ms ease;
  }

  .wardrobe-collection__header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: end;
  }

  .wardrobe-collection h2 {
    margin-top: 12px;
    font-size: 64px;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .collection-filters {
    position: relative;
    width: 543px;
    height: 27px;
    margin: 0 0 1px;
    padding: 0;
  }

  .collection-filters__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: fill;
    pointer-events: none;
  }

  .collection-filters__image--prendas,
  .collection-filters[data-state='prendas'] .collection-filters__image--all {
    opacity: 0;
  }

  .collection-filters[data-state='prendas'] .collection-filters__image--prendas {
    opacity: 1;
  }

  .collection-filter {
    position: absolute;
    top: 0;
    z-index: 2;
    height: 100%;
    padding: 0;
    background: transparent;
    border: 0;
    color: transparent;
    cursor: pointer;
    font-size: 0;
  }

  .collection-filter:focus-visible {
    outline: 2px solid var(--marie-blue);
    outline-offset: 3px;
  }

  .collection-filter--1 {
    left: 0;
    width: 113px;
  }

  .collection-filter--2 {
    left: 142px;
    width: 112px;
  }

  .collection-filter--3 {
    left: 284px;
    width: 128px;
  }

  .collection-filter--4 {
    left: 439px;
    width: 104px;
  }

  .wardrobe-collection__divider {
    position: relative;
    left: 50%;
    width: 100vw;
    max-width: none;
    height: 9px;
    margin: 66px 0 0;
    object-fit: fill;
    transform: translateX(-50%);
  }

  .collection-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 36px 20px;
    margin-top: 67px;
  }

  .collection-card {
    position: relative;
    display: block;
    aspect-ratio: 439 / 591;
    padding: 0;
    margin: 0;
    overflow: hidden;
    background: transparent;
    border: 0;
    cursor: pointer;
    opacity: 1;
    transition: opacity 180ms ease;
  }

  .collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .wardrobe-collection[data-filter='all'] .collection-card {
    opacity: 1;
  }

  .wardrobe-collection[data-filter='prendas'] .collection-card.is-muted {
    opacity: 0.5;
  }

  .wardrobe-collection.has-selection .collection-card:not(.is-selected) {
    opacity: 0.5;
  }

  .wardrobe-collection.has-selection .collection-card.is-selected {
    opacity: 1;
  }

  .collection-card:focus-visible {
    outline: 2px solid var(--marie-blue);
    outline-offset: 4px;
  }

  .collection-selection {
    position: absolute;
    inset: 328px 0 0;
    z-index: 8;
    display: grid;
    justify-items: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .collection-selection[aria-hidden='true'] {
    display: none;
  }

  .wardrobe-collection.has-selection .collection-selection {
    display: grid;
    pointer-events: auto;
    opacity: 1;
  }

  .collection-selection__close {
    position: absolute;
    inset: 0;
    z-index: 1;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: default;
  }

  .collection-selection__figure {
    position: relative;
    z-index: 2;
    width: 762px;
    height: 941px;
    margin: 0;
    pointer-events: none;
  }

  .collection-selection__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (prefers-reduced-motion: reduce) {
    .ticket-link,
    .wardrobe-collection,
    .collection-card,
    .collection-selection {
      transition: none;
    }
  }
</style>

<script>
  const collection = document.querySelector<HTMLElement>('.wardrobe-collection');
  const filterButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.collection-filter')
  );
  const filters = document.querySelector<HTMLElement>('.collection-filters');
  const cards = Array.from(document.querySelectorAll<HTMLButtonElement>('.collection-card'));
  const selection = document.querySelector<HTMLElement>('.collection-selection');
  const selectionImage = document.querySelector<HTMLImageElement>('.collection-selection__image');
  const selectionCaption = document.querySelector<HTMLElement>('.collection-selection figcaption');
  const selectionClose = document.querySelector<HTMLButtonElement>('.collection-selection__close');

  function clearSelection() {
    collection?.classList.remove('has-selection');
    selection?.setAttribute('aria-hidden', 'true');
    cards.forEach((card) => card.classList.remove('is-selected'));
  }

  function applyFilter(filter: string) {
    const isFiltered = filter !== 'all';

    collection?.setAttribute('data-filter', filter);
    filters?.setAttribute('data-state', filter === 'prendas' ? 'prendas' : 'all');
    clearSelection();

    filterButtons.forEach((button) => {
      const isActive = button.dataset.filter === filter;
      button.classList.toggle('is-active', isActive);
      button.setAttribute('aria-pressed', String(isActive));
    });

    cards.forEach((card) => {
      const isMatch = !isFiltered || card.dataset.category === filter;
      card.classList.toggle('is-muted', !isMatch);
      card.classList.toggle('is-filter-match', isFiltered && isMatch);
    });
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => applyFilter(button.dataset.filter ?? 'all'));
  });

  applyFilter('all');

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      if (!selectionImage || !selectionCaption) return;
      const openSrc = card.dataset.openSrc;

      if (!openSrc) return;

      selectionImage.src = openSrc;
      selectionImage.alt = card.dataset.alt ?? '';
      selectionCaption.textContent = card.dataset.title ?? '';
      cards.forEach((currentCard) =>
        currentCard.classList.toggle('is-selected', currentCard === card)
      );
      collection?.classList.add('has-selection');
      selection?.setAttribute('aria-hidden', 'false');
    });
  });

  selectionClose?.addEventListener('click', clearSelection);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') clearSelection();
  });
</script>
