---
import MainLayout from '@layouts/MainLayout.astro';

const events = [
  {
    day: '01',
    kind: 'visita guiada',
    title: 'Recorrido inaugural',
    time: '11 H',
    category: 'visitas',
  },
  {
    day: '02',
    kind: 'EXPOSICIÓN',
    title: 'Retratos de moda',
    time: '10–20 H',
    category: 'exposiciones',
  },
  {
    day: '04',
    kind: 'charla',
    title: 'Vestir el siglo XIX',
    time: '18 H',
    category: 'charlas',
    featured: true,
  },
  { day: '05', kind: 'visita guiada', title: 'Colección', time: '11 H', category: 'visitas' },
  { day: '07', kind: 'taller', title: 'Estampación textil', time: '15 H', category: 'talleres' },
  {
    day: '09',
    kind: 'visita guiada',
    title: 'Tejidos y técnicas',
    time: '17 H',
    category: 'visitas',
  },
  {
    day: '11',
    kind: 'exposición',
    title: 'El New Look',
    time: '10-20 H',
    category: 'exposiciones',
  },
  { day: '13', kind: 'charla', title: 'Encajes y Bordados', time: '16 H', category: 'charlas' },
  { day: '14', kind: 'charla', title: 'El cuerpo vestido', time: '18 H', category: 'charlas' },
  {
    day: '16',
    kind: 'Proyección',
    title: 'Cristóbal Balenciaga',
    time: '19 H',
    category: 'proyecciones',
  },
  {
    day: '17',
    kind: 'Visita guiada',
    title: 'Alta Costura 1947–1957',
    time: '17 H',
    category: 'visitas',
  },
  { day: '19', kind: 'taller', title: 'El Figurín', time: '16 H', category: 'talleres' },
  {
    day: '20',
    kind: 'visita guiada',
    title: 'Siluetas del siglo XVIII',
    time: '12 H',
    category: 'visitas',
  },
  { day: '21', kind: 'proyección', title: 'Música y moda', time: '20 H', category: 'proyecciones' },
  { day: '23', kind: 'teller', title: 'Atelier abierto', time: '15 H', category: 'talleres' },
  {
    day: '24',
    kind: 'visita guiada',
    title: 'Una pieza, 30 min',
    time: '13 H',
    category: 'visitas',
  },
  {
    day: '25',
    kind: 'exposición',
    title: 'Moda en movimiento',
    time: '10-20 H',
    category: 'exposiciones',
  },
  {
    day: '26',
    kind: 'proyección',
    title: 'Dior, el modisto',
    time: '16 H',
    category: 'proyecciones',
  },
  { day: '27', kind: 'taller', title: 'Patronaje histórico', time: '18 H', category: 'talleres' },
  { day: '29', kind: 'visita guiada', title: 'Nocturna', time: '19-23 H', category: 'visitas' },
];

const filters = [
  ['todo', 'TODO'],
  ['exposiciones', 'EXPOSICIONES'],
  ['visitas', 'VISITAS'],
  ['talleres', 'TALLERES'],
  ['proyecciones', 'PROYECCIONES'],
  ['charlas', 'CHARLAS'],
];
---

<MainLayout
  immersive
  title="Agenda — Junio 2026"
  description="Agenda de junio de 2026 del Palais Galliera."
>
  <section class="agenda-page" data-agenda>
    <nav class="agenda-nav" aria-label="Principal">
      <a class="agenda-nav__logo" href="/" aria-label="Palais Galliera — Inicio">
        <img src="/images/timeline-agenda/agenda-nav-icon.svg" alt="" width="61" height="61" />
      </a>
      <div class="agenda-nav__bar">
        <span class="agenda-nav__label">VISITAR</span>
        <a href="/muestra">EXPOSICIONES</a>
        <a href="/coleccion">COLECCIONES</a>
        <span class="agenda-nav__label">EL MUSEO</span>
        <a class="is-active" href="/agenda" aria-current="page">AGENDA</a>
        <a class="agenda-nav__tickets" href="#evento-04">ENTRADAS</a>
        <span class="agenda-nav__search" aria-hidden="true"></span>
      </div>
    </nav>

    <div class="agenda-layout">
      <header class="agenda-heading">
        <p>AGENDA</p>
        <h1>Junio 2026</h1>
      </header>

      <div class="agenda-program">
        <div class="agenda-filters" role="group" aria-label="Filtrar eventos">
          <div class="agenda-filters__options">
            {
              filters.map(([value, label]) => (
                <button
                  type="button"
                  class="agenda-filter"
                  data-agenda-filter={value}
                  aria-pressed={value === 'todo' ? 'true' : 'false'}
                >
                  {label}
                </button>
              ))
            }
          </div>
          <p><span data-agenda-count>{events.length}</span> EVENTOS</p>
          <p class="sr-only" aria-live="polite" data-agenda-status></p>
        </div>

        <img
          class="agenda-rule"
          src="/images/timeline-agenda/agenda-rule.svg"
          alt=""
          aria-hidden="true"
        />

        <div
          class="agenda-list"
          data-agenda-list
          data-lenis-prevent
          aria-label="Actividades de junio de 2026"
          tabindex="0"
        >
          {
            events.map((event) => (
              <article
                class:list={['agenda-row', { 'is-featured': event.featured }]}
                data-agenda-row
                data-category={event.category}
                id={`evento-${event.day}`}
              >
                {event.featured ? (
                  <button
                    class="agenda-row__header"
                    type="button"
                    aria-expanded="false"
                    aria-controls={`agenda-detail-${event.day}`}
                    data-agenda-toggle
                  >
                    <span class="agenda-row__date">
                      <strong>{event.day}</strong>
                      <span>JUN</span>
                    </span>
                    <span class="agenda-row__kind">{event.kind}</span>
                    <span class="agenda-row__title" id={`agenda-event-title-${event.day}`}>
                      {event.title}
                    </span>
                    <span class="agenda-row__time">{event.time}</span>
                  </button>
                ) : (
                  <div class="agenda-row__header">
                    <span class="agenda-row__date">
                      <strong>{event.day}</strong>
                      <span>JUN</span>
                    </span>
                    <span class="agenda-row__kind">{event.kind}</span>
                    <span class="agenda-row__title">{event.title}</span>
                    <span class="agenda-row__time">{event.time}</span>
                  </div>
                )}

                {event.featured && (
                  <div
                    class="agenda-row__detail"
                    id={`agenda-detail-${event.day}`}
                    role="region"
                    aria-labelledby={`agenda-event-title-${event.day}`}
                    aria-hidden="true"
                    inert
                  >
                    <img
                      class="agenda-row__piece"
                      src="/images/timeline-agenda/agenda-detail.png"
                      alt="Vestido floral del acervo del Palais Galliera"
                    />
                    <div class="agenda-row__copy">
                      <p>
                        Una charla que recorre cómo el vestir del siglo XIX construyó identidad y
                        posición social a través de la silueta: del corsé y la crinolina al polisón,
                        cada estructura moldeó el cuerpo según los códigos de su época. A partir de
                        piezas del acervo Galliera, figurines y prensa de moda, se revisa la
                        transición del taller artesanal a los primeros sistemas de alta costura, y
                        el modo en que la indumentaria volvió visibles las reglas de género y clase
                        del período.
                      </p>
                      <dl>
                        <div>
                          <dt>DURACIÓN</dt>
                          <dd>90 min</dd>
                        </div>
                        <div>
                          <dt>LUGAR</dt>
                          <dd>Auditorio</dd>
                        </div>
                        <div>
                          <dt>HORARIO</dt>
                          <dd>18:00 h</dd>
                        </div>
                      </dl>
                      <button
                        class="agenda-row__reserve"
                        type="button"
                        aria-label="Reservar entradas"
                      >
                        <img src="/images/timeline-agenda/agenda-ticket.png" alt="" />
                      </button>
                    </div>
                  </div>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .agenda-page {
    --agenda-black: #141414;
    --agenda-cream: #f3eee1;
    --agenda-orange: #fd6500;
    --agenda-purple: #520345;
    --agenda-blue: #b9d6fe;
    position: relative;
    isolation: isolate;
    height: 100dvh;
    overflow: hidden;
    color: var(--agenda-black);
    background-color: var(--agenda-cream);
    background-image: url('/images/timeline-agenda/fondo-agenda.svg');
    background-position: 0 0;
    background-size: 100% auto;
    background-repeat: no-repeat;
  }

  .agenda-nav {
    position: relative;
    z-index: 102;
    display: grid;
    grid-template-columns: 61px minmax(0, 889px);
    gap: min(20.05vw, 385px);
    width: min(calc(100% - 6.25vw), 1345px);
    height: 61px;
    margin: 39px 0 0 3.125vw;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .agenda-nav__logo {
    display: grid;
    place-items: center;
    width: 61px;
    height: 61px;
  }

  .agenda-nav__logo img {
    width: 100%;
    height: 100%;
  }

  .agenda-nav__bar {
    display: flex;
    align-items: center;
    gap: 37px;
    width: 889px;
    height: 61px;
    padding: 0 39px;
    color: var(--agenda-cream);
    background: var(--agenda-black);
    transition: color 160ms ease;
  }

  .agenda-nav__bar a,
  .agenda-nav__label {
    flex: 0 0 auto;
  }

  .agenda-nav__bar .is-active {
    color: var(--agenda-orange);
  }

  .agenda-nav__tickets {
    display: grid;
    place-items: center;
    width: 110px;
    height: 32px;
    margin-left: auto;
    color: var(--agenda-cream) !important;
    background: var(--agenda-orange);
    border-radius: 2px;
  }

  .agenda-nav__search {
    position: relative;
    width: 21px;
    height: 21px;
    margin-left: 10px;
  }

  .agenda-nav__search::before,
  .agenda-nav__search::after {
    position: absolute;
    content: '';
  }

  .agenda-nav__search::before {
    inset: 0 5px 5px 0;
    border: 1px solid currentColor;
    border-radius: 50%;
  }

  .agenda-nav__search::after {
    right: 1px;
    bottom: 1px;
    width: 7px;
    height: 1px;
    background: currentColor;
    transform: rotate(45deg);
    transform-origin: right;
  }

  .agenda-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 38.7vw minmax(0, 1120px);
    align-items: start;
    height: calc(100dvh - 219px);
    margin-top: 119px;
  }

  .agenda-heading {
    padding-left: 3.125vw;
  }

  .agenda-heading p {
    position: relative;
    z-index: 1;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .agenda-heading h1 {
    margin-top: 8px;
    color: var(--agenda-orange);
    font-size: clamp(5.8rem, 7.3vw, 8.75rem);
    font-style: normal;
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.02em;
    white-space: nowrap;
    transform: scaleX(0.83);
    transform-origin: left center;
  }

  .agenda-program {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
    height: 100%;
  }

  .agenda-filters {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    height: 39px;
    padding: 0 8px 0 13px;
  }

  .agenda-filters__options {
    display: flex;
    align-items: center;
    gap: clamp(1.7rem, 4.3vw, 5rem);
  }

  .agenda-filter {
    padding: 0;
    color: var(--agenda-black);
    background: none;
    border: 0;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .agenda-filter[aria-pressed='true'] {
    color: var(--agenda-orange);
  }

  .agenda-filters > p {
    padding-right: 1px;
    font-size: 18px;
    white-space: nowrap;
  }

  .agenda-rule {
    display: block;
    width: calc(100% + 8px);
    height: auto;
    margin-left: 0;
  }

  .agenda-list {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
    overflow-y: auto;
    overscroll-behavior: contain;
    background: var(--agenda-cream);
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .agenda-list::-webkit-scrollbar {
    display: none;
  }

  .agenda-list:focus-visible {
    outline-offset: -2px;
  }

  .agenda-row {
    position: relative;
    height: 110px;
    color: var(--agenda-black);
    background: var(--agenda-cream);
    border-bottom: 1px solid var(--agenda-black);
    transition:
      height 420ms cubic-bezier(0.16, 1, 0.3, 1),
      background 220ms ease;
  }

  .agenda-row[hidden] {
    display: none;
  }

  .agenda-row:not(.is-open):hover {
    z-index: 101;
    color: var(--agenda-cream);
    background: linear-gradient(180deg, var(--agenda-purple) 0%, var(--agenda-orange) 100%);
  }

  .agenda-row.is-open {
    height: 424px;
    color: var(--agenda-cream);
    background: linear-gradient(180deg, var(--agenda-purple) 0%, var(--agenda-orange) 100%);
  }

  .agenda-row__header {
    display: grid;
    grid-template-columns: 180px 240px minmax(0, 1fr) 157px;
    align-items: center;
    width: 100%;
    height: 110px;
    padding: 0;
    color: inherit;
    text-align: left;
    background: none;
    border: 0;
  }

  button.agenda-row__header {
    cursor: pointer;
  }

  .agenda-row__date {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-left: 18px;
  }

  .agenda-row__date strong {
    min-width: 67px;
    font-family: var(--font-display);
    font-size: 64px;
    font-style: italic;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .agenda-row__date span,
  .agenda-row__kind,
  .agenda-row__time {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .agenda-row__kind {
    justify-self: center;
    color: var(--agenda-orange);
  }

  .agenda-row__title {
    padding-left: 30px;
    font-size: 32px;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.035em;
  }

  .agenda-row__time {
    justify-self: center;
  }

  .agenda-row__detail {
    position: absolute;
    inset: 110px 0 0;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 250ms ease 90ms,
      visibility 250ms ease 90ms;
  }

  .agenda-row.is-open .agenda-row__detail {
    opacity: 1;
    visibility: visible;
  }

  .agenda-row__piece {
    position: absolute;
    top: -8px;
    left: 127px;
    width: 290px;
    max-width: none;
  }

  .agenda-row__copy {
    position: absolute;
    top: 8px;
    left: 450px;
    width: 520px;
  }

  .agenda-row__copy > p {
    width: 540px;
    font-size: 16px;
    line-height: 1.08;
    transform: scaleX(0.83);
    transform-origin: left top;
  }

  .agenda-row__copy dl {
    position: absolute;
    top: 159px;
    left: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    width: 520px;
    margin: 0;
  }

  .agenda-row__copy dt {
    color: var(--agenda-blue);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .agenda-row__copy dd {
    margin: 1px 0 0;
    font-size: 16px;
  }

  .agenda-row__reserve {
    position: absolute;
    top: 230px;
    left: 0;
    display: grid;
    place-items: center;
    width: 214px;
    height: 44px;
    margin: 0;
    padding: 0;
    color: var(--agenda-cream);
    background: none;
    border: 0;
    cursor: pointer;
  }

  .agenda-row__reserve img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @media (hover: none) {
    .agenda-row:not(.is-open):hover {
      z-index: auto;
      color: var(--agenda-black);
      background: var(--agenda-cream);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .agenda-row,
    .agenda-row__detail {
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  const agenda = document.querySelector<HTMLElement>('[data-agenda]');

  if (agenda) {
    const rows = Array.from(agenda.querySelectorAll<HTMLElement>('[data-agenda-row]'));
    const count = agenda.querySelector<HTMLElement>('[data-agenda-count]');
    const status = agenda.querySelector<HTMLElement>('[data-agenda-status]');
    const filters = agenda.querySelectorAll<HTMLButtonElement>('[data-agenda-filter]');

    const setRowOpen = (row: HTMLElement, open: boolean) => {
      const toggle = row.querySelector<HTMLButtonElement>('[data-agenda-toggle]');
      const detail = row.querySelector<HTMLElement>('.agenda-row__detail');
      row.classList.toggle('is-open', open);
      toggle?.setAttribute('aria-expanded', String(open));
      detail?.setAttribute('aria-hidden', String(!open));
      detail?.toggleAttribute('inert', !open);
    };

    filters.forEach((filter) => {
      filter.addEventListener('click', () => {
        const value = filter.dataset.agendaFilter ?? 'todo';
        let visible = 0;

        filters.forEach((item) => item.setAttribute('aria-pressed', String(item === filter)));
        rows.forEach((row) => {
          const show = value === 'todo' || row.dataset.category === value;
          setRowOpen(row, false);
          row.hidden = !show;
          if (show) visible += 1;
        });

        if (count) count.textContent = String(visible);
        if (status)
          status.textContent = `${visible} eventos visibles: ${filter.textContent?.trim()}`;
      });
    });

    rows.forEach((row) => {
      row
        .querySelector<HTMLButtonElement>('[data-agenda-toggle]')
        ?.addEventListener('click', () => {
          const open = !row.classList.contains('is-open');
          rows.forEach((candidate) => setRowOpen(candidate, candidate === row && open));
        });
    });

    agenda.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      const openRow = rows.find((row) => row.classList.contains('is-open'));
      if (!openRow) return;
      event.preventDefault();
      setRowOpen(openRow, false);
      openRow.querySelector<HTMLButtonElement>('[data-agenda-toggle]')?.focus();
    });
  }
</script>
