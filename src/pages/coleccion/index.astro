  @media (prefers-reduced-motion: reduce) {
    .catalogue *,
    .catalogue *::before,
    .catalogue *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  type CatalogueItem = {
    slug: string;
    image: string;
    title: string;
    year: string;
    byline: string;
    section: string;
    themeIds: string[];
    docTypeId: string;
    periodId: string;
  };

  const catalogue = document.querySelector<HTMLElement>('[data-catalogue]');
  const data = document.getElementById('catalogue-items')?.textContent ?? '[]';
  const items = JSON.parse(data) as CatalogueItem[];
  const orbitData = document.getElementById('catalogue-orbit-positions')?.textContent ?? '[]';
  const orbitPositions = JSON.parse(orbitData) as { x: number; y: number; w: number }[];
  const neighbourPositions = [
    { x: 9.8, y: 62 },
    { x: 23.3, y: 45 },
    { x: 67.2, y: 44 },
    { x: 81.3, y: 65 },
  ];

  if (catalogue && items.length > 0) {
    const mainImage = catalogue.querySelector<HTMLImageElement>('[data-main-image]');
    const title = catalogue.querySelector<HTMLElement>('[data-piece-title]');
    const byline = catalogue.querySelector<HTMLElement>('[data-piece-byline]');
    const section = catalogue.querySelector<HTMLElement>('[data-piece-section]');
    const pieceNumber = catalogue.querySelector<HTMLElement>('[data-piece-number]');
    const countCurrent = catalogue.querySelector<HTMLElement>('[data-count-current]');
    const pieceLink = catalogue.querySelector<HTMLAnchorElement>('[data-piece-link]');
    const mainLink = catalogue.querySelector<HTMLAnchorElement>('[data-main-link]');
    const selectedView = catalogue.querySelector<HTMLElement>('[data-selected-view]');
    const introView = catalogue.querySelector<HTMLElement>('[data-intro-view]');
    const liveRegion = catalogue.querySelector<HTMLElement>('[data-live-region]');
    const sideCards = [...catalogue.querySelectorAll<HTMLButtonElement>('[data-side-card]')];
    const orbitButtons = [...catalogue.querySelectorAll<HTMLButtonElement>('[data-orbit-piece]')];
    const sideOffsets = [-2, -1, 1, 2];
    let currentIndex = 3;
    let changeTimer = 0;
    let orbitTimer = 0;
    let neighbourTimer = 0;
    let orbitLocked = false;
    let neighboursLocked = false;

    const normalized = (index: number) => (index + items.length) % items.length;

    const setNeighbourPosition = (card: HTMLButtonElement, positionIndex: number) => {
      const position = neighbourPositions[positionIndex];
      if (!position) return;
      card.dataset.position = String(positionIndex);
      card.style.setProperty('--neighbour-x', `${position.x}%`);
      card.style.setProperty('--neighbour-y', `${position.y}%`);
    };

    const rotateNeighbours = (delta: number) => {
      if (neighboursLocked) return;

      neighboursLocked = true;
      window.clearTimeout(neighbourTimer);

      sideCards.forEach((card) => {
        const position = Number(card.dataset.position ?? 0);
        const rawTarget = position + delta;
        const target = ((rawTarget % sideCards.length) + sideCards.length) % sideCards.length;
        const wraps = rawTarget < 0 || rawTarget >= sideCards.length;

        if (!wraps) {
          setNeighbourPosition(card, target);
          return;
        }

        card.classList.add('is-wrapping');
        window.setTimeout(() => {
          card.classList.add('is-teleporting');
          setNeighbourPosition(card, target);
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              card.classList.remove('is-teleporting', 'is-wrapping');
            });
          });
        }, 230);
      });

      neighbourTimer = window.setTimeout(() => {
        neighboursLocked = false;
      }, 680);
    };

    const render = (nextIndex: number, announce = true) => {
      const previousIndex = currentIndex;
      currentIndex = normalized(nextIndex);
      if (currentIndex !== previousIndex) {
        const forwardDistance = normalized(currentIndex - previousIndex);
        const backwardDistance = normalized(previousIndex - currentIndex);
        rotateNeighbours(forwardDistance <= backwardDistance ? 1 : -1);
      }
      const current = items[currentIndex];
      const visibleNumber = String(currentIndex + 2).padStart(2, '0');

      catalogue.classList.add('is-changing');
      window.clearTimeout(changeTimer);
      changeTimer = window.setTimeout(() => {
        if (mainImage) {
          mainImage.src = current.image;
          mainImage.alt = current.title;
        }
        if (title) {
          title.textContent = current.title;
          title.toggleAttribute('data-exact-title', currentIndex === 3);
        }
        if (byline) byline.textContent = current.byline;
        if (section) section.textContent = current.section;
        if (pieceNumber) pieceNumber.textContent = `PIEZA ${visibleNumber}/ 42`;
        if (countCurrent) countCurrent.textContent = visibleNumber;
        if (pieceLink) pieceLink.href = `/coleccion/${current.slug}`;
        if (mainLink) {
          mainLink.href = `/coleccion/${current.slug}`;
          mainLink.setAttribute('aria-label', `Abrir ficha de ${current.title}`);
        }

        sideCards.forEach((card, cardIndex) => {
          const positionIndex = Number(card.dataset.position ?? cardIndex);
          const sideIndex = normalized(currentIndex + sideOffsets[positionIndex]);
          const side = items[sideIndex];
          const image = card.querySelector<HTMLImageElement>('[data-side-image]');
          const sideTitle = card.querySelector<HTMLElement>('[data-side-title]');
          const sideYear = card.querySelector<HTMLElement>('[data-side-year]');
          card.dataset.index = String(sideIndex);
          card.setAttribute('aria-label', `Ver ${side.title}, ${side.year}`);
          if (image) image.src = side.image;
          if (sideTitle) sideTitle.textContent = side.title;
          if (sideYear) sideYear.textContent = side.year;
        });

        if (announce && liveRegion) liveRegion.textContent = `${current.title}, ${current.year}`;
        catalogue.classList.remove('is-changing');
      }, 250);
    };

    const selectMode = () => {
      catalogue.dataset.mode = 'selected';
      introView?.setAttribute('aria-hidden', 'true');
      selectedView?.setAttribute('aria-hidden', 'false');
      render(currentIndex, false);
    };

    const setOrbitPosition = (button: HTMLButtonElement, positionIndex: number) => {
      const position = orbitPositions[positionIndex];
      if (!position) return;
      button.dataset.position = String(positionIndex);
      button.style.setProperty('--piece-x', `${position.x}%`);
      button.style.setProperty('--piece-y', `${position.y}%`);
      button.style.setProperty('--piece-w', `${position.w}%`);
      if (positionIndex === 5) button.setAttribute('aria-current', 'true');
      else button.removeAttribute('aria-current');
    };

    const rotateOrbit = (delta: number) => {
      if (orbitLocked || orbitPositions.length !== orbitButtons.length) return;

      orbitLocked = true;
      catalogue.classList.add('is-orbiting');
      window.clearTimeout(orbitTimer);

      let centeredButton: HTMLButtonElement | undefined;
      orbitButtons.forEach((button) => {
        const position = Number(button.dataset.position ?? 0);
        const rawTarget = position + delta;
        const target =
          ((rawTarget % orbitPositions.length) + orbitPositions.length) % orbitPositions.length;
        const wraps = rawTarget < 0 || rawTarget >= orbitPositions.length;

        if (target === 5) centeredButton = button;

        if (!wraps) {
          setOrbitPosition(button, target);
          return;
        }

        button.classList.add('is-wrapping');
        window.setTimeout(() => {
          button.classList.add('is-teleporting');
          setOrbitPosition(button, target);
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              button.classList.remove('is-teleporting', 'is-wrapping');
            });
          });
        }, 230);
      });

      if (centeredButton) {
        currentIndex = Number(centeredButton.dataset.index ?? currentIndex);
        const current = items[currentIndex];
        if (liveRegion) liveRegion.textContent = `Seleccionada ${current.title}, ${current.year}`;
      }

      orbitTimer = window.setTimeout(() => {
        orbitLocked = false;
        catalogue.classList.remove('is-orbiting');
      }, 680);
    };

    catalogue.querySelector('[data-discover]')?.addEventListener('click', selectMode);

    orbitButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const position = Number(button.dataset.position ?? 5);
        let delta = 5 - position;
        const half = orbitButtons.length / 2;
        if (delta > half) delta -= orbitButtons.length;
        if (delta < -half) delta += orbitButtons.length;
        if (delta !== 0) rotateOrbit(delta);
      });
    });

    sideCards.forEach((card) => {
      card.addEventListener('click', () => render(Number(card.dataset.index ?? currentIndex)));
    });

    catalogue.querySelector('[data-previous]')?.addEventListener('click', () => {
      if (catalogue.dataset.mode !== 'selected') rotateOrbit(-1);
      else render(currentIndex - 1);
    });

    catalogue.querySelector('[data-next]')?.addEventListener('click', () => {
      if (catalogue.dataset.mode !== 'selected') rotateOrbit(1);
      else render(currentIndex + 1);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        if (catalogue.dataset.mode === 'selected') render(currentIndex - 1);
        else rotateOrbit(-1);
      }
      if (event.key === 'ArrowRight') {
        if (catalogue.dataset.mode === 'selected') render(currentIndex + 1);
        else rotateOrbit(1);
      }
    });

    const params = new URLSearchParams(window.location.search);
    const theme = params.get('tema');
    const type = params.get('tipo');
    const period = params.get('periodo');
    if (theme || type || period) {
      const filteredIndex = items.findIndex(
        (item) =>
          (!theme || item.themeIds.includes(theme)) &&
          (!type || item.docTypeId === type) &&
          (!period || item.periodId === period)
      );
      if (filteredIndex >= 0) {
        currentIndex = filteredIndex;
        selectMode();
      }
    }
  }
</script>
