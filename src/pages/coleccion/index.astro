---
/**
 * Colección (/coleccion) — visor curatorial basado en los frames Figma
 * 1:291 (portada) y 1:1348 (pieza seleccionada).
 */
import MainLayout from '@layouts/MainLayout.astro';
import { pieces } from '@data/collection';

const curated = [
  {
    slug: 'vestido-gasa-1790',
    image: '/images/catalogo/c10.png',
    title: 'Robe à la française',
    year: 'c. 1760–1775',
  },
  {
    slug: 'redingote',
    image: '/images/catalogo/c06.png',
    title: 'Robe et tablier de jupe de robe',
    year: 'c. 1730–1750',
  },
  {
    slug: 'casaca-bordada',
    image: '/images/catalogo/c05.png',
    title: 'Robe et tablier de jupe à la française',
    year: 'c. 1730',
  },
  {
    slug: 'robe-francaise-1760',
    image: '/images/catalogo/c04.png',
    title: 'Ensemble (habillement)',
    year: 'c. 1755–1765',
    byline: 'Anónimo · c. 1755–1765 · lampás de seda',
    section: 'Vêtements et accessoires de vêtement',
  },
  {
    slug: 'vestido-corte',
    image: '/images/catalogo/c02.png',
    title: 'Robe à la française',
    year: 'c. 1780',
  },
  {
    slug: 'robe-polonaise',
    image: '/images/catalogo/c11.png',
    title: 'Robe à la française',
    year: 'c. 1760–1775',
  },
  {
    slug: 'robe-anglaise',
    image: '/images/catalogo/c07.png',
    title: 'Robe à la française',
    year: 'c. 1755–1765',
  },
  {
    slug: 'chaleco-courtois',
    image: '/images/catalogo/c09.png',
    title: 'Robe à la française',
    year: 'c. 1770',
  },
  {
    slug: 'robe-francaise-1730',
    image: '/images/catalogo/c03.png',
    title: 'Robe à la française',
    year: 'c. 1760–1775',
  },
  {
    slug: 'robe-francaise-1730',
    image: '/images/catalogo/c12.png',
    title: 'Robe et tablier de jupe de robe',
    year: 'c. 1730–1750',
  },
  {
    slug: 'caraco-falda',
    image: '/images/catalogo/c14.png',
    title: 'Robe à la française',
    year: 'c. 1755–1765',
  },
];

const catalogueItems = curated.flatMap((entry) => {
  const piece = pieces.find((candidate) => candidate.slug === entry.slug);
  if (!piece) return [];

  return [
    {
      ...entry,
      byline: entry.byline ?? `${piece.designer ?? 'Anónimo'} · ${entry.year} · ${piece.material}`,
      section: entry.section ?? piece.section ?? 'Vêtements et accessoires de vêtement',
      themeIds: piece.themeIds,
      docTypeId: piece.docTypeId,
      periodId: piece.periodId,
    },
  ];
});

const initialIndex = 3;
const initialItem = catalogueItems[initialIndex];
const introCenterPosition = 5;
const introOrder = catalogueItems.map(
  (_, position) =>
    (initialIndex + position - introCenterPosition + catalogueItems.length) % catalogueItems.length
);
const introPositions = [
  { x: 14.3, y: 92.5, w: 5.1 },
  { x: 16.9, y: 71.4, w: 6 },
  { x: 21.4, y: 51.4, w: 5.7 },
  { x: 29.6, y: 36.6, w: 5.9 },
  { x: 39.4, y: 28.3, w: 5.2 },
  { x: 49.7, y: 22.9, w: 5.2 },
  { x: 60.6, y: 29.1, w: 5.9 },
  { x: 71, y: 37, w: 5.3 },
  { x: 79.3, y: 51.4, w: 5.4 },
  { x: 82.9, y: 71, w: 5.7 },
  { x: 85.3, y: 92.2, w: 6.1 },
];
const selectedNeighbourPositions = [
  { x: 9.8, y: 62 },
  { x: 23.3, y: 45 },
  { x: 67.2, y: 44 },
  { x: 81.3, y: 65 },
];
---

<MainLayout
  title="Colección — Robe à la française"
  description="Una selección inmersiva de indumentaria del siglo XVIII del acervo del Palais Galliera."
  immersive
>
  <div class="collection-shell">
    <header class="collection-nav">
      <a class="collection-nav__logo" href="/" aria-label="Palais Galliera — Inicio">
        <img src="/images/collection-fidelity/catalogue-logo.svg" alt="" />
      </a>

      <nav class="collection-nav__bar" aria-label="Principal">
        <a href="/historia">Visitar</a>
        <a href="/muestra">Exposiciones</a>
        <a class="is-active" href="/coleccion-permanente">Colecciones</a>
        <a href="/historia">El museo</a>
        <a href="/agenda">Agenda</a>
        <a class="collection-nav__tickets" href="/agenda">Entradas</a>
        <a class="collection-nav__search" href="/coleccion" aria-label="Buscar en la colección">
          <img src="/images/collection-fidelity/catalogue-search.svg" alt="" />
        </a>
      </nav>
    </header>

    <section class="catalogue" data-catalogue data-mode="intro" aria-labelledby="catalogue-title">
      <div class="catalogue__arch" aria-hidden="true"></div>

      <div class="catalogue__intro" data-intro-view>
        <div class="catalogue__orbit" aria-label="Piezas de la selección">
          {
            introOrder.map((itemIndex, orbitIndex) => {
              const item = catalogueItems[itemIndex];
              const position = introPositions[orbitIndex];
              return (
                <button
                  class="catalogue__orbit-piece"
                  type="button"
                  data-orbit-piece
                  data-index={itemIndex}
                  data-position={orbitIndex}
                  style={`--piece-x:${position.x}%;--piece-y:${position.y}%;--piece-w:${position.w}%;`}
                  aria-label={`Ver ${item.title}, ${item.year}`}
                  aria-current={orbitIndex === initialIndex ? 'true' : undefined}
                >
                  <img src={item.image} alt="" />
                </button>
              );
            })
          }
        </div>

        <h1 class="catalogue__title" id="catalogue-title">
          <img src="/images/collection-fidelity/catalogue-title.png" alt="" aria-hidden="true" />
          <span class="sr-only">Robe à la française</span>
        </h1>

        <div class="catalogue__intro-meta">
          <p>
            <img
              src="/images/collection-fidelity/catalogue-selection.png"
              alt=""
              aria-hidden="true"
            />
            <span class="sr-only">Selección siglo XVIII, 1700 a 1800, 42 piezas</span>
          </p>
          <button class="catalogue__discover" type="button" data-discover aria-label="Descubrir">
            <img
              src="/images/collection-fidelity/catalogue-discover.png"
              alt=""
              aria-hidden="true"
            />
          </button>
        </div>
      </div>

      <div class="catalogue__selected" data-selected-view aria-hidden="true">
        <div class="catalogue__piece-copy">
          <p class="catalogue__eyebrow" data-piece-number>PIEZA 05/ 42</p>
          <h2 data-piece-title data-exact-title>{initialItem.title}</h2>
          <p class="catalogue__byline" data-piece-byline>{initialItem.byline}</p>
          <p class="catalogue__section" data-piece-section>{initialItem.section}</p>
          <span class="catalogue__rule" aria-hidden="true"></span>
          <a class="catalogue__piece-link" href={`/coleccion/${initialItem.slug}`} data-piece-link>
            Ver ficha <span aria-hidden="true">→</span>
          </a>
          <p class="catalogue__count">
            <span data-count-current>05</span>
            <em>/ 42</em>
          </p>
        </div>

        <p class="catalogue__selection-meta">
          COLECCIÓN · ROBE À LA FRANÇAISE — SIGLO XVIII<br />
          1700 — 1800 · 42 PIEZAS
        </p>

        <a
          class="catalogue__main-piece"
          href={`/coleccion/${initialItem.slug}`}
          data-main-link
          aria-label={`Abrir ficha de ${initialItem.title}`}
        >
          <img src={initialItem.image} alt={initialItem.title} data-main-image />
        </a>

        <div class="catalogue__neighbours" aria-label="Piezas próximas">
          {
            [-2, -1, 1, 2].map((offset, neighbourIndex) => {
              const index = (initialIndex + offset + catalogueItems.length) % catalogueItems.length;
              const item = catalogueItems[index];
              const position = selectedNeighbourPositions[neighbourIndex];
              return (
                <button
                  class="catalogue__neighbour"
                  type="button"
                  data-side-card
                  data-index={index}
                  data-position={neighbourIndex}
                  style={`--neighbour-x:${position.x}%;--neighbour-y:${position.y}%;`}
                >
                  <img src={item.image} alt="" data-side-image />
                  <span class="catalogue__neighbour-title" data-side-title>
                    {item.title}
                  </span>
                  <span class="catalogue__neighbour-year" data-side-year>
                    {item.year}
                  </span>
                </button>
              );
            })
          }
        </div>
      </div>

      <div class="catalogue__controls" aria-label="Navegar por la colección">
        <button type="button" data-previous aria-label="Pieza anterior">
          <img src="/images/collection-fidelity/museum-arrow.svg" alt="" />
        </button>
        <button type="button" data-next aria-label="Pieza siguiente">
          <img src="/images/collection-fidelity/museum-arrow.svg" alt="" />
        </button>
      </div>

      <p class="sr-only" aria-live="polite" data-live-region></p>
    </section>
  </div>
</MainLayout>

<script
  is:inline
  type="application/json"
  id="catalogue-items"
  set:html={JSON.stringify(catalogueItems)}
/>
<script
  is:inline
  type="application/json"
  id="catalogue-orbit-positions"
  set:html={JSON.stringify(introPositions)}
/>

<style>
  .collection-shell {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 49.5rem;
    overflow: hidden;
    background: #141414;
  }

  .collection-nav {
    position: absolute;
    inset: 0;
    z-index: 30;
    pointer-events: none;
  }

  .collection-nav__logo {
    position: absolute;
    top: 3.61%;
    left: 3.125%;
    width: max(3.177%, 3rem);
    aspect-ratio: 1;
    pointer-events: auto;
    transition: transform 180ms ease;
  }

  .collection-nav__logo:hover,
  .collection-nav__logo:focus-visible {
    transform: scale(1.06);
  }

  .collection-nav__logo img {
    width: 100%;
    height: 100%;
  }

  .collection-nav__bar {
    position: absolute;
    top: 3.61%;
    left: 26.3%;
    width: 46.35%;
    height: clamp(3.5rem, 5.65vh, 3.8125rem);
    color: #f3eee1;
    background: #fd6500;
    pointer-events: auto;
  }

  .collection-nav__bar > a {
    position: absolute;
    top: 50%;
    color: inherit;
    font-size: clamp(0.65rem, 0.729vw, 0.875rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
    text-transform: uppercase;
    transform: translateY(-50%);
    transition:
      color 160ms ease,
      background-color 160ms ease;
  }

  .collection-nav__bar > a:hover,
  .collection-nav__bar > a:focus-visible,
  .collection-nav__bar > a.is-active {
    color: #141414;
  }

  .collection-nav__bar > a:nth-child(1) {
    left: 4.382%;
  }
  .collection-nav__bar > a:nth-child(2) {
    left: 14.944%;
  }
  .collection-nav__bar > a:nth-child(3) {
    left: 30.787%;
  }
  .collection-nav__bar > a:nth-child(4) {
    left: 46.18%;
  }
  .collection-nav__bar > a:nth-child(5) {
    left: 58.54%;
  }

  .collection-nav__bar > .collection-nav__tickets {
    top: 22.95%;
    left: 75.73%;
    display: grid;
    width: 12.36%;
    height: 52.46%;
    place-items: center;
    color: #f3eee1;
    border-radius: 2px;
    background: #141414;
    transform: none;
  }

  .collection-nav__bar > .collection-nav__tickets:hover,
  .collection-nav__bar > .collection-nav__tickets:focus-visible {
    color: #141414;
    background: #f3eee1;
  }

  .collection-nav__bar > .collection-nav__search {
    right: 4.28%;
    width: 2.14%;
    height: 33%;
  }

  .collection-nav__search img {
    width: 100%;
    height: 100%;
  }

  .catalogue {
    --ink: #141414;
    --orange: #fd6500;
    --cream: #f3eee1;
    position: absolute;
    top: clamp(4rem, 5vw, 4.5rem);
    right: 0;
    left: 0;
    min-height: calc(100svh - clamp(4rem, 5vw, 4.5rem));
    height: min(1079px, calc(100svh - clamp(4rem, 5vw, 4.5rem)));
    overflow: hidden;
    color: var(--cream);
    background: var(--ink);
    isolation: isolate;
  }

  .catalogue__arch {
    position: absolute;
    z-index: -1;
    top: 25.8%;
    left: 50%;
    width: 71.25%;
    height: 102.1%;
    border: 1px solid var(--orange);
    border-radius: 1000px 1000px 0 0;
    transform: translateX(-50%);
    transition:
      top 700ms cubic-bezier(0.76, 0, 0.24, 1),
      width 700ms cubic-bezier(0.76, 0, 0.24, 1),
      height 700ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  .catalogue__arch::after {
    position: absolute;
    inset: 0.25rem;
    border: 1px solid var(--orange);
    border-radius: inherit;
    content: '';
  }

  .catalogue[data-mode='selected'] .catalogue__arch {
    top: 46%;
    width: calc(100% - 2.25rem);
    height: 165%;
  }

  .catalogue__intro,
  .catalogue__selected {
    position: absolute;
    inset: 0;
    transition:
      opacity 500ms ease,
      transform 700ms cubic-bezier(0.76, 0, 0.24, 1),
      visibility 0s linear 500ms;
  }

  .catalogue__intro {
    opacity: 1;
    transform: none;
  }

  .catalogue__selected {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(3rem);
  }

  .catalogue[data-mode='selected'] .catalogue__intro {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.96);
  }

  .catalogue[data-mode='selected'] .catalogue__selected {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transform: none;
    transition-delay: 180ms, 120ms, 0s;
  }

  .catalogue__title {
    position: absolute;
    top: 49.3%;
    left: 50%;
    width: min(42.5625rem, 35.5vw);
    margin: 0;
    transform: translateX(-50%);
  }

  .catalogue__title img {
    display: block;
    width: 100%;
    height: auto;
  }

  .catalogue__orbit {
    position: absolute;
    inset: 0;
  }

  .catalogue__orbit-piece {
    position: absolute;
    top: var(--piece-y);
    left: var(--piece-x);
    width: var(--piece-w);
    height: 16%;
    padding: 0;
    overflow: visible;
    color: inherit;
    background: transparent;
    border: 0;
    cursor: pointer;
    transform: translate(-50%, -50%);
    transition:
      top 620ms cubic-bezier(0.76, 0, 0.24, 1),
      left 620ms cubic-bezier(0.76, 0, 0.24, 1),
      width 620ms cubic-bezier(0.76, 0, 0.24, 1),
      opacity 220ms ease,
      transform 260ms ease;
  }

  .catalogue.is-orbiting .catalogue__orbit-piece {
    pointer-events: none;
  }

  .catalogue__orbit-piece.is-wrapping {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.72);
  }

  .catalogue__orbit-piece.is-teleporting {
    transition: none;
  }

  .catalogue__orbit-piece:hover,
  .catalogue__orbit-piece:focus-visible {
    z-index: 3;
    transform: translate(-50%, -50%) scale(1.12);
  }

  .catalogue__orbit-piece img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 10px 15px rgb(0 0 0 / 36%));
  }

  .catalogue__intro-meta {
    position: absolute;
    bottom: 8.55%;
    left: 35%;
    width: 29.27%;
    height: min(2rem, 1.67vw);
    color: var(--cream);
  }

  .catalogue__intro-meta p,
  .catalogue__eyebrow,
  .catalogue__selection-meta,
  .catalogue__piece-link,
  .catalogue__neighbour-year {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .catalogue__intro-meta p {
    position: absolute;
    top: 21.875%;
    left: 0;
    width: 70.82%;
    height: 46.875%;
    font-size: min(1rem, 0.833vw);
    font-weight: 400;
    line-height: 0;
    letter-spacing: 0.06em;
    text-align: right;
    text-transform: capitalize;
    white-space: pre;
  }

  .catalogue__discover {
    position: absolute;
    top: 0;
    right: 0;
    width: 19.57%;
    height: 100%;
    padding: 0;
    color: var(--cream);
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .catalogue__intro-meta p > img,
  .catalogue__discover > img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .catalogue__piece-copy {
    position: absolute;
    z-index: 4;
    top: 9%;
    left: 3.1%;
    width: min(41%, 49rem);
    text-shadow: 0 1px 5px rgb(0 0 0 / 70%);
  }

  .catalogue__eyebrow {
    color: var(--orange);
  }

  .catalogue__piece-copy h2 {
    max-width: 44rem;
    margin: 0.5rem 0 0;
    color: var(--cream);
    font-family: var(--font-display);
    font-size: clamp(5.25rem, 6.7vw, 8rem);
    font-weight: 100;
    line-height: 0.953;
    letter-spacing: -0.025em;
  }

  .catalogue__piece-copy h2[data-exact-title] {
    width: 36.4375rem;
    max-width: none;
    height: auto;
    aspect-ratio: 583 / 244;
    margin-top: 0.9375rem;
    color: transparent;
    background: url('/images/collection-fidelity/catalogue-piece-title.png') left top / 100% 100%
      no-repeat;
    font-size: 0;
    line-height: 0;
    text-shadow: none;
  }

  .catalogue__piece-copy h2[data-exact-title] + .catalogue__byline {
    margin-top: 1.375rem;
  }

  .catalogue__byline,
  .catalogue__section {
    margin: 1.65rem 0 0;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.15;
  }

  .catalogue__section {
    margin-top: 0.1rem;
  }

  .catalogue__rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    margin-top: 1.1rem;
    background: var(--cream);
  }

  .catalogue__piece-link {
    display: inline-flex;
    gap: 0.4rem;
    margin-top: 1rem;
    color: var(--cream);
  }

  .catalogue__piece-link:hover {
    color: var(--orange);
  }

  .catalogue__count {
    margin: 3.55rem 0 0;
    font-size: 1rem;
    font-weight: 300;
  }

  .catalogue__count em {
    color: var(--orange);
    font-style: normal;
  }

  .catalogue__selection-meta {
    position: absolute;
    z-index: 4;
    top: 9.5%;
    right: 3.5%;
    color: var(--orange);
    line-height: 1.55;
    text-align: right;
  }

  .catalogue__main-piece {
    position: absolute;
    z-index: 2;
    top: 0.6%;
    left: 29.79%;
    width: 40.47%;
    height: 103%;
    margin: 0;
    outline-offset: -0.25rem;
  }

  .catalogue__main-piece img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 18px 24px rgb(0 0 0 / 32%));
    transition:
      opacity 180ms ease,
      transform 500ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  .catalogue.is-changing .catalogue__main-piece img {
    opacity: 0;
    transform: translateY(1rem) scale(0.97);
  }

  .catalogue__main-piece:hover img,
  .catalogue__main-piece:focus-visible img {
    transform: scale(1.015);
  }

  .catalogue__neighbours {
    position: absolute;
    inset: 0;
  }

  .catalogue__neighbour {
    position: absolute;
    z-index: 3;
    top: var(--neighbour-y);
    left: var(--neighbour-x);
    width: 10%;
    padding: 0;
    color: var(--cream);
    text-align: left;
    background: transparent;
    border: 0;
    cursor: pointer;
    transition:
      top 620ms cubic-bezier(0.76, 0, 0.24, 1),
      left 620ms cubic-bezier(0.76, 0, 0.24, 1),
      opacity 180ms ease,
      transform 260ms ease;
  }

  .catalogue__neighbour.is-wrapping {
    opacity: 0;
    transform: scale(0.82);
  }

  .catalogue__neighbour.is-teleporting {
    transition: none;
  }

  .catalogue__neighbour:hover,
  .catalogue__neighbour:focus-visible {
    transform: translateY(-0.75rem);
  }

  .catalogue__neighbour img {
    display: block;
    width: 100%;
    height: 21vh;
    max-height: 15rem;
    object-fit: contain;
  }

  .catalogue__neighbour-title,
  .catalogue__neighbour-year {
    display: block;
  }

  .catalogue__neighbour-title {
    margin-top: 0.4rem;
    font-size: 1rem;
    line-height: 1.1;
  }

  .catalogue__neighbour-year {
    margin-top: 0.35rem;
    color: var(--orange);
  }

  .catalogue__controls {
    position: absolute;
    z-index: 8;
    right: 3.2%;
    bottom: 14%;
    left: 3.2%;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .catalogue__controls button {
    width: 2.6rem;
    height: 2.6rem;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    pointer-events: auto;
    transition: transform 200ms ease;
  }

  .catalogue__controls button:hover,
  .catalogue__controls button:focus-visible {
    transform: scale(1.12);
  }

  .catalogue__controls button:last-child img {
    transform: rotate(180deg);
  }

  .catalogue__controls img {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (min-width: 901px) {
    .catalogue__neighbour {
      width: var(--card-width);
    }

    .catalogue__neighbour img {
      width: var(--image-width);
      height: auto;
      max-height: none;
    }

    .catalogue__neighbour-title,
    .catalogue__neighbour-year {
      width: var(--copy-width);
