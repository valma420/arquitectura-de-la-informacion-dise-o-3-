---
/**
 * Ficha de objeto — traducción de los frames Figma 15:3009 y
 * 1:1187 / 1:1207 / 1:1227 / 1:1247 / 1:1267.
 */
import MainLayout from '@layouts/MainLayout.astro';
import { getPeriod, pieces } from '@data/collection';

export function getStaticPaths() {
  const objectDetailSlug = 'robe-francaise-1760';

  return pieces
    .filter((piece) => piece.slug === objectDetailSlug)
    .map((piece) => ({ params: { slug: piece.slug }, props: { piece } }));
}

const { piece } = Astro.props;
const period = getPeriod(piece.periodId);
const isFigmaFeature = piece.slug === 'robe-francaise-1760';

const catalogueImages: Record<string, string> = {
  'robe-francaise-1730': '/images/catalogo/c01.png',
  'vestido-corte': '/images/catalogo/c02.png',
  'caraco-falda': '/images/catalogo/c03.png',
  'robe-francaise-1760': '/images/catalogo/c14.png',
  'casaca-bordada': '/images/catalogo/c05.png',
  redingote: '/images/catalogo/c06.png',
  'robe-anglaise': '/images/catalogo/c07.png',
  'robe-polonaise': '/images/catalogo/c08.png',
  'vestido-gasa-1790': '/images/catalogo/c09.png',
  'chaleco-courtois': '/images/catalogo/c10.png',
};

const featureImage = catalogueImages[piece.slug] ?? piece.image;
const detailImage = isFigmaFeature
  ? '/images/collection-fidelity/robe/zoom-dress.png'
  : featureImage;
const yearMatches = piece.yearLabel.match(/\d{4}/g) ?? [String(piece.year)];
const firstYear = isFigmaFeature ? '1755' : yearMatches[0];
const lastYear = isFigmaFeature ? '1765' : (yearMatches.at(-1) ?? yearMatches[0]);
const displayTitle = isFigmaFeature ? 'Robe à la française' : piece.title;
const displayByline = isFigmaFeature
  ? 'ANÓNIMO · FRANCIA, C. 1755–1765'
  : `${piece.designer ?? 'ANÓNIMO'} · ${piece.origin ?? 'FRANCIA'}, ${piece.yearLabel}`.toUpperCase();
const periodCaption = isFigmaFeature
  ? 'SIGLO XVIII — REINADO DE LUIS XV'
  : `${period?.name ?? 'COLECCIÓN'} — ${piece.section ?? 'INDUMENTARIA'}`.toUpperCase();
const description = isFigmaFeature
  ? 'Conjunto de vestido y falda «à la française», la silueta cortesana por excelencia del siglo XVIII. Corpiño abierto que forma cola, frentes ribeteados con falbalás acolchados en algodón; espalda con dobles pliegues planos (pliegue Watteau). Se llevaba sobre paniers laterales.'
  : piece.description;

const metadata = [
  ['N° DE INVENTARIO', isFigmaFeature ? 'GAL1958.86.2' : (piece.inv ?? '—')],
  ['DENOMINACIÓN', displayTitle],
  ['AUTOR', isFigmaFeature ? 'Anónimo' : (piece.designer ?? 'Anónimo')],
  ['DATACIÓN', isFigmaFeature ? 'c. 1755–1765' : piece.yearLabel],
  ['PERÍODO', isFigmaFeature ? 'Luis XV (1715–1774)' : (period?.name ?? '—')],
  ['MATERIALES', isFigmaFeature ? 'Lampás, seda, tafetán, lino' : (piece.material ?? '—')],
  ['TÉCNICA', isFigmaFeature ? 'Tejido façonné · pasamanería' : (piece.technique ?? '—')],
  ['ADQUISICIÓN', isFigmaFeature ? '28 / 03 / 1958' : (piece.acquisition ?? '—')],
];

const exactDetails = [
  {
    title: 'Silueta · Panier',
    description:
      'La falda se extiende sobre paniers laterales, ensanchando la cadera y estrechando visualmente el talle. Definió la silueta cortesana del período.',
    crop: '100% center',
    size: 'auto 100%',
    zoomSrc: '/images/collection-fidelity/robe/zoom-panier.png',
    thumb: '/images/collection-fidelity/robe/zoom-thumb-panier-a.png',
    backgroundSrc: '/images/collection-fidelity/robe/zoom-background-panier.png',
    figureSrc: '/images/collection-fidelity/robe/zoom-panier-diagram-figma.svg',
    figureVariant: 'panier',
    figureLabel: 'Esquema constructivo',
    figureCaption: 'Estructura interna · vista frontal',
    noteLabel: 'Sobre su uso',
    note: 'Los paniers ceremoniales podían alcanzar más de un metro y medio de ancho, restringiendo el paso a través de puertas y obligando a caminar de costado.',
    related: [
      {
        title: 'Robe à la française',
        year: 'c. 1780',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-panier-a.png',
      },
      {
        title: 'Robe à la française',
        year: 'c. 1770-1780',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-panier-b.png',
      },
      {
        title: 'Robe et tablier de jupe à la française',
        year: 'c. 1730',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-panier-c.png',
      },
    ],
  },
  {
    title: 'Fabalás',
    description:
      'Volantes de seda fruncidos sobre relleno de algodón que ribetean el frente del corpiño. Su volumen se logra por acolchado interior, no por múltiples capas de tela.',
    crop: 'center',
    size: '100%',
    zoomSrc: '/images/collection-fidelity/robe/zoom-fabalas.png',
    thumb: '/images/collection-fidelity/robe/zoom-thumb-fabalas-a.png',
    backgroundSrc: '/images/collection-fidelity/robe/zoom-background-fabalas.png',
    figureSrc: '/images/collection-fidelity/robe/zoom-fabalas-cross.svg',
    figureLabel: 'Corte transversal',
    figureCaption: 'Tres capas · seda, algodón, base',
    noteLabel: 'Origen del término',
    note: 'Del italiano falpalà, se popularizó en la corte francesa a comienzos del siglo XVIII. El acolchado con algodón permitía obtener volumen sin sumar capas de seda, ahorrando material y peso en un tejido costoso.',
    related: [
      {
        title: 'Robe et jupe',
        year: 'c. 1780',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-fabalas-a.png',
      },
      {
        title: 'Robe, jupe de robe et morceaux',
        year: 'c. 1750-1760',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-fabalas-b.png',
      },
      {
        title: 'Robe et jupe à la française',
        year: 'c. 1750-1760',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-fabalas-c.png',
      },
    ],
  },
  {
    title: 'Lampás de seda',
    description:
      'Tejido façonné de doble urdimbre y doble trama. El motivo floral se obtiene en el tejido mismo, sin bordado ni estampación. Manufactura probable: Lyon, centro europeo de la seda del siglo XVIII.',
    crop: 'center',
    size: '100%',
    zoomSrc: '/images/collection-fidelity/robe/zoom-lampas.png',
    thumb: '/images/collection-fidelity/robe/zoom-thumb-lampas-a.png',
    backgroundSrc: '/images/collection-fidelity/robe/zoom-background-lampas.png',
    figureSrc: '/images/collection-fidelity/robe/zoom-lampas-weave.svg',
    figureLabel: 'Estructura del tejido',
    figureCaption: 'Doble urdimbre · doble trama',
    noteLabel: 'Manufactura',
    note: 'La producción de lampás en Lyon estaba protegida como industria estratégica de la corona francesa. El motivo se drafteaba previamente en una grilla técnica llamada mise-en-carte, plano de programación del telar. Un solo vestido podía requerir varios meses de trabajo.',
    related: [
      {
        title: "Robe et pièce d'estomac",
        year: 'c. 1740-1755',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-lampas-a.png',
      },
      {
        title: 'Robe, jupe de robe et morceaux',
        year: 'c. 1750-1780',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-lampas-b.png',
      },
      {
        title: 'Robe et tablier de jupe de robe',
        year: 'c. 1730-1750',
        thumb: '/images/collection-fidelity/robe/zoom-thumb-lampas-c.png',
      },
    ],
  },
];

const genericDetails = [
  {
    ...exactDetails[0],
    title: 'Construcción',
    description: piece.technique ?? 'Confección y terminaciones realizadas a mano.',
  },
  {
    ...exactDetails[1],
    title: 'Mangas',
    description: 'Volumen, caída y terminaciones que estructuran la parte superior.',
  },
  {
    ...exactDetails[2],
    title: 'Ornamento',
    description: piece.material ?? 'Textiles y ornamentos seleccionados para la pieza.',
  },
  {
    ...exactDetails[3],
    title: 'Materia',
    description: piece.material ?? 'Textiles conservados por el Palais Galliera.',
  },
  {
    ...exactDetails[4],
    title: 'Silueta',
    description: piece.description,
  },
];

const details = (isFigmaFeature ? exactDetails : genericDetails).slice(0, 3);
const hotspots = isFigmaFeature
  ? [
      { x: 36, y: 40 },
      { x: 59, y: 64 },
      { x: 82, y: 79 },
    ]
  : [
      { x: 29, y: 32 },
      { x: 50, y: 23 },
      { x: 60, y: 32 },
    ];
---

<MainLayout immersive title={`${displayTitle} — Colección`} description={description}>
  <article class:list={['object', { 'object--feature': isFigmaFeature }]} data-object-page>
    <a class="object__back" href="/coleccion">
      {
        isFigmaFeature ? (
          <img
            src="/images/collection-fidelity/robe/back-to-collection.svg"
            alt="Volver a la colección"
          />
        ) : (
          <span>Volver a la colección</span>
        )
      }
    </a>

    {
      isFigmaFeature && (
        <img
          class="object__fidelity-copy"
          src="/images/collection-fidelity/robe/object-texture.png"
          alt=""
          aria-hidden="true"
        />
      )
    }

    <div class="object__timeline" aria-hidden="true">
      <span class="object__year object__year--first">{firstYear}</span>
      <img
        class="object__year-flower object__year-flower--first"
        src="/images/collection-fidelity/hotspot-flower.svg"
        alt=""
      />
      <span class="object__timeline-line"></span>
      <span class="object__year object__year--last">{lastYear}</span>
      <img
        class="object__year-flower object__year-flower--last"
        src="/images/collection-fidelity/hotspot-flower.svg"
        alt=""
      />
    </div>

    <section class="object__copy" aria-labelledby="object-title">
      <p class="object__period">{periodCaption}</p>
      <h1 id="object-title">{displayTitle}</h1>
      <p class="object__byline">{displayByline}</p>
      <p class="object__description">{description}</p>

      <dl class="object__meta">
        {
          metadata.map(([label, value]) => (
            <div class="object__meta-row">
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <figure class="object__media">
      <img src={featureImage} alt={displayTitle} />
      <figcaption class="sr-only">
        Seleccioná los puntos celestes para explorar detalles de la pieza.
      </figcaption>
      {
        hotspots.map((hotspot, index) => (
          <button
            class="object__hotspot"
            type="button"
            style={`--hotspot-x:${hotspot.x}%;--hotspot-y:${hotspot.y}%;`}
            data-hotspot
            data-index={index}
            data-label={details[index].title}
            aria-label={`Explorar detalle: ${details[index].title}`}
            aria-controls="object-detail-viewer"
          >
            <img src="/images/collection-fidelity/hotspot-flower.svg" alt="" />
          </button>
        ))
      }
    </figure>

    {
      isFigmaFeature && (
        <aside class="object__feature-notes" aria-label="Vistas y patrón de la pieza">
          <section>
            <h2>Vistas</h2>
            <div class="object__views" aria-hidden="true">
              <img src="/images/collection-fidelity/robe/views-a.svg" alt="" />
              <img src="/images/collection-fidelity/robe/views-b.svg" alt="" />
              <img src="/images/collection-fidelity/robe/views-c.svg" alt="" />
            </div>
            <p>
              Las tres vistas muestran los elementos constructivos que definen la tipología: pliegue
              Watteau en la espalda, estomacar al frente y volumen lateral generado por paniers.
            </p>
          </section>
          <section>
            <h2>Patrón</h2>
            <img
              class="object__pattern"
              src="/images/collection-fidelity/robe/pattern.svg"
              alt=""
            />
            <p>
              Lampás de seda, tejido façonné con motivos florales en repetición vertical. Producción
              probable: Lyon, centro europeo de la seda del siglo XVIII.
            </p>
          </section>
        </aside>
      )
    }

    <button
      class="object__detail-entry"
      type="button"
      data-detail-entry
      aria-label="Explorar detalles"
    >
      <img
        src={isFigmaFeature
          ? '/images/collection-fidelity/robe/arrow-down.svg'
          : '/images/collection-fidelity/museum-arrow.svg'}
        alt=""
      />
    </button>
  </article>

  <section
    class="detail-viewer"
    id="object-detail-viewer"
    data-detail-viewer
    data-index="0"
    style={`--detail-background:url('${details[0].backgroundSrc}');--detail-zoom:url('${detailImage}');`}
    role="dialog"
    aria-modal="true"
    aria-labelledby="detail-title"
    aria-hidden="true"
    hidden
  >
    <a class="detail-viewer__back" href="/coleccion">
      <img
        src="/images/collection-fidelity/robe/back-to-collection.svg"
        alt="Volver a la colección"
      />
    </a>

    <button
      class="detail-viewer__close"
      type="button"
      data-detail-close
      aria-label="Cerrar detalle"
    >
      <span aria-hidden="true">×</span>
    </button>

    <div class="detail-viewer__progress" aria-hidden="true">
      <span data-progress-segment></span>
    </div>

    <div class="detail-viewer__thumbs" aria-label="Piezas relacionadas">
      {
        details[0].related.map((related, relatedIndex) => (
          <button type="button" data-detail-thumb data-index={relatedIndex} disabled>
            <img src={related.thumb} alt="" data-detail-thumb-image />
            <span data-detail-thumb-title>{related.title}</span>
            <em data-detail-thumb-year>{related.year}</em>
          </button>
        ))
      }
    </div>

    <div
      class="detail-viewer__focus"
      data-detail-focus
      style={`--crop:${details[0].crop};--crop-size:${details[0].size};`}
      aria-hidden="true"
    >
    </div>

    <div class="detail-viewer__copy">
      <h2 id="detail-title" data-detail-title>{details[0].title}</h2>
      <p data-detail-description>{details[0].description}</p>
    </div>

    <div
      class="detail-viewer__figure"
      data-detail-figure
      data-figure-variant={details[0].figureVariant}
    >
      <p class="detail-viewer__label" data-detail-figure-label>{details[0].figureLabel}</p>
      <div class="detail-viewer__figure-media">
        <img src={details[0].figureSrc} alt="" data-detail-figure-image />
      </div>
      <p class="detail-viewer__caption" data-detail-figure-caption>{details[0].figureCaption}</p>
    </div>

    <div class="detail-viewer__note">
      <p class="detail-viewer__label" data-detail-note-label>{details[0].noteLabel}</p>
      <p data-detail-note>{details[0].note}</p>
    </div>
  </section>
</MainLayout>

<script is:inline type="application/json" id="object-details" set:html={JSON.stringify(details)} />

<style>
  .object,
  .detail-viewer {
    --ink: #141414;
    --orange: #fd6500;
    --cream: #f3eee1;
    --blue: #b9d6fe;
    --purple: #520345;
  }

  .object {
    position: relative;
    width: 100%;
    min-height: 45rem;
    height: 100svh;
    overflow: hidden;
    color: var(--cream);
    background: var(--ink);
    isolation: isolate;
  }

  .object__back,
  .detail-viewer__back {
    position: absolute;
    z-index: 12;
    top: 5.25%;
    left: 3%;
    display: grid;
    width: 13.4rem;
    height: 2.75rem;
    place-items: center;
    color: var(--cream);
    background: var(--purple) url('/images/collection-fidelity/back-frame.svg') center / 100% 100%
      no-repeat;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: transform 180ms ease;
  }

  .object__back:hover,
  .object__back:focus-visible,
  .detail-viewer__back:hover,
  .detail-viewer__back:focus-visible {
    transform: translateY(-2px);
  }

  .object__timeline {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .object__timeline-line {
    position: absolute;
    top: 14.6%;
    bottom: -2.5%;
    left: 6.55%;
    width: 2px;
    background: var(--orange);
  }

  .object__year {
    position: absolute;
    left: 1.9%;
    color: var(--orange);
    font-size: 2rem;
    font-style: italic;
    font-weight: 300;
    line-height: 1;
  }

  .object__year--first {
    top: 13.55%;
  }

  .object__year--last {
    top: 59%;
    left: 1.45%;
  }

  .object__year-flower {
    position: absolute;
    left: 5.82%;
    width: 1.5rem;
    height: 1.5rem;
    filter: brightness(0) saturate(100%) invert(44%) sepia(99%) saturate(3475%) hue-rotate(358deg)
      brightness(101%) contrast(105%);
  }

  .object__year-flower--first {
    top: 13.5%;
  }

  .object__year-flower--last {
    top: 59.1%;
  }

  .object__copy {
    position: absolute;
    z-index: 5;
    top: 13.9%;
    left: 9.3%;
    width: 24.3%;
    min-width: 25rem;
  }

  .object__period,
  .object__byline,
  .object__meta dt {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .object__period {
    color: var(--orange);
  }

  .object__copy h1 {
    margin: 0.5rem 0 0;
    color: var(--blue);
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 3.35vw, 4rem);
    font-style: italic;
    font-weight: 100;
    line-height: 1;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .object__byline {
    margin-top: 0.75rem;
    color: var(--cream);
  }

  .object__description {
    max-width: 28rem;
    margin: 1rem 0 0;
    font-size: 1rem;
    line-height: 1.15;
  }

  .object__meta {
    width: 100%;
    margin: 2.15rem 0 0;
  }

  .object__meta-row {
    display: grid;
    grid-template-columns: 46% 54%;
    align-items: center;
    min-height: 3.4rem;
    border-bottom: 1px solid var(--blue);
  }

  .object__meta-row dd {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.15;
  }

  .object__media {
    position: absolute;
    z-index: 2;
    top: 2.8%;
    left: 34.15%;
    width: 43.75%;
    height: 97.2%;
    margin: 0;
  }

  .object__media > img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    filter: drop-shadow(0 20px 24px rgb(0 0 0 / 30%));
  }

  .object__hotspot {
    position: absolute;
    z-index: 7;
    top: var(--hotspot-y);
    left: var(--hotspot-x);
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    place-items: center;
    background: transparent;
    border: 0;
    cursor: default;
    transform: translate(-50%, -50%);
  }

  .object__hotspot > img {
    width: 1.55rem;
    height: 1.55rem;
    filter: drop-shadow(0 3px 8px rgb(20 20 20 / 50%));
    animation: hotspot-breathe 2.8s ease-in-out infinite;
  }

  .object__hotspot:nth-of-type(2) > img {
    animation-delay: -0.55s;
  }

  .object__hotspot:nth-of-type(3) > img {
    animation-delay: -1.1s;
  }

  .object__hotspot:nth-of-type(4) > img {
    animation-delay: -1.65s;
  }

  .object__hotspot:nth-of-type(5) > img {
    animation-delay: -2.2s;
  }

  .object__hotspot::after {
    position: absolute;
    top: calc(100% + 0.1rem);
    left: 50%;
    padding: 0.4rem 0.55rem;
    color: var(--cream);
    background: rgb(20 20 20 / 90%);
    border: 1px solid rgb(185 214 254 / 55%);
    font-size: 0.625rem;
    letter-spacing: 0.05em;
    white-space: nowrap;
    content: attr(data-label);
    opacity: 0;
    transform: translate(-50%, -0.2rem);
    transition:
      opacity 150ms ease,
      transform 150ms ease;
    pointer-events: none;
  }

  .object__hotspot:hover::after,
  .object__hotspot:focus-visible::after {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .object__detail-entry {
    position: absolute;
    z-index: 8;
    bottom: 4.8%;
    left: 9.25%;
    width: 2.6rem;
    height: 2.6rem;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .object__detail-entry img {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
    transition: transform 180ms ease;
  }

  .object__detail-entry:hover img,
  .object__detail-entry:focus-visible img {
    transform: translateY(0.25rem) rotate(-90deg);
  }

  .detail-viewer {
    position: fixed;
    z-index: 9999;
    top: 50%;
    left: 50%;
    width: var(--presentation-width);
    height: calc(var(--presentation-width) * 0.5625);
    overflow: hidden;
    color: var(--cream);
    background: var(--ink);
    box-shadow: 0 0 0 100vmax var(--color-black);
    opacity: 0;
    transform: translate(-50%, -50%);
    transition: opacity 320ms ease;
    isolation: isolate;
  }

  .detail-viewer[hidden] {
    display: none;
  }

  .detail-viewer::before {
    position: absolute;
    z-index: -2;
    inset: 0;
    background-image: var(--detail-background);
    background-position: center;
    background-size: 100% 100%;
    background-repeat: no-repeat;
    content: '';
    opacity: 1;
    filter: none;
    transform: scale(1.02);
    transition:
      background-position 520ms cubic-bezier(0.76, 0, 0.24, 1),
      transform 620ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  .detail-viewer::after {
    position: absolute;
    z-index: -1;
    inset: 0;
    background:
      linear-gradient(90deg, rgb(20 20 20 / 72%) 0 19%, transparent 42%),
      linear-gradient(90deg, transparent 0 54%, rgb(20 20 20 / 68%) 72% 100%);
    content: '';
  }

  .detail-viewer.is-open {
    opacity: 1;
  }

  .detail-viewer.is-open::before {
    transform: scale(1);
  }

  .detail-viewer__close {
    position: absolute;
    z-index: 15;
    top: 5.25%;
    right: 3%;
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    padding: 0 0 0.15rem;
    place-items: center;
    color: var(--cream);
    background: rgb(20 20 20 / 55%);
    border: 1px solid var(--cream);
    border-radius: 50%;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 1.55rem;
    font-weight: 200;
  }

  .detail-viewer__back {
    top: 5.28%;
    left: 2.97%;
    width: 11.1%;
    height: 3.98%;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .detail-viewer__back img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .detail-viewer__progress {
    position: absolute;
    top: 12.75%;
    bottom: 10.45%;
    left: 3.125%;
    width: 1px;
    background: var(--cream);
  }

  .detail-viewer__progress span {
    position: absolute;
    top: 0;
    left: -1px;
    width: 3px;
    height: 33.333%;
    background: var(--orange);
    transform: translateY(0);
    transition: transform 420ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  .detail-viewer__thumbs {
    position: absolute;
    z-index: 5;
    top: 17.9%;
    left: 8.8%;
    display: grid;
    gap: 2.15rem;
    width: 15rem;
  }

  .detail-viewer__thumbs button {
    display: grid;
    grid-template-columns: 6.2rem;
    row-gap: 0.35rem;
    align-items: start;
    width: 6.2rem;
    padding: 0;
    color: var(--cream);
    text-align: left;
    background: transparent;
    border: 0;
    cursor: pointer;
    opacity: 0.85;
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .detail-viewer__thumbs button:not(:disabled):hover,
  .detail-viewer__thumbs button:not(:disabled):focus-visible {
    opacity: 1;
    transform: translateX(0.35rem);
  }

  .detail-viewer__thumbs img {
    width: 6.2rem;
    aspect-ratio: 118 / 137;
    object-fit: contain;
    background: rgb(20 20 20 / 45%);
    border-radius: 250px 250px 0 0;
  }

  .detail-viewer__thumbs span,
  .detail-viewer__thumbs em {
    display: block;
    max-width: none;
    font-style: normal;
    line-height: 1;
  }

  .detail-viewer__thumbs span {
    font-size: 0.72rem;
  }

  .detail-viewer__thumbs em {
    margin-top: -0.1rem;
    color: var(--blue);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .detail-viewer__focus {
    position: absolute;
    z-index: 4;
    top: 14.25%;
    left: 23.55%;
    width: 34.85%;
    height: 70%;
    overflow: hidden;
    background-image: var(--detail-zoom);
    background-position: var(--crop);
    background-size: var(--crop-size);
    background-repeat: no-repeat;
    border-radius: 1000px 1000px 0 0;
    box-shadow: 0 22px 70px rgb(0 0 0 / 30%);
    transform: scale(0.72);
    transform-origin: center 60%;
    transition:
      background-position 500ms cubic-bezier(0.76, 0, 0.24, 1),
      background-size 500ms cubic-bezier(0.76, 0, 0.24, 1),
      transform 600ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  .detail-viewer.is-open .detail-viewer__focus {
    transform: none;
  }

  .detail-viewer[data-index='0'] .detail-viewer__focus {
    top: 14.1667%;
    left: 26.1979%;
    width: 32.1875%;
    height: 70.3704%;
  }

  .detail-viewer__copy {
    position: absolute;
    z-index: 6;
    top: 14.259%;
    left: 65.625%;
    right: auto;
    bottom: auto;
    width: 20.3125%;
    min-width: 0;
    text-shadow: 0 2px 14px rgb(0 0 0 / 55%);
  }

  .detail-viewer__copy h2 {
    margin: 0;
    color: var(--blue);
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 3.35vw, 4rem);
    font-style: italic;
    font-weight: 100;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .detail-viewer__copy p {
    max-width: 33.25rem;
    margin: 1.25rem 0 0;
    font-size: clamp(0.95rem, 0.94vw, 1.125rem);
    font-style: normal;
    line-height: 1;
  }

  .detail-viewer__label,
  .detail-viewer__caption {
    margin: 0;
    font-size: clamp(0.68rem, 0.73vw, 0.875rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .detail-viewer__label {
    color: var(--orange);
  }

  .detail-viewer__caption {
    color: var(--cream);
    text-align: center;
  }

  .detail-viewer__figure {
    position: absolute;
    z-index: 6;
    top: 34.7222%;
    left: 65.625%;
    right: auto;
    width: 27.34375%;
  }

  .detail-viewer__figure-media {
    height: clamp(10rem, 29.75vh, 20rem);
    margin-top: 2rem;
  }

  .detail-viewer__figure-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .detail-viewer__figure[data-figure-variant='panier'] .detail-viewer__figure-media {
    height: calc(var(--presentation-width) * 0.1671875);
    margin-top: calc(var(--presentation-width) * 0.0122969);
    overflow: hidden;
    background: var(--ink);
  }

  .detail-viewer__figure[data-figure-variant='panier'] .detail-viewer__figure-media img {
    width: 99.43%;
    height: auto;
    margin-left: 0.571428%;
    transform: translateY(-37.603%);
    transform-origin: top left;
  }

  .detail-viewer__figure .detail-viewer__caption {
    margin-top: calc(var(--presentation-width) * 0.0083333);
  }

  .detail-viewer__note {
    position: absolute;
    z-index: 6;
    top: 75.2778%;
    left: 65.625%;
    right: auto;
    bottom: auto;
    width: 20.3125%;
  }

  .detail-viewer__note > p:last-child {
    max-width: 33.5rem;
    margin: calc(var(--presentation-width) * 0.0130208) 0 0;
    color: var(--cream);
    font-size: clamp(0.95rem, 0.94vw, 1.125rem);
    line-height: 1;
  }

  .object--feature .object__back {
    top: 4.35%;
    left: 2.5%;
    width: 11.146%;
    height: 4.074%;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .object--feature .object__back img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .object--feature .object__detail-entry img,
  .object--feature .object__detail-entry:hover img,
  .object--feature .object__detail-entry:focus-visible img {
    transform: none;
  }

  .object--feature .object__timeline,
  .object--feature .object__feature-notes {
    display: none;
  }

  .object__fidelity-copy {
    position: absolute;
    z-index: 5;
    top: 16.65%;
    left: 5.3%;
    width: 89.7%;
    height: 66.6%;
    object-fit: fill;
    pointer-events: none;
  }

  .object--feature .object__copy {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .object--feature .object__media {
    top: 4.45%;
    left: 24.1%;
    width: 50.8%;
    height: 95.55%;
  }

  .object--feature .object__hotspot {
    width: 2.35rem;
    height: 2.35rem;
  }

  .object--feature .object__hotspot > img {
    width: 1.35rem;
    height: 1.35rem;
  }

  .object--feature .object__feature-notes {
    position: absolute;
    z-index: 5;
    top: 18%;
    right: 5.2%;
    width: 19.2%;
  }

  .object__feature-notes section + section {
    margin-top: 3.25rem;
  }

  .object__feature-notes h2 {
    margin: 0;
    color: var(--orange);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .object__feature-notes p {
    margin: 1.15rem 0 0;
    color: var(--cream);
    font-size: 0.875rem;
    line-height: 1.08;
  }

  .object__views {
    display: grid;
    grid-template-columns: 1.25fr 1fr 0.72fr;
    align-items: end;
    gap: 1.2rem;
    height: 8rem;
    margin-top: 1.35rem;
  }

  .object__views img {
    width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .object__pattern {
    display: block;
    width: 100%;
    height: 12.3rem;
    margin-top: 1.35rem;
    object-fit: cover;
    object-position: center;
  }

  :global(html.detail-open) {
    overflow: hidden;
  }

  @keyframes hotspot-breathe {
    0%,
    100% {
      transform: scale(0.9) rotate(-3deg);
    }
    50% {
      transform: scale(1.08) rotate(3deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .object *,
    .detail-viewer *,
    .object *::before,
    .object *::after,
    .detail-viewer *::before,
    .detail-viewer *::after {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  type DetailState = {
    title: string;
    description: string;
    crop: string;
    size: string;
    zoomSrc?: string;
    thumb: string;
    backgroundSrc?: string;
    figureSrc?: string;
    figureVariant?: string;
    figureLabel?: string;
    figureCaption?: string;
    noteLabel?: string;
    note?: string;
    related?: {
      title: string;
      year: string;
      thumb: string;
    }[];
  };

  const viewer = document.querySelector<HTMLElement>('[data-detail-viewer]');
  const detailsData = document.getElementById('object-details')?.textContent ?? '[]';
  const detailStates = JSON.parse(detailsData) as DetailState[];

  if (viewer && detailStates.length > 0) {
    const pageContent = document.querySelector<HTMLElement>('[data-object-page]');
    const title = viewer.querySelector<HTMLElement>('[data-detail-title]');
    const description = viewer.querySelector<HTMLElement>('[data-detail-description]');
    const focus = viewer.querySelector<HTMLElement>('[data-detail-focus]');
    const progress = viewer.querySelector<HTMLElement>('[data-progress-segment]');
    const figureLabel = viewer.querySelector<HTMLElement>('[data-detail-figure-label]');
    const figure = viewer.querySelector<HTMLElement>('[data-detail-figure]');
    const figureImage = viewer.querySelector<HTMLImageElement>('[data-detail-figure-image]');
    const figureCaption = viewer.querySelector<HTMLElement>('[data-detail-figure-caption]');
    const noteLabel = viewer.querySelector<HTMLElement>('[data-detail-note-label]');
    const note = viewer.querySelector<HTMLElement>('[data-detail-note]');
    const closeButton = viewer.querySelector<HTMLButtonElement>('[data-detail-close]');
    const previousButton = viewer.querySelector<HTMLButtonElement>('[data-detail-previous]');
    const nextButton = viewer.querySelector<HTMLButtonElement>('[data-detail-next]');
    const thumbButtons = [...viewer.querySelectorAll<HTMLButtonElement>('[data-detail-thumb]')];
    let activeIndex = 0;
    let lastFocus: HTMLElement | null = null;
    let closeTimer = 0;

    const normalized = (index: number) => (index + detailStates.length) % detailStates.length;
    const getFocusable = () =>
      Array.from(
        viewer.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      );

    const renderDetail = (nextIndex: number) => {
      activeIndex = normalized(nextIndex);
      const state = detailStates[activeIndex];
      viewer.dataset.index = String(activeIndex);
      if (title) title.textContent = state.title;
      if (description) description.textContent = state.description;
      if (focus) {
        focus.style.setProperty('--crop', state.crop);
        focus.style.setProperty('--crop-size', state.size);
      }
      if (state.backgroundSrc) {
        viewer.style.setProperty('--detail-background', `url('${state.backgroundSrc}')`);
      }
      if (state.zoomSrc) {
        viewer.style.setProperty('--detail-zoom', `url('${state.zoomSrc}')`);
      }
      if (progress) progress.style.transform = `translateY(${activeIndex * 100}%)`;
      if (figureLabel) figureLabel.textContent = state.figureLabel ?? '';
      if (figure) {
        if (state.figureVariant) figure.dataset.figureVariant = state.figureVariant;
        else delete figure.dataset.figureVariant;
      }
      if (figureImage && state.figureSrc) figureImage.src = state.figureSrc;
      if (figureCaption) figureCaption.textContent = state.figureCaption ?? '';
      if (noteLabel) noteLabel.textContent = state.noteLabel ?? '';
      if (note) note.textContent = state.note ?? '';

      thumbButtons.forEach((button, index) => {
        const related = state.related?.[index];
        const image = button.querySelector<HTMLImageElement>('[data-detail-thumb-image]');
        const thumbTitle = button.querySelector<HTMLElement>('[data-detail-thumb-title]');
        const thumbYear = button.querySelector<HTMLElement>('[data-detail-thumb-year]');

        button.dataset.index = String(index);
        button.setAttribute('aria-label', related ? `${related.title}, ${related.year}` : '');
        button.setAttribute('aria-current', index === 0 ? 'true' : 'false');
        if (image && related) image.src = related.thumb;
        if (thumbTitle) thumbTitle.textContent = related?.title ?? '';
        if (thumbYear) thumbYear.textContent = related?.year ?? '';
      });
    };

    const openDetail = (index: number, trigger?: HTMLElement) => {
      window.clearTimeout(closeTimer);
      lastFocus =
        trigger ?? (document.activeElement instanceof HTMLElement ? document.activeElement : null);
      renderDetail(index);
      pageContent?.setAttribute('inert', '');
      viewer.hidden = false;
      viewer.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('detail-open');
      requestAnimationFrame(() => {
        viewer.classList.add('is-open');
        closeButton?.focus();
      });
    };

    const closeDetail = () => {
      viewer.classList.remove('is-open');
      viewer.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('detail-open');
      closeTimer = window.setTimeout(() => {
        viewer.hidden = true;
        pageContent?.removeAttribute('inert');
        lastFocus?.focus();
      }, 320);
    };

    document.querySelectorAll<HTMLButtonElement>('[data-hotspot]').forEach((button) => {
      button.addEventListener('click', () => openDetail(Number(button.dataset.index ?? 0), button));
    });

    document
      .querySelector<HTMLButtonElement>('[data-detail-entry]')
      ?.addEventListener('click', (event) => {
        openDetail(0, event.currentTarget as HTMLElement);
      });

    closeButton?.addEventListener('click', closeDetail);
    previousButton?.addEventListener('click', () => renderDetail(activeIndex - 1));
    nextButton?.addEventListener('click', () => renderDetail(activeIndex + 1));

    let lastWheelNavigation = 0;
    viewer.addEventListener(
      'wheel',
      (event) => {
        if (viewer.hidden || Math.abs(event.deltaY) < 12) return;
        event.preventDefault();

        const now = performance.now();
        if (now - lastWheelNavigation < 420) return;
        lastWheelNavigation = now;
        renderDetail(activeIndex + (event.deltaY > 0 ? 1 : -1));
      },
      { passive: false }
    );

    document.addEventListener('keydown', (event) => {
      if (viewer.hidden) return;
      if (event.key === 'Escape') {
        event.preventDefault();
        closeDetail();
        return;
      }
      if (event.key === 'Tab') {
        const focusable = getFocusable();
        const first = focusable.at(0);
        const last = focusable.at(-1);

        if (!first || !last) return;
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
        return;
      }
      if (event.key === 'ArrowLeft') renderDetail(activeIndex - 1);
      if (event.key === 'ArrowRight') renderDetail(activeIndex + 1);
    });
  }
</script>
