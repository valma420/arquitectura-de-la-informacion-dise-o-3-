---
/**
 * Coleccion permanente — indice visual basado en los frames Figma
 * 1:1384, 1:1458, 1:1566 y 1:1670.
 */
import MainLayout from '@layouts/MainLayout.astro';

const permanentImages = Array.from(
  { length: 47 },
  (_, index) => `collection-fidelity/permanent/piece-${String(index + 1).padStart(2, '0')}.png`
);

const collectionLayout = [
  [599, 895, 132, 177],
  [-23, 674, 135, 180],
  [185, 693, 132, 177],
  [819, 169, 139, 172],
  [1697, 681, 129, 178],
  [804, 694, 131, 175],
  [1009, 894, 135, 180],
  [178, 867, 132, 178],
  [1506, 594, 136, 175],
  [1813, 884, 137, 156],
  [-79, 412, 132, 180],
  [1556, 820, 184, 251],
  [1019, 6, 132, 175],
  [1258, 0, 132, 178],
  [390, 174, 143, 165],
  [1029, 691, 132, 175],
  [44, 248, 133, 176],
  [1222, 900, 134, 179],
  [1243, 168, 135, 171],
  [1506, 6, 132, 176],
  [238, 25, 113, 151],
  [395, 859, 123, 187],
  [610, 169, 135, 171],
  [1834, 632, 138, 173],
  [1386, 699, 122, 186],
  [599, 672, 173, 235],
  [1036, 166, 131, 176],
  [1707, 25, 122, 194],
  [181, 190, 130, 178],
  [1218, 694, 133, 177],
  [393, 693, 131, 175],
  [1489, 149, 133, 177],
  [817, 900, 119, 159],
  [1402, 866, 154, 205],
  [89, 468, 132, 176],
  [395, 6, 131, 175],
  [1651, 276, 131, 175],
  [1667, 504, 160, 146],
  [-35, 874, 118, 163],
  [1834, 364, 109, 201],
  [600, 6, 133, 176],
  [812, 6, 131, 175],
  [-123, 133, 185, 246],
  [1859, 108, 130, 178],
  [1443, 374, 131, 175],
  [370, 494, 136, 180],
  [238, 371, 142, 162],
];

const pieceProfiles = [
  ['redingote', 'neoclasico abrigo lana'],
  ['robe-polonaise', 'rococo vestido seda'],
  ['caraco-falda', 'rococo abrigo bordado'],
  ['vestido-gasa-1790', 'neoclasico vestido encaje'],
  ['casaca-bordada', 'rococo abrigo bordado'],
  ['robe-anglaise', 'rococo vestido seda'],
  ['robe-francaise-1730', 'rococo vestido seda'],
  ['vestido-corte', 'rococo vestido seda'],
  ['chaleco-courtois', 'rococo abrigo bordado'],
];

const collectionPieces = collectionLayout.map(([x, y, w, h], index) => {
  const [slug, tags] = pieceProfiles[index % pieceProfiles.length];
  return { x, y, w, h, slug, tags };
});

const filters = [
  {
    label: 'Período',
    options: [
      ['Rococó', 'rococo'],
      ['Neoclásico', 'neoclasico'],
      ['Siglo XIX', 'siglo-xix'],
      ['Belle Époque', 'belle-epoque'],
      ['Années folles', 'annees-folles'],
      ['Los años 30', 'anos-30'],
      ['New Look', 'new-look'],
      ['La Revolución juvenil', 'revolucion-juvenil'],
    ],
  },
  {
    label: 'Diseñador',
    options: [
      ['Anónimo', 'anonimo'],
      ['Maison Worth', 'worth'],
      ['Paul Poiret', 'poiret'],
      ['Madeleine Vionnet', 'vionnet'],
      ['Christian Dior', 'dior'],
    ],
  },
  {
    label: 'Tipología',
    options: [
      ['Vestido', 'vestido'],
      ['Abrigo', 'abrigo'],
      ['Traje', 'traje'],
      ['Calzado', 'calzado'],
      ['Sombrerería', 'sombrereria'],
      ['Accesorios', 'accesorios'],
      ['Partes de abajo', 'partes-abajo'],
      ['Partes de arriba', 'partes-arriba'],
    ],
  },
  {
    label: 'Material',
    options: [
      ['Seda', 'seda'],
      ['Algodón', 'algodon'],
      ['Lana', 'lana'],
      ['Encaje', 'encaje'],
      ['Cuero', 'cuero'],
      ['Bordado', 'bordado'],
    ],
  },
  {
    label: 'Color',
    options: [
      ['Claro', 'claro'],
      ['Oscuro', 'oscuro'],
      ['Azul', 'azul'],
      ['Verde', 'verde'],
      ['Rojo', 'rojo'],
    ],
  },
];
---

<MainLayout
  title="Colección permanente"
  description="Índice visual de la colección permanente del prototipo Palais Galliera."
  immersive
>
  <div class="permanent-collection" data-permanent-collection>
    <header class="collection-nav">
      <a class="collection-nav__logo" href="/" aria-label="Palais Galliera — Inicio">
        <svg viewBox="0 0 61 61" aria-hidden="true">
          <circle cx="30.5" cy="30.5" r="30.5" fill="currentColor"></circle>
          <g fill="none" stroke="#f3eee1" stroke-width="1.5">
            <path d="M17 26h27L30.5 19 17 26Z"></path>
            <path d="M18 41h25M20 28v11m7-11v11m7-11v11m7-11v11"></path>
          </g>
        </svg>
      </a>

      <nav class="collection-nav__bar" aria-label="Principal">
        <a href="/historia">Visitar</a>
        <a href="/muestra">Exposiciones</a>
        <a class="is-active" href="/coleccion-permanente" aria-current="page">Colecciones</a>
        <a href="/historia">El museo</a>
        <a href="/agenda">Agenda</a>
        <a class="collection-nav__tickets" href="/agenda">Entradas</a>
        <a class="collection-nav__search" href="#filtros" aria-label="Filtrar la colección">
          <img src="/images/collection-fidelity/catalogue-search.svg" alt="" />
        </a>
      </nav>
    </header>

    <div class="permanent-collection__summary">
      <p>22.071 prendas y accesorios</p>
      <p>Indumentaria · siglo XVIII a la actualidad</p>
    </div>

    <div class="permanent-collection__pieces" aria-label="Objetos de la colección">
      {
        collectionPieces.map((piece, index) => (
          <a
            class="collection-piece"
            href={index === 4 ? '/coleccion' : `/coleccion/${piece.slug}`}
            style={`--piece-x:${(piece.x / 1920) * 100}%;--piece-y:${(piece.y / 1079) * 100}%;--piece-w:${(piece.w / 1920) * 100}%;--piece-h:${(piece.h / 1079) * 100}%;--piece-delay:${(index % 8) * 45}ms;`}
            data-tags={piece.tags}
            aria-label={
              index === 4 ? 'Abrir selección Robe à la française' : 'Abrir ficha del objeto'
            }
          >
            <img src={`/images/${permanentImages[index]}`} alt="" />
          </a>
        ))
      }
    </div>

    <section class="permanent-collection__center" aria-labelledby="collection-title">
      <h1 id="collection-title">Colección</h1>

      <div class="collection-filters" id="filtros" aria-label="Filtrar la colección">
        {
          filters.map((filter) => (
            <div class="collection-filter" data-filter>
              <button type="button" aria-expanded="false" data-filter-toggle>
                {filter.label}
              </button>
              <div class="collection-filter__menu" data-filter-menu hidden>
                {filter.options.map(([label, value]) => (
                  <label>
                    <input type="checkbox" value={value} data-filter-option />
                    <span aria-hidden="true" />
                    {label}
                  </label>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <p class="sr-only" aria-live="polite" data-filter-status></p>
  </div>
</MainLayout>

<style>
  .permanent-collection {
    --purple: #520345;
    --cream: #f3eee1;
    --blue: #b9d6fe;
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 49.5rem;
    overflow: hidden;
    color: var(--purple);
    background: var(--cream);
    isolation: isolate;
  }

  .collection-nav {
    position: absolute;
    z-index: 20;
    top: 3.6%;
    left: 3.1%;
    display: flex;
    align-items: center;
    width: 70.1%;
    min-width: 58rem;
    height: 3.8125rem;
  }

  .collection-nav__logo {
    display: block;
    width: 3.8125rem;
    height: 3.8125rem;
    flex: 0 0 auto;
    color: var(--purple);
  }

  .collection-nav__logo svg,
  .collection-nav__search img {
    width: 100%;
    height: 100%;
  }

  .collection-nav__bar {
    display: flex;
    align-items: center;
    width: 55.6rem;
    height: 100%;
    margin-left: 24.1rem;
    padding: 0 1.5rem 0 2.45rem;
    color: var(--cream);
    background: var(--purple);
  }

  .collection-nav__bar > a:not(.collection-nav__tickets, .collection-nav__search) {
    margin-right: 2.35rem;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .collection-nav__bar > a.is-active {
    color: var(--blue);
  }

  .collection-nav__tickets {
    display: grid;
    width: 6.85rem;
    height: 2rem;
    margin-left: auto;
    place-items: center;
    color: var(--purple);
    background: var(--blue);
    border-radius: 2px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .collection-nav__search {
    width: 1.35rem;
    height: 1.35rem;
    margin-left: 1.4rem;
    filter: brightness(0) invert(1);
  }

  .permanent-collection__summary {
    position: absolute;
    z-index: 5;
    top: 14.25%;
    left: 3.1%;
    font-size: 0.75rem;
    line-height: 1.2;
  }

  .permanent-collection__summary p {
    margin: 0;
  }

  .permanent-collection__pieces {
    position: absolute;
    z-index: 1;
    inset: 0;
  }

  .collection-piece {
    position: absolute;
    top: var(--piece-y);
    left: var(--piece-x);
    display: block;
    width: var(--piece-w);
    min-width: 3.4rem;
    height: var(--piece-h);
    opacity: 1;
    transform: none;
    transition:
      opacity 350ms ease,
      transform 420ms cubic-bezier(0.76, 0, 0.24, 1),
      filter 350ms ease;
    animation: collection-piece-enter 650ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--piece-delay);
  }

  .collection-piece img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 0.25rem 0.2rem rgb(82 3 69 / 8%));
  }

  .collection-piece:hover,
  .collection-piece:focus-visible {
    z-index: 8;
    filter: saturate(1.08);
    transform: scale(1.15);
  }

  .permanent-collection.is-filtering .collection-piece {
    opacity: 0.16;
    filter: saturate(0.3);
  }

  .permanent-collection.is-filtering .collection-piece.is-match {
    opacity: 1;
    filter: none;
  }

  .permanent-collection__center {
    position: absolute;
    z-index: 10;
    top: 34.8%;
    left: 50%;
    width: min(58rem, 56vw);
    transform: translateX(-50%);
  }

  .permanent-collection h1 {
    margin: 0;
    color: var(--purple);
    font-family: var(--font-display);
    font-size: clamp(8rem, 10.42vw, 12.5rem);
    font-style: normal;
    font-weight: 100;
    line-height: 0.8;
    letter-spacing: -0.04em;
    text-align: center;
  }

  .collection-filters {
    display: flex;
    justify-content: center;
    gap: 0.7rem;
    margin-top: 2.1rem;
  }

  .collection-filter {
    position: relative;
  }

  .collection-filter > button {
    min-width: 6.65rem;
    height: 2rem;
    padding: 0 1rem;
    color: var(--purple);
    background: var(--cream);
    border: 1px solid var(--purple);
    border-radius: 100px;
    cursor: pointer;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition:
      color 160ms ease,
      background-color 160ms ease;
  }

  .collection-filter > button[aria-expanded='true'] {
    color: var(--cream);
    background: var(--purple);
  }

  .collection-filter__menu {
    position: absolute;
    top: calc(100% + 0.2rem);
    left: 0;
    width: max(100%, 9.5rem);
    overflow: hidden;
    color: var(--purple);
    background: linear-gradient(to bottom, #d8bccb, var(--blue));
    box-shadow: 0 0.75rem 1.5rem rgb(82 3 69 / 18%);
  }

  .collection-filter__menu label {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2.2rem;
    padding: 0.35rem 0.7rem;
    border-bottom: 1px solid rgb(82 3 69 / 18%);
    cursor: pointer;
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .collection-filter__menu label:hover {
    background: rgb(243 238 225 / 38%);
  }

  .collection-filter__menu input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .collection-filter__menu label > span {
    width: 0.65rem;
    height: 0.65rem;
    border: 1px solid var(--purple);
  }

  .collection-filter__menu input:checked + span {
    background: var(--purple);
    box-shadow: inset 0 0 0 2px var(--blue);
  }

  @keyframes collection-piece-enter {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(1.5rem) scale(0.92);
    }
  }

  @media (max-width: 1100px) {
    .collection-nav {
      top: 1rem;
      left: 1rem;
      width: calc(100% - 2rem);
      min-width: 0;
    }

    .collection-nav__bar {
      justify-content: flex-end;
      margin-left: auto;
    }

    .collection-nav__bar > a:not(.collection-nav__tickets, .collection-nav__search) {
      display: none;
    }

    .permanent-collection__summary {
      top: 6.4rem;
      left: 1.25rem;
    }

    .permanent-collection__center {
      top: 37%;
      width: 92vw;
    }

    .permanent-collection h1 {
      font-size: clamp(5rem, 19vw, 9rem);
    }

    .collection-filters {
      flex-wrap: wrap;
      width: min(38rem, 92vw);
      margin-inline: auto;
    }

    .collection-filter__menu {
      z-index: 30;
    }
  }

  @media (max-width: 600px) {
    .permanent-collection {
      min-height: 43rem;
    }

    .collection-nav__bar {
      position: absolute;
      right: 0;
      width: 9.5rem;
      margin-left: 0;
      padding-left: 1rem;
    }

    .collection-nav__tickets {
      width: 5.6rem;
    }

    .permanent-collection__summary {
      font-size: 0.68rem;
    }

    .permanent-collection__center {
      top: 35%;
      width: calc(100vw - 2rem);
    }

    .permanent-collection h1 {
      font-size: clamp(3rem, 14vw, 3.6rem);
    }

    .collection-filters {
      gap: 0.45rem;
      width: 100%;
      margin-top: 1.5rem;
    }

    .collection-filter {
      min-width: 0;
      flex: 0 0 calc(50% - 0.25rem);
    }

    .collection-filter > button {
      width: 100%;
      min-width: 0;
      height: 1.8rem;
      padding-inline: 0.35rem;
      font-size: 0.5rem;
    }

    .collection-piece {
      width: calc(var(--piece-w) * 1.65);
      height: calc(var(--piece-h) * 1.65);
    }

    .collection-piece:nth-child(3n) {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-piece,
    .collection-filter > button {
      animation: none;
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  const collection = document.querySelector<HTMLElement>('[data-permanent-collection]');

  if (collection) {
    const filters = [...collection.querySelectorAll<HTMLElement>('[data-filter]')];
    const pieces = [...collection.querySelectorAll<HTMLElement>('[data-tags]')];
    const status = collection.querySelector<HTMLElement>('[data-filter-status]');
    const activeFilters = new Map<HTMLElement, { value: string; label: string }>();

    const closeMenus = (except?: HTMLElement) => {
      filters.forEach((filter) => {
        if (filter === except) return;
        filter.querySelector<HTMLElement>('[data-filter-menu]')?.setAttribute('hidden', '');
        filter
          .querySelector<HTMLButtonElement>('[data-filter-toggle]')
          ?.setAttribute('aria-expanded', 'false');
      });
    };

    const applyFilters = () => {
      const selections = [...activeFilters.values()];
      let matchCount = 0;

      pieces.forEach((piece) => {
        const tags = (piece.dataset.tags ?? '').split(' ');
        const matches = selections.every(({ value }) => tags.includes(value));
        piece.classList.toggle('is-match', matches);
        if (matches) matchCount += 1;
      });

      collection.classList.toggle('is-filtering', selections.length > 0);
      if (status) {
        const labels = selections.map(({ label }) => label).join(' + ');
        status.textContent = labels
          ? `${labels}: ${matchCount} objetos visibles`
          : `${matchCount} objetos visibles`;
      }
    };

    filters.forEach((filter) => {
      const toggle = filter.querySelector<HTMLButtonElement>('[data-filter-toggle]');
      const menu = filter.querySelector<HTMLElement>('[data-filter-menu]');
      const filterLabel = toggle?.textContent?.trim() ?? '';

      toggle?.addEventListener('click', () => {
        const willOpen = toggle.getAttribute('aria-expanded') !== 'true';
        closeMenus(filter);
        toggle.setAttribute('aria-expanded', String(willOpen));
        menu?.toggleAttribute('hidden', !willOpen);
      });

      filter.querySelectorAll<HTMLInputElement>('[data-filter-option]').forEach((option) => {
        option.addEventListener('change', () => {
          if (!option.checked) {
            activeFilters.delete(filter);
            applyFilters();
            if (toggle) toggle.textContent = filterLabel;
            closeMenus();
            return;
          }

          filter.querySelectorAll<HTMLInputElement>('[data-filter-option]').forEach((other) => {
            if (other !== option) other.checked = false;
          });

          const label = option.closest('label')?.textContent?.trim() ?? option.value;
          activeFilters.set(filter, { value: option.value, label });
          applyFilters();
          if (toggle) toggle.textContent = label;
          closeMenus();
        });
      });
    });

    document.addEventListener('click', (event) => {
      if (
        !(event.target instanceof Node) ||
        collection.querySelector('.collection-filters')?.contains(event.target)
      ) {
        return;
      }
      closeMenus();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenus();
    });
  }
</script>
