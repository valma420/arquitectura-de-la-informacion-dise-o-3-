---
/**
 * Coleccion permanente — indice visual basado en los frames Figma
 * 1:1384, 1:1458, 1:1566 y 1:1670.
 */
import MainLayout from '@layouts/MainLayout.astro';

const permanentImages = Array.from(
  { length: 47 },
  (_, index) => `collection-fidelity/permanent/piece-${String(index + 1).padStart(2, '0')}.png`
);

const collectionLayout = [
  [599, 895, 132, 177],
  [-23, 674, 135, 180],
  [185, 693, 132, 177],
  [819, 169, 139, 172],
  [1697, 681, 129, 178],
  [804, 694, 131, 175],
  [1009, 894, 135, 180],
  [178, 867, 132, 178],
  [1506, 594, 136, 175],
  [1813, 884, 137, 156],
  [-79, 412, 132, 180],
  [1556, 820, 184, 251],
  [1019, 6, 132, 175],
  [1258, 0, 132, 178],
  [390, 174, 143, 165],
  [1029, 691, 132, 175],
  [44, 248, 133, 176],
  [1222, 900, 134, 179],
  [1243, 168, 135, 171],
  [1506, 6, 132, 176],
  [238, 25, 113, 151],
  [395, 859, 123, 187],
  [610, 169, 135, 171],
  [1834, 632, 138, 173],
  [1386, 699, 122, 186],
  [599, 672, 173, 235],
  [1036, 166, 131, 176],
  [1707, 25, 122, 194],
  [181, 190, 130, 178],
  [1218, 694, 133, 177],
  [393, 693, 131, 175],
  [1489, 149, 133, 177],
  [817, 900, 119, 159],
  [1402, 866, 154, 205],
  [89, 468, 132, 176],
  [395, 6, 131, 175],
  [1651, 276, 131, 175],
  [1667, 504, 160, 146],
  [-35, 874, 118, 163],
  [1834, 364, 109, 201],
  [600, 6, 133, 176],
  [812, 6, 131, 175],
  [-123, 133, 185, 246],
  [1859, 108, 130, 178],
  [1443, 374, 131, 175],
  [370, 494, 136, 180],
  [238, 371, 142, 162],
];

const pieceProfiles = [
  ['redingote', 'neoclasico abrigo lana'],
  ['robe-polonaise', 'rococo vestido seda'],
  ['caraco-falda', 'rococo abrigo bordado'],
  ['vestido-gasa-1790', 'neoclasico vestido encaje'],
  ['casaca-bordada', 'rococo abrigo bordado'],
  ['robe-anglaise', 'rococo vestido seda'],
  ['robe-francaise-1730', 'rococo vestido seda'],
  ['vestido-corte', 'rococo vestido seda'],
  ['chaleco-courtois', 'rococo abrigo bordado'],
];

const collectionPieces = collectionLayout.map(([x, y, w, h], index) => {
  const [slug, tags] = pieceProfiles[index % pieceProfiles.length];
  return { x, y, w, h, slug, tags };
});

const filters = [
  {
    label: 'Período',
    options: [
      ['Rococó', true],
      ['Neoclásico', false],
      ['Siglo XIX', false],
      ['Belle Époque', false],
      ['Années folles', false],
      ['Los años 30', false],
      ['New Look', false],
      ['La Revolución juvenil', false],
      ['Power dressing', false],
      ['Siglo XXI', false],
    ],
  },
  {
    label: 'Diseñador',
    options: [
      ['Anonimo / s.d.', false],
      ['Chanel', true],
      ['Christian Dior', false],
      ['Cristóbal Balenciaga', false],
      ['Yves Saint Laurent', false],
      ['Jean Paul Gaultier', false],
      ['Givenchy', false],
      ['Elsa Schiaparelli', false],
      ['Madame Grès', false],
      ['Pierre Balmain', false],
    ],
  },
  {
    label: 'Tipología',
    options: [
      ['Vestido', true],
      ['Abrigo', false],
      ['Traje', false],
      ['Calzado', false],
      ['Sombrerería', false],
      ['Accesorios', false],
      ['Partes de abajo', false],
      ['Partes de arriba', false],
    ],
  },
  {
    label: 'Material',
    options: [
      ['Seda', true],
      ['Algodón', false],
      ['Lana', false],
      ['Encaje', false],
      ['Cuero', false],
      ['Bordado', false],
    ],
  },
  {
    label: 'Color',
    options: [
      ['Negro', true],
      ['Blanco', false],
      ['Rojo', false],
      ['Azul', false],
      ['Verde', false],
      ['Dorado / metálico', false],
    ],
  },
];
---

<MainLayout
  title="Colección permanente"
  description="Índice visual de la colección permanente del prototipo Palais Galliera."
  immersive
>
  <div class="permanent-collection" data-permanent-collection>
    <header class="collection-nav">
      <a class="collection-nav__logo" href="/" aria-label="Palais Galliera — Inicio">
        <img src="/images/site/logo-light-4.svg" alt="" />
      </a>

      <nav class="collection-nav__bar" aria-label="Principal">
        <a href="/historia">Visitar</a>
        <a href="/muestra">Exposiciones</a>
        <a class="is-active" href="/coleccion-permanente" aria-current="page">Colecciones</a>
        <a href="/historia">El museo</a>
        <a href="/agenda">Agenda</a>
        <a class="collection-nav__tickets" href="/agenda">Entradas</a>
        <a class="collection-nav__search" href="#filtros" aria-label="Filtrar la colección">
          <img src="/images/collection-fidelity/catalogue-search.svg" alt="" />
        </a>
      </nav>
    </header>

    <div class="permanent-collection__summary">
      <p>22.071 prendas y accesorios</p>
      <p>Indumentaria · siglo XVIII a la actualidad</p>
    </div>

    <div class="permanent-collection__pieces" aria-label="Objetos de la colección">
      {
        collectionPieces.map((piece, index) => (
          <a
            class="collection-piece"
            href={index === 4 ? '/coleccion' : `/coleccion/${piece.slug}`}
            style={`--piece-x:${(piece.x / 1920) * 100}%;--piece-y:${(piece.y / 1079) * 100}%;--piece-w:${(piece.w / 1920) * 100}%;--piece-h:${(piece.h / 1079) * 100}%;--piece-delay:${(index % 8) * 45}ms;`}
            data-tags={piece.tags}
            aria-label={
              index === 4 ? 'Abrir selección Robe à la française' : 'Abrir ficha del objeto'
            }
          >
            <img src={`/images/${permanentImages[index]}`} alt="" />
          </a>
        ))
      }
    </div>

    <section class="permanent-collection__center" aria-labelledby="collection-title">
      <h1 id="collection-title">Colección</h1>

      <div class="collection-filters" id="filtros" aria-label="Filtrar la colección">
        {
          filters.map((filter, index) => (
            <div class="collection-filter" data-filter>
              <button
                type="button"
                aria-controls={`collection-filter-menu-${index}`}
                aria-expanded="false"
                data-filter-toggle
              >
                {filter.label}
              </button>
              <div
                class="collection-filter__menu"
                id={`collection-filter-menu-${index}`}
                aria-label={filter.label}
                data-filter-menu
                hidden
              >
                {filter.options.map(([label, selected]) => (
                  <label>
                    <input type="checkbox" checked={selected} data-filter-option />
                    <span aria-hidden="true" />
                    {label}
                  </label>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <p class="sr-only" aria-live="polite" data-filter-status></p>
  </div>
</MainLayout>

<style>
  .permanent-collection {
    --purple: #520345;
    --cream: #f3eee1;
    --blue: #b9d6fe;
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 49.5rem;
    overflow: hidden;
    color: var(--purple);
    background: var(--cream);
    isolation: isolate;
  }

  .collection-nav {
    position: absolute;
    z-index: 20;
    top: 3.6145%;
    left: 3.125vw;
    width: 0;
    height: 3.1771vw;
  }

  .collection-nav__logo {
    display: block;
    width: 3.1771vw;
    height: 3.1771vw;
    color: var(--purple);
  }

  .collection-nav__logo img,
  .collection-nav__search img {
    width: 100%;
    height: 100%;
  }

  .collection-nav__bar {
    position: absolute;
    top: 0;
    left: 23.2292vw;
    width: 46.3021vw;
    height: 100%;
    color: var(--cream);
    background: var(--purple);
  }

  .collection-nav__bar > a:not(.collection-nav__tickets, .collection-nav__search) {
    position: absolute;
    top: 1.1979vw;
    font-size: 0.7292vw;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .collection-nav__bar > a:nth-child(1) {
    left: 2.0313vw;
  }

  .collection-nav__bar > a:nth-child(2) {
    left: 6.9271vw;
  }

  .collection-nav__bar > a:nth-child(3) {
    left: 14.2708vw;
  }

  .collection-nav__bar > a:nth-child(4) {
    left: 21.4063vw;
  }

  .collection-nav__bar > a:nth-child(5) {
    left: 27.1354vw;
  }

  .collection-nav__bar > a.is-active {
    color: var(--blue);
  }

  .collection-nav__tickets {
    display: grid;
    position: absolute;
    top: 0.7292vw;
    left: 35.1042vw;
    width: 5.7292vw;
    height: 1.6667vw;
    place-items: center;
    color: var(--purple);
    background: var(--blue);
    border-radius: 2px;
    font-size: 0.7292vw;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .collection-nav__search {
    position: absolute;
    top: 1.0417vw;
    left: 43.3333vw;
    width: 1vw;
    height: 1vw;
    filter: brightness(0) invert(1);
  }

  .permanent-collection__summary {
    position: absolute;
    z-index: 5;
    top: 14.25%;
    left: 3.1%;
    font-size: 1.125rem;
    font-weight: 450;
    line-height: 1.15;
  }

  .permanent-collection__summary p {
    margin: 0;
  }

  .permanent-collection__summary p + p {
    margin-top: 0.15rem;
    font-size: 1rem;
  }

  .permanent-collection__pieces {
    position: absolute;
    z-index: 1;
    inset: 0;
  }

  .collection-piece {
    position: absolute;
    top: var(--piece-y);
    left: var(--piece-x);
    display: block;
    width: var(--piece-w);
    min-width: 3.4rem;
    height: var(--piece-h);
    opacity: 1;
    transform: none;
    transition:
      opacity 350ms ease,
      transform 420ms cubic-bezier(0.76, 0, 0.24, 1),
      filter 350ms ease;
    animation: collection-piece-enter 650ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--piece-delay);
  }

  .collection-piece img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 0.25rem 0.2rem rgb(82 3 69 / 8%));
  }

  .collection-piece:hover,
  .collection-piece:focus-visible {
    z-index: 8;
    filter: saturate(1.08);
    transform: scale(1.15);
  }

  .permanent-collection.is-filtering .collection-piece {
    opacity: 0.16;
    filter: saturate(0.3);
  }

  .permanent-collection.is-filtering .collection-piece.is-match {
    opacity: 1;
    filter: none;
  }

  .permanent-collection__center {
    position: absolute;
    z-index: 10;
    top: 34.8%;
    left: 50%;
    width: min(58rem, 56vw);
    transform: translateX(-50%);
  }

  .permanent-collection h1 {
    margin: 0;
    color: var(--purple);
    font-family: var(--font-display);
    font-size: clamp(8rem, 10.42vw, 12.5rem);
    font-style: normal;
    font-weight: 100;
    line-height: 0.8;
    letter-spacing: -0.02em;
    text-align: center;
  }

  .collection-filters {
    display: flex;
    justify-content: center;
    gap: 1.125rem;
    margin-top: 2.2875rem;
  }

  .collection-filter {
    position: relative;
  }

  .collection-filter > button {
    width: 7rem;
    height: 2rem;
    padding: 0 0.5rem;
    color: transparent;
    background: url('/images/collection-fidelity/vectores.svg') var(--vector-x) -2.8125rem /
      52.1875rem 32.8125rem no-repeat;
    border: 0;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition:
      color 160ms ease,
      background-color 160ms ease;
  }

  .collection-filter:nth-child(1) > button {
    --vector-x: -11.8125rem;
  }

  .collection-filter:nth-child(2) > button {
    --vector-x: -19.8125rem;
  }

  .collection-filter:nth-child(3) > button {
    --vector-x: -27.8125rem;
  }

  .collection-filter:nth-child(4) > button {
    --vector-x: -35.8125rem;
  }

  .collection-filter:nth-child(5) > button {
    --vector-x: -43.8125rem;
  }

  .collection-filter > button[aria-expanded='true'] {
    color: transparent;
  }

  .collection-filter__menu {
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    width: 14.375rem;
    overflow: hidden;
    color: var(--purple);
    background: linear-gradient(to bottom, #f3eee1, #b9d6fe);
    box-shadow: 0 0.875rem 1.5rem rgb(82 3 69 / 18%);
  }

  .collection-filter__menu label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    min-height: 2.625rem;
    padding: 0 0.875rem;
    border-bottom: 1px solid rgb(82 3 69 / 18%);
    cursor: pointer;
    font-size: 1rem;
    font-weight: 450;
    white-space: nowrap;
  }

  .collection-filter__menu label:has(input:checked) {
    background: #ceb8c2;
  }

  .collection-filter__menu input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .collection-filter__menu label > span {
    width: 0.875rem;
    height: 0.875rem;
    border: 1px solid var(--purple);
  }

  .collection-filter__menu input:checked + span {
    background: var(--purple);
    box-shadow: inset 0 0 0 3px #ceb8c2;
  }

  @keyframes collection-piece-enter {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(1.5rem) scale(0.92);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-piece,
    .collection-filter > button {
      animation: none;
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  const collection = document.querySelector<HTMLElement>('[data-permanent-collection]');

  if (collection) {
    const filters = [...collection.querySelectorAll<HTMLElement>('[data-filter]')];

    const closeMenus = (except?: HTMLElement) => {
      filters.forEach((filter) => {
        if (filter === except) return;
        filter.querySelector<HTMLElement>('[data-filter-menu]')?.setAttribute('hidden', '');
        filter
          .querySelector<HTMLButtonElement>('[data-filter-toggle]')
          ?.setAttribute('aria-expanded', 'false');
      });
    };

    filters.forEach((filter) => {
      const toggle = filter.querySelector<HTMLButtonElement>('[data-filter-toggle]');
      const menu = filter.querySelector<HTMLElement>('[data-filter-menu]');

      toggle?.addEventListener('click', () => {
        const willOpen = toggle.getAttribute('aria-expanded') !== 'true';
        closeMenus(filter);
        toggle.setAttribute('aria-expanded', String(willOpen));
        menu?.toggleAttribute('hidden', !willOpen);
      });

      filter.querySelectorAll<HTMLInputElement>('[data-filter-option]').forEach((option) => {
        option.addEventListener('change', () => {
          filter.querySelectorAll<HTMLInputElement>('[data-filter-option]').forEach((other) => {
            if (other !== option) other.checked = false;
          });
          option.checked = true;
        });
      });
    });

    document.addEventListener('click', (event) => {
      if (
        !(event.target instanceof Node) ||
        collection.querySelector('.collection-filters')?.contains(event.target)
      ) {
        return;
      }
      closeMenus();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenus();
    });
  }
</script>
