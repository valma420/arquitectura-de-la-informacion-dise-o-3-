---
import MainLayout from '@layouts/MainLayout.astro';

const orbitObjects = [
  {
    image: '/images/home/orbit-dress.png',
    label: 'Figurín de vestido, archivo Palais Galliera',
    x: 3.7,
    y: 80.3,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-pattern.png',
    label: 'Patronaje, archivo Palais Galliera',
    x: 22.4,
    y: 60.6,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-coat.png',
    label: 'Abrigo bordado, colección Palais Galliera',
    x: 50,
    y: 54,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-blue.png',
    label: 'Detalle textil bordado, colección Palais Galliera',
    x: 77.6,
    y: 60.6,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-photo.png',
    label: 'Fotografía de moda, archivo Palais Galliera',
    x: 96.3,
    y: 80.3,
    width: 10.26,
    rotate: 0,
  },
];
---

<MainLayout
  title="Palais Galliera"
  description="Palais Galliera — conservar la moda es conservar el tiempo. Explorá el acervo, las exposiciones, la memoria y la agenda del museo."
  immersive
>
  <section class="home-intro" data-home-intro aria-label="Introducción al Palais Galliera">
    <div class="home-intro__sticky">
      <img
        class="home-intro__image home-intro__image--base"
        src="/images/home/intro-gallery.png"
        alt="Galería del Palais Galliera con indumentaria histórica"
        loading="eager"
      />
      <img
        class="home-intro__image home-intro__image--title"
        src="/images/home/intro-title.png"
        alt=""
        loading="eager"
        data-home-intro-title
      />
    </div>
  </section>

  <section class="home-hero" data-home-hero>
    <div class="home-hero__pattern" aria-hidden="true"></div>

    <h1 class="home-hero__title" aria-label="Palais Galliera" data-home-hero-title>
      <span>Palais</span>
      <strong>Galliera</strong>
    </h1>

    <div class="orbit" data-home-orbit aria-label="Piezas destacadas del acervo">
      <span class="orbit__line orbit__line--outer" aria-hidden="true"></span>
      <span class="orbit__line orbit__line--inner" aria-hidden="true"></span>
      {
        orbitObjects.map((object, index) => (
          <figure
            class="orbit__object"
            style={`--x:${object.x}%;--y:${object.y}%;--w:${object.width}vw;--r:${object.rotate}deg;--i:${index};`}
            data-orbit-object
          >
            <div class="orbit__frame">
              <img src={object.image} alt={object.label} loading="eager" />
            </div>
            <figcaption class="label">{object.label}</figcaption>
          </figure>
        ))
      }
    </div>

    <div class="home-hero__manifesto" data-reveal>
      <p class="home-hero__statement type-display-italic">
        Conservar la moda es conservar el tiempo.
      </p>
      <p class="home-hero__intro">
        Cada prenda que el Palais Galliera guarda es el testimonio de un cuerpo, una época y un modo
        de habitar el mundo. Desde 1977, el museo de la Ciudad de París resguarda tres siglos de
        indumentaria como patrimonio frágil y vivo.
      </p>
    </div>
  </section>

  <section class="home-portals" id="recorridos" aria-label="Recorridos del museo">
    <article class="portal portal--archive" data-portal>
      <h2 class="portal__heading">
        <button
          class="portal__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="portal-acervo"
          data-portal-toggle
        >
          <span class="portal__label">El acervo</span>
        </button>
      </h2>

      <div class="portal__body" id="portal-acervo" aria-hidden="true" inert>
        <div class="portal__body-inner">
          <div class="acervo-panel">
            <div class="acervo-panel__copy">
              <p class="acervo-panel__lead">
                200.000 piezas de indumentaria y accesorios, del siglo XVIII a hoy. La totalidad del
                acervo del Palais Galliera, ordenada, buscable y accesible.
              </p>
              <p class="acervo-panel__note">
                Recorré la colección por objeto o por relato.<br />Dos caminos, un mismo patrimonio.
              </p>
              <div class="portal-actions">
                <a class="portal-cta" href="/coleccion">Colección permanente</a>
                <a class="portal-cta" href="/linea-de-tiempo">Línea de tiempo</a>
              </div>
            </div>

            <div class="acervo-panel__gallery" aria-hidden="true">
              <img
                class="acervo-panel__arch acervo-panel__arch--back"
                src="/images/home/portal-acervo-01.png"
                alt=""
                loading="lazy"
              />
              <img
                class="acervo-panel__arch acervo-panel__arch--middle"
                src="/images/home/portal-acervo-02.png"
                alt=""
                loading="lazy"
              />
              <img
                class="acervo-panel__arch acervo-panel__arch--front"
                src="/images/home/portal-acervo-03.png"
                alt=""
                loading="lazy"
              />
              <div class="acervo-panel__timeline">
                <span>1870</span><span>1870</span><span>1870</span><span>1870</span><span>1870</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>

    <article class="portal portal--exhibition" data-portal>
      <h2 class="portal__heading">
        <button
          class="portal__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="portal-exposiciones"
          data-portal-toggle
        >
          <span class="portal__label">Exposiciones</span>
        </button>
      </h2>

      <div class="portal__body" id="portal-exposiciones" aria-hidden="true" inert>
        <div class="portal__body-inner">
          <div class="exhibition-panel">
            <img
              class="exhibition-panel__image"
              src="/images/home/portal-exposiciones.png"
              alt="Doble página editorial con siluetas del New Look"
              loading="lazy"
            />
            <div class="exhibition-panel__veil" aria-hidden="true"></div>
            <div class="exhibition-panel__copy">
              <h3>New Look</h3>
              <p class="exhibition-panel__date">15 marzo · 28 julio · salas del jardín bajo</p>
              <p class="exhibition-panel__description">
                La moda parisina abrió paso a una nueva etapa.<br />Esta muestra recorre la década
                del New Look a través de prendas, figurines y documentos del acervo del Galliera.
              </p>
              <a class="portal-cta" href="/muestra">Ver exposición</a>
            </div>
            <a class="exhibition-panel__arrow" href="/muestra" aria-label="Ver exposición New Look">
              <img src="/images/home/portal-memory-arrow.svg" alt="" />
            </a>
          </div>
        </div>
      </div>
    </article>

    <article class="portal portal--memory" data-portal>
      <h2 class="portal__heading">
        <button
          class="portal__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="portal-memoria"
          data-portal-toggle
        >
          <span class="portal__label">Memoria</span>
        </button>
      </h2>

      <div class="portal__body" id="portal-memoria" aria-hidden="true" inert>
        <div class="portal__body-inner">
          <div class="memory-panel">
            <a class="memory-card" href="/explorar">
              <span class="memory-card__title">Reconstruír</span>
              <span class="memory-card__number">01</span>
              <span class="memory-card__media memory-card__media--dress">
                <img
                  src="/images/home/portal-memory-01.png"
                  alt="Vestido histórico"
                  loading="lazy"
                />
              </span>
              <span class="memory-card__arrow" aria-hidden="true">
                <img src="/images/home/portal-memory-arrow.svg" alt="" />
              </span>
              <span class="memory-card__copy"
                >Reconocé las prendas de un período y armá su sala.</span
              >
            </a>

            <a class="memory-card" href="/historia">
              <span class="memory-card__title">Leer</span>
              <span class="memory-card__number">02</span>
              <span class="memory-card__media">
                <img
                  src="/images/home/portal-memory-02.png"
                  alt="Ilustración de moda del siglo XIX"
                  loading="lazy"
                />
              </span>
              <span class="memory-card__arrow" aria-hidden="true">
                <img src="/images/home/portal-memory-arrow.svg" alt="" />
              </span>
              <span class="memory-card__copy"
                >Conocé la historia de las épocas icónicas para la moda.</span
              >
            </a>

            <a class="memory-card" href="/coleccion">
              <span class="memory-card__title">Vestir</span>
              <span class="memory-card__number">03</span>
              <span class="memory-card__media">
                <img
                  src="/images/home/portal-memory-03.png"
                  alt="Audrey Hepburn con vestido de alta costura"
                  loading="lazy"
                />
              </span>
              <span class="memory-card__arrow" aria-hidden="true">
                <img src="/images/home/portal-memory-arrow.svg" alt="" />
              </span>
              <span class="memory-card__copy"
                >Conocé los vestuarios de personalidades icónicas.</span
              >
            </a>
          </div>
        </div>
      </div>
    </article>

    <article class="portal portal--agenda" data-portal>
      <h2 class="portal__heading">
        <button
          class="portal__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="portal-agenda"
          data-portal-toggle
        >
          <span class="portal__label">Agenda</span>
        </button>
      </h2>

      <div class="portal__body" id="portal-agenda" aria-hidden="true" inert>
        <div class="portal__body-inner">
          <div class="agenda-panel">
            <h3>Hoy</h3>
            <span class="agenda-panel__rule" aria-hidden="true">
              <img src="/images/home/portal-agenda-rule.svg" alt="" />
            </span>
            <div class="agenda-panel__event">
              <time class="agenda-panel__date" datetime="2026-07-09">
                <span>09</span><small>Jul</small>
              </time>
              <p class="agenda-panel__title">Tejidos y técnicas</p>
              <p class="agenda-panel__type">Visita guiada</p>
              <time class="agenda-panel__time" datetime="17:00"
                ><span>17</span><small>Hs.</small></time
              >
            </div>
            <a class="portal-cta" href="/agenda">Ver agenda completa</a>
          </div>
        </div>
      </div>
    </article>
  </section>
</MainLayout>

<style>
  .home-intro {
    position: relative;
    z-index: 5;
    height: 220svh;
    background: #141414;
  }

  .home-intro__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    isolation: isolate;
    background: #141414;
  }

  .home-intro__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .home-intro__image--title {
    z-index: 1;
    opacity: 0;
    clip-path: inset(100% 0 0 0);
    will-change: clip-path, opacity;
  }

  .home-hero {
    position: relative;
    height: clamp(64rem, 106.46vw, 127.75rem);
    min-height: 64rem;
    overflow: hidden;
    isolation: isolate;
    background: #141414;
    color: var(--color-cream);
  }

  .home-hero__pattern {
    position: absolute;
    top: -221.41vw;
    left: -37.55vw;
    width: 328.23vw;
    aspect-ratio: 6302 / 6301;
    z-index: -2;
    background: url('/images/site/home-pattern.svg') 0 0 / 100% 100% no-repeat;
    pointer-events: none;
  }

  .home-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: none;
  }

  .home-hero__title {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: clamp(6.25rem, 9.9vw, 11.875rem);
    color: var(--color-orange);
    text-transform: uppercase;
    pointer-events: none;
  }

  .home-hero__title span {
    font-family: var(--font-display);
    font-size: clamp(4rem, 7.9vw, 9.5rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.85;
    text-transform: none;
  }

  .home-hero__title strong {
    font-family: var(--font-display);
    font-size: clamp(7rem, 15.7vw, 18.84rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.88;
    letter-spacing: -0.055em;
  }

  .orbit {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .orbit__line {
    position: absolute;
    left: 50%;
    top: 54.89%;
    border: 1px solid rgba(243, 238, 225, 0.72);
    border-radius: 50% 50% 0 0;
    transform: translateX(-50%);
  }

  .orbit__line--outer {
    width: 100%;
    height: 45.11%;
  }

  .orbit__line--inner {
    top: 55.63%;
    width: 98.65%;
    height: 44.37%;
    opacity: 1;
  }

  .orbit__object {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: clamp(7.5rem, var(--w), 12.3125rem);
    margin: 0;
    transform: translate(-50%, -50%) rotate(var(--r));
    transform-origin: 50% 100%;
  }

  .orbit__frame {
    position: relative;
    aspect-ratio: 197 / 266;
  }

  .orbit__frame::after {
    content: '';
    position: absolute;
    inset: -0.5%;
    background: url('/images/home/orbit-frame.svg') center / 100% 100% no-repeat;
    pointer-events: none;
  }

  .orbit__frame img {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .orbit__object figcaption {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.6rem);
    width: max-content;
    max-width: 11rem;
    transform: translateX(-50%);
    display: none;
  }

  .home-hero__manifesto {
    position: absolute;
    z-index: 4;
    left: 50%;
    top: 74.9%;
    bottom: auto;
    width: min(70%, 84rem);
    transform: translateX(-50%);
    text-align: center;
  }

  .home-hero__statement {
    color: #b9d6fe;
    font-size: clamp(2rem, 3.33vw, 4rem);
  }

  .home-hero__intro {
    max-width: 88ch;
    margin: var(--space-sm) auto 0;
    color: rgba(243, 238, 225, 0.74);
    font-size: clamp(0.875rem, 1.667vw, 2rem);
    font-style: italic;
  }

  .home-portals {
    overflow: clip;
    background: var(--color-ink);
  }

  .portal {
    position: relative;
    color: var(--color-cream);
  }

  .portal__heading {
    position: relative;
    z-index: 2;
    margin: 0;
  }

  .portal__toggle {
    width: 100%;
    height: clamp(8rem, 11.6667vw, 14rem);
    display: flex;
    align-items: center;
    padding: 0 var(--layout-gutter);
    border: 0;
    border-top: 1px solid var(--color-ink);
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: filter var(--duration-fast) var(--ease-standard);
  }

  .portal:last-child .portal__toggle {
    border-bottom: 1px solid var(--color-ink);
  }

  .portal__toggle:hover,
  .portal__toggle:focus-visible {
    filter: brightness(1.06);
  }

  .portal__label {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 7.2917vw, 8.75rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.86;
    letter-spacing: -0.02em;
  }

  .portal__body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.85s var(--ease-expo);
  }

  .portal.is-active .portal__body {
    grid-template-rows: 1fr;
  }

  .portal__body-inner {
    min-height: 0;
    overflow: hidden;
  }

  .portal__body-inner > * {
    opacity: 0;
    transform: translateY(-1.5rem);
    transition:
      opacity 0.35s var(--ease-standard),
      transform 0.85s var(--ease-expo);
  }

  .portal.is-active .portal__body-inner > * {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.16s;
  }

  .portal-cta {
    position: relative;
    z-index: 1;
    width: min(16.4375rem, 100%);
    height: 2.833rem;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 0.15rem 1.2rem 0;
    background: url('/images/home/portal-cta.svg') center / 100% 100% no-repeat;
    color: var(--color-cream);
    font-size: 0.875rem;
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.06em;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .portal-cta:hover,
  .portal-cta:focus-visible {
    transform: translateY(-0.15rem);
  }

  .portal--archive .portal__toggle {
    background: linear-gradient(100deg, #141414 0%, #9e3600 48%, #fd6500 100%);
  }

  .portal--exhibition .portal__toggle {
    color: #fd6500;
    background: linear-gradient(100deg, #a52a24 0%, #520345 72%);
  }

  .portal--memory .portal__toggle {
    color: #520345;
    background: linear-gradient(100deg, #8f6aae 0%, #b9d6fe 100%);
  }

  .portal--agenda .portal__toggle {
    color: #141414;
    background: linear-gradient(100deg, #dfe8ef 0%, #f3eee1 100%);
  }

  .acervo-panel {
    position: relative;
    height: clamp(34rem, 38.2292vw, 45.875rem);
    overflow: hidden;
    background:
      radial-gradient(circle at 96% 100%, rgba(253, 101, 0, 0.72), transparent 26%),
      linear-gradient(100deg, #fd6500 0%, #8f3000 43%, #141414 100%);
  }

  .acervo-panel__copy {
    position: absolute;
    z-index: 7;
    left: var(--layout-gutter);
    top: 39.24%;
    width: min(34.53125%, 41.4375rem);
  }

  .acervo-panel__lead {
    max-width: 34ch;
    font-size: clamp(1.3rem, 1.6667vw, 2rem);
    font-style: italic;
    line-height: 1.16;
  }

  .acervo-panel__note {
    margin-top: clamp(2rem, 3.3vw, 4rem);
    font-size: clamp(0.875rem, 0.9375vw, 1.125rem);
    line-height: 1.15;
  }

  .portal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 1.72vw, 2.0625rem);
    margin-top: clamp(2.25rem, 4.6vw, 5.5rem);
  }

  .acervo-panel__gallery {
    position: absolute;
    inset: 0;
  }

  .acervo-panel__arch {
    position: absolute;
    top: 0;
    width: 34.53125%;
    height: 100%;
    object-fit: fill;
    pointer-events: none;
  }

  .acervo-panel__arch--back {
    z-index: 1;
    left: 62.34375%;
  }

  .acervo-panel__arch--middle {
    z-index: 2;
    left: 50.52083%;
  }

  .acervo-panel__arch--front {
    z-index: 3;
    left: 38.64583%;
  }

  .acervo-panel__timeline {
    position: absolute;
    z-index: 6;
    left: 38.64583%;
    right: 0;
    top: 86.24%;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-top: 2px solid #141414;
    color: #141414;
    font-size: clamp(1.2rem, 1.6667vw, 2rem);
    font-style: italic;
  }

  .acervo-panel__timeline span {
    transform: translateY(-0.15em);
  }

  .exhibition-panel {
    position: relative;
    height: clamp(42rem, 48.1771vw, 57.8125rem);
    overflow: hidden;
    background: #520345;
    color: var(--color-cream);
  }

  .exhibition-panel__image,
  .exhibition-panel__veil {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 155.7%;
  }

  .exhibition-panel__image {
    object-fit: cover;
    object-position: top center;
  }

  .exhibition-panel__veil {
    background:
      linear-gradient(90deg, rgba(82, 3, 69, 0.82), rgba(82, 3, 69, 0.5)),
      linear-gradient(180deg, rgba(82, 3, 69, 0.1), rgba(20, 20, 20, 0.28));
    mix-blend-mode: multiply;
  }

  .exhibition-panel__copy {
    position: absolute;
    z-index: 2;
    left: var(--layout-gutter);
    top: 49.5%;
    width: min(31%, 36rem);
  }

  .exhibition-panel__copy h3 {
    font-family: var(--font-body);
    font-size: clamp(4.25rem, 5.9896vw, 7.1875rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.95;
  }

  .exhibition-panel__date {
    margin-top: 0.25rem;
    font-size: clamp(0.8rem, 0.9375vw, 1.125rem);
    text-transform: uppercase;
  }

  .exhibition-panel__description {
    margin-top: clamp(1.6rem, 2.25vw, 2.7rem);
    font-size: clamp(0.875rem, 0.9375vw, 1.125rem);
    line-height: 1.15;
  }

  .exhibition-panel__copy .portal-cta {
    margin-top: clamp(2.5rem, 4.1vw, 4.9rem);
  }

  .exhibition-panel__arrow {
    position: absolute;
    z-index: 2;
    right: var(--layout-gutter);
    bottom: clamp(2rem, 3vw, 3.6rem);
    width: 5.0625rem;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border: 3px solid var(--color-cream);
    border-radius: 50%;
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .exhibition-panel__arrow:hover,
  .exhibition-panel__arrow:focus-visible {
    transform: translateX(0.3rem);
  }

  .exhibition-panel__arrow img {
    width: 66%;
  }

  .memory-panel {
    height: clamp(38rem, 35.0521vw, 42.0625rem);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 4.3%;
    padding: clamp(10rem, 11.25vw, 13.5rem) 5% 4.25rem;
    color: var(--color-cream);
    background: linear-gradient(180deg, #b9d6fe 0%, #9170b0 42%, #520345 100%);
  }

  .memory-card {
    position: relative;
