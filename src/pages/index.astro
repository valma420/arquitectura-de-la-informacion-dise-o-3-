---
import MainLayout from '@layouts/MainLayout.astro';

const orbitObjects = [
  {
    image: '/images/home/orbit-dress.png',
    label: 'Figurín de vestido, archivo Palais Galliera',
    x: 3.7,
    y: 80.3,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-pattern.png',
    label: 'Patronaje, archivo Palais Galliera',
    x: 22.4,
    y: 60.6,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-coat.png',
    label: 'Abrigo bordado, colección Palais Galliera',
    x: 50,
    y: 54,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-blue.png',
    label: 'Detalle textil bordado, colección Palais Galliera',
    x: 77.6,
    y: 60.6,
    width: 10.26,
    rotate: 0,
  },
  {
    image: '/images/home/orbit-photo.png',
    label: 'Fotografía de moda, archivo Palais Galliera',
    x: 96.3,
    y: 80.3,
    width: 10.26,
    rotate: 0,
  },
];

const portals = [
  {
    id: 'acervo',
    number: '01',
    label: 'El acervo',
    title: '243.000 piezas para mirar el tiempo de cerca.',
    copy: 'Indumentaria, accesorios, fotografía y artes gráficas conservados como una memoria material de tres siglos.',
    cta: 'Explorar la colección',
    href: '/coleccion',
    image: '/images/catalogo/c14.png',
    caption: 'Robe à la française · ca. 1775',
    tone: 'archive',
  },
  {
    id: 'exposiciones',
    number: '02',
    label: 'Exposiciones',
    title: 'New Look',
    copy: 'La revolución de 1947 que volvió a dibujar la cintura, el volumen y la manera de mirar el cuerpo vestido.',
    cta: 'Entrar a la muestra',
    href: '/muestra',
    image: '/images/muestra/m14.jpeg',
    caption: 'Tailleur Bar · Christian Dior · 1947',
    tone: 'exhibition',
  },
  {
    id: 'memoria',
    number: '03',
    label: 'Memoria',
    title: 'Las prendas también cuentan quiénes fuimos.',
    copy: 'Biografías, archivos y relatos curatoriales conectan cada objeto con las personas y los gestos que le dieron sentido.',
    cta: 'Leer la historia',
    href: '/historia',
    image: '/images/site/dior-portrait.png',
    caption: 'Christian Dior · 1905–1957',
    tone: 'memory',
  },
  {
    id: 'agenda',
    number: '04',
    label: 'Agenda',
    title: 'El museo está vivo hoy.',
    copy: 'Recorridos, talleres, conversaciones y activaciones alrededor de la colección y de la muestra New Look.',
    cta: 'Ver la agenda',
    href: '/agenda',
    image: '/images/site/palais.jpg',
    caption: 'Palais Galliera · París',
    tone: 'agenda',
  },
];
---

<MainLayout
  title="Palais Galliera"
  description="Palais Galliera — conservar la moda es conservar el tiempo. Explorá el acervo, las exposiciones, la memoria y la agenda del museo."
>
  <section class="home-hero" data-home-hero>
    <div class="home-hero__pattern" aria-hidden="true"></div>

    <h1 class="home-hero__title" aria-label="Palais Galliera">
      <span>Palais</span>
      <strong>Galliera</strong>
    </h1>

    <div class="orbit" data-home-orbit aria-label="Piezas destacadas del acervo">
      <span class="orbit__line orbit__line--outer" aria-hidden="true"></span>
      <span class="orbit__line orbit__line--inner" aria-hidden="true"></span>
      {
        orbitObjects.map((object, index) => (
          <figure
            class="orbit__object"
            style={`--x:${object.x}%;--y:${object.y}%;--w:${object.width}vw;--r:${object.rotate}deg;--i:${index};`}
            data-orbit-object
          >
            <div class="orbit__frame">
              <img src={object.image} alt={object.label} loading="eager" />
            </div>
            <figcaption class="label">{object.label}</figcaption>
          </figure>
        ))
      }
    </div>

    <div class="home-hero__manifesto" data-reveal>
      <p class="home-hero__statement type-display-italic">
        Conservar la moda es conservar el tiempo.
      </p>
      <p class="home-hero__intro">
        Cada prenda que el Palais Galliera guarda es el testimonio de un cuerpo, una época y un modo
        de habitar el mundo. Desde 1977, el museo de la Ciudad de París resguarda tres siglos de
        indumentaria como patrimonio frágil y vivo.
      </p>
    </div>
  </section>

  <section class="home-portals" id="recorridos" aria-label="Recorridos del museo">
    {
      portals.map((portal, index) => (
        <article
          class:list={['portal', `portal--${portal.tone}`, { 'is-active': index === 1 }]}
          data-portal
        >
          <h2 class="portal__heading">
            <button
              class="portal__toggle"
              type="button"
              aria-expanded={index === 1 ? 'true' : 'false'}
              aria-controls={`portal-${portal.id}`}
              data-portal-toggle
            >
              <span class="portal__number label">{portal.number}</span>
              <span class="portal__label">{portal.label}</span>
              <span class="portal__icon" aria-hidden="true">
                ↗
              </span>
            </button>
          </h2>

          <div class="portal__body" id={`portal-${portal.id}`}>
            <div class="portal__body-inner">
              <div class="portal__preview">
                <div class="portal__copy">
                  <p class="label">{portal.label}</p>
                  <h3>{portal.title}</h3>
                  <p>{portal.copy}</p>
                  <a class="portal__cta label" href={portal.href}>
                    {portal.cta} <span aria-hidden="true">→</span>
                  </a>
                </div>

                <figure class="portal__media">
                  <img src={portal.image} alt={portal.caption} loading="lazy" />
                  <figcaption class="label">{portal.caption}</figcaption>
                </figure>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</MainLayout>

<style>
  .home-hero {
    position: relative;
    height: clamp(64rem, 106.46vw, 127.75rem);
    min-height: 64rem;
    overflow: hidden;
    isolation: isolate;
    background: #141414;
    color: var(--color-cream);
  }

  .home-hero__pattern {
    position: absolute;
    top: -221.41vw;
    left: -37.55vw;
    width: 328.23vw;
    aspect-ratio: 6302 / 6301;
    z-index: -2;
    background: url('/images/site/home-pattern.svg') 0 0 / 100% 100% no-repeat;
    pointer-events: none;
  }

  .home-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: none;
  }

  .home-hero__title {
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: clamp(6.25rem, 9.9vw, 11.875rem);
    color: var(--color-orange);
    text-transform: uppercase;
    pointer-events: none;
  }

  .home-hero__title span {
    font-family: var(--font-display);
    font-size: clamp(4rem, 7.9vw, 9.5rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.85;
    text-transform: none;
  }

  .home-hero__title strong {
    font-family: var(--font-display);
    font-size: clamp(7rem, 15.7vw, 18.84rem);
    font-weight: var(--font-weight-regular);
    line-height: 0.88;
    letter-spacing: -0.055em;
  }

  .orbit {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .orbit__line {
    position: absolute;
    left: 50%;
    top: 54.89%;
    border: 1px solid rgba(243, 238, 225, 0.72);
    border-radius: 50% 50% 0 0;
    transform: translateX(-50%);
  }

  .orbit__line--outer {
    width: 100%;
    height: 45.11%;
  }

  .orbit__line--inner {
    top: 55.63%;
    width: 98.65%;
    height: 44.37%;
    opacity: 1;
  }

  .orbit__object {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: clamp(7.5rem, var(--w), 12.3125rem);
    margin: 0;
    transform: translate(-50%, -50%) rotate(var(--r));
    transform-origin: 50% 100%;
  }

  .orbit__frame {
    position: relative;
    aspect-ratio: 197 / 266;
  }

  .orbit__frame::after {
    content: '';
    position: absolute;
    inset: -0.5%;
    background: url('/images/home/orbit-frame.svg') center / 100% 100% no-repeat;
    pointer-events: none;
  }

  .orbit__frame img {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .orbit__object figcaption {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.6rem);
    width: max-content;
    max-width: 11rem;
    transform: translateX(-50%);
    display: none;
  }

  .home-hero__manifesto {
    position: absolute;
    z-index: 4;
    left: 50%;
    top: 74.9%;
    bottom: auto;
    width: min(70%, 84rem);
    transform: translateX(-50%);
    text-align: center;
  }

  .home-hero__statement {
    color: #b9d6fe;
    font-size: clamp(2rem, 3.33vw, 4rem);
  }

  .home-hero__intro {
    max-width: 88ch;
    margin: var(--space-sm) auto 0;
    color: rgba(243, 238, 225, 0.74);
    font-size: clamp(0.875rem, 1.667vw, 2rem);
    font-style: italic;
  }

  .home-portals {
    background: var(--color-ink);
  }

  .portal {
    color: var(--color-cream);
  }

  .portal__heading {
    position: relative;
    z-index: 2;
  }

  .portal__toggle {
    width: 100%;
    min-height: clamp(5.25rem, 10vw, 8rem);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-md);
    padding: 0.45rem var(--layout-gutter);
    border: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
  }

  .portal__number {
    align-self: start;
    padding-top: 0.7rem;
  }

  .portal__label {
    font-family: var(--font-display);
    font-size: clamp(3.1rem, 7vw, 7.5rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
  }

  .portal__icon {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4rem);
    transition: transform var(--duration-base) var(--ease-expo);
  }

  .portal.is-active .portal__icon {
    transform: rotate(90deg);
  }

  .portal__body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.8s var(--ease-expo);
  }

  .portal.is-active .portal__body {
    grid-template-rows: 1fr;
  }

  .portal__body-inner {
    overflow: hidden;
  }

  .portal__preview {
    min-height: clamp(27rem, 58svh, 44rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.8fr);
    gap: clamp(2rem, 8vw, 9rem);
    align-items: center;
    padding: clamp(2.5rem, 7vh, 6rem) var(--layout-gutter);
  }

  .portal__copy {
    max-width: 48rem;
  }

  .portal__copy > .label {
    opacity: 0.72;
  }

  .portal__copy h3 {
    margin-top: var(--space-md);
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.95;
    max-width: 12ch;
  }

  .portal__copy > p:not(.label) {
    margin-top: var(--space-lg);
    max-width: 48ch;
    line-height: 1.65;
  }

  .portal__cta {
    display: inline-flex;
    gap: 1rem;
    align-items: center;
    margin-top: var(--space-lg);
    padding: 0.9rem 1.2rem;
    border: 1px solid currentColor;
    transition:
      color var(--duration-fast) var(--ease-standard),
      background var(--duration-fast) var(--ease-standard);
  }

  .portal__cta:hover {
    color: var(--color-ink);
    background: var(--color-cream);
  }

  .portal__media {
    position: relative;
    width: min(100%, 27rem);
    margin: 0 auto;
  }

  .portal__media img {
    width: 100%;
    height: clamp(22rem, 48vw, 35rem);
    object-fit: cover;
    object-position: top;
    border-radius: 48% 48% 0 0 / 18% 18% 0 0;
    filter: saturate(0.82) contrast(1.04);
  }

  .portal__media figcaption {
    position: absolute;
    right: 0;
    bottom: 0;
    max-width: 85%;
    padding: 0.65rem 0.8rem;
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .portal--archive .portal__toggle,
  .portal--archive .portal__preview {
    background: linear-gradient(105deg, #1d120a, #8f3000 46%, #ff5a00);
  }

  .portal--exhibition .portal__toggle,
  .portal--exhibition .portal__preview {
    background:
      linear-gradient(115deg, rgba(255, 90, 0, 0.15), transparent 38%),
      linear-gradient(100deg, var(--color-purple-deep), var(--color-purple));
  }

  .portal--memory .portal__toggle,
  .portal--memory .portal__preview {
    color: var(--color-purple-deep);
    background: linear-gradient(110deg, #b69ad9, var(--color-blue));
  }

  .portal--agenda .portal__toggle,
  .portal--agenda .portal__preview {
    color: var(--color-purple);
    background: linear-gradient(115deg, var(--color-cream) 30%, var(--color-blue));
  }

  @media (max-width: 800px) {
    .home-hero {
      height: max(45rem, calc(100svh - 72px));
      min-height: 45rem;
    }

    .home-hero__pattern {
      top: -95rem;
      left: -22rem;
      width: 112rem;
    }

    .home-hero__title {
      padding-top: 2.5rem;
    }

    .home-hero__title span {
      font-size: clamp(2.2rem, 10vw, 3.3rem);
    }

    .home-hero__title strong {
      font-size: clamp(4.2rem, 20vw, 6.5rem);
    }

    .orbit__line--outer {
      top: 38%;
      width: 125%;
      height: 44%;
    }

    .orbit__line--inner {
      top: 44%;
      width: 94%;
      height: 34%;
    }

    .orbit__object {
      width: clamp(4.1rem, var(--w), 6.5rem);
    }

    .orbit__object:nth-of-type(3) {
      top: 36%;
    }

    .orbit__object figcaption {
      display: none;
    }

    .home-hero__manifesto {
      top: auto;
      bottom: 1.75rem;
      width: calc(100% - 2 * var(--layout-gutter));
    }

    .home-hero__statement {
      font-size: clamp(1.9rem, 8vw, 2.8rem);
    }

    .portal__toggle {
      min-height: 5.25rem;
      gap: var(--space-sm);
    }

    .portal__label {
      font-size: clamp(2.6rem, 14vw, 4.2rem);
    }

    .portal__preview {
      min-height: 40rem;
      grid-template-columns: 1fr;
      align-content: start;
      gap: var(--space-xl);
      padding-block: var(--space-xl);
    }

    .portal__copy h3 {
      font-size: clamp(2.8rem, 14vw, 4.8rem);
    }

    .portal__media {
      width: min(78vw, 21rem);
    }

    .portal__media img {
      height: 26rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .portal__body {
      transition: none;
    }
  }
</style>

<script>
  const portalElements = Array.from(document.querySelectorAll<HTMLElement>('[data-portal]'));
  const hoverQuery = window.matchMedia('(hover: hover) and (pointer: fine)');

  function activatePortal(target: HTMLElement) {
    portalElements.forEach((portal) => {
      const active = portal === target;
      portal.classList.toggle('is-active', active);
      portal
        .querySelector<HTMLButtonElement>('[data-portal-toggle]')
        ?.setAttribute('aria-expanded', String(active));
    });
  }

  portalElements.forEach((portal) => {
    portal
      .querySelector<HTMLButtonElement>('[data-portal-toggle]')
      ?.addEventListener('click', () => activatePortal(portal));

    portal.addEventListener('pointerenter', () => {
      if (hoverQuery.matches) activatePortal(portal);
    });
  });
</script>
