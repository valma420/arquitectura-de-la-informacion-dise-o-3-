---
import MainLayout from '@layouts/MainLayout.astro';
---

<MainLayout
  title="Palais Galliera"
  description="Explorá la colección, las exposiciones, la memoria y la agenda del Palais Galliera."
  immersive
>
  <section class="flower-home" data-flower-home aria-label="Palais Galliera: recorridos del museo">
    <div class="flower-home__stage" data-home-stage>
      <div class="flower-home__lens" data-home-lens aria-hidden="true"></div>

      <h1 class="flower-home__title" aria-label="Palais Galliera">
        <span>Palais</span>
        <span>Galliera</span>
      </h1>

      <nav class="flower-map" aria-label="Explorar el Palais Galliera">
        <button
          class="flower-trigger flower-trigger--archive"
          type="button"
          aria-controls="home-panel-archive"
          aria-expanded="false"
          data-panel-trigger="archive"
        >
          <span class="flower-trigger__mark" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="flower-trigger__label">Colecciones</span>
        </button>

        <button
          class="flower-trigger flower-trigger--exhibition"
          type="button"
          aria-controls="home-panel-exhibition"
          aria-expanded="false"
          data-panel-trigger="exhibition"
        >
          <span class="flower-trigger__mark" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="flower-trigger__label">Exposiciones</span>
        </button>

        <button
          class="flower-trigger flower-trigger--memory"
          type="button"
          aria-controls="home-panel-memory"
          aria-expanded="false"
          data-panel-trigger="memory"
        >
          <span class="flower-trigger__mark" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="flower-trigger__label">Memoria</span>
        </button>

        <button
          class="flower-trigger flower-trigger--agenda"
          type="button"
          aria-controls="home-panel-agenda"
          aria-expanded="false"
          data-panel-trigger="agenda"
        >
          <span class="flower-trigger__mark" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="flower-trigger__label">Agenda</span>
        </button>
      </nav>
    </div>

    <section
      class="flower-panel flower-panel--archive"
      id="home-panel-archive"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-archive-title"
      data-home-panel="archive"
      hidden
      inert
    >
      <button class="flower-panel__close" type="button" data-panel-close>
        <span aria-hidden="true">←</span>
        Volver
      </button>

      <div class="flower-panel__single">
        <div class="flower-panel__bloom" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="flower-panel__content flower-panel__content--archive">
          <h2 id="home-panel-archive-title">El acervo</h2>
          <p class="flower-panel__copy">
            200.000 piezas de indumentaria y accesorios, del siglo XVIII a hoy. La totalidad del
            acervo del Palais Galliera, ordenada, buscable y accesible.
          </p>
          <p class="flower-panel__copy">
            Recorré la colección por objeto o por relato.<br />
            Dos caminos, un mismo patrimonio.
          </p>
          <div class="flower-panel__actions">
            <a class="flower-link" href="/coleccion-permanente">
              <span>Colección permanente</span>
              <span aria-hidden="true">↗</span>
            </a>
            <a class="flower-link" href="/linea-de-tiempo">
              <span>Línea de tiempo</span>
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section
      class="flower-panel flower-panel--exhibition"
      id="home-panel-exhibition"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-exhibition-title"
      data-home-panel="exhibition"
      hidden
      inert
    >
      <button class="flower-panel__close" type="button" data-panel-close>
        <span aria-hidden="true">←</span>
        Volver
      </button>

      <div class="flower-panel__single">
        <div class="flower-panel__bloom" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="flower-panel__content flower-panel__content--exhibition">
          <p class="flower-panel__section">15 marzo – 28 julio · Salas del jardín bajo</p>
          <h2 id="home-panel-exhibition-title">New Look</h2>
          <p class="flower-panel__copy">
            La moda parisina abrió paso a una nueva etapa. Esta muestra recorre la década del New
            Look a través de prendas, figurines y documentos del acervo del Galliera.
          </p>
          <div class="flower-panel__actions flower-panel__actions--centered">
            <a class="flower-link" href="/muestra">
              <span>Ver exposición</span>
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section
      class="flower-panel flower-panel--memory"
      id="home-panel-memory"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-memory-title"
      data-home-panel="memory"
      hidden
      inert
    >
      <button class="flower-panel__close" type="button" data-panel-close>
        <span aria-hidden="true">←</span>
        Volver
      </button>

      <div class="memory-panel">
        <h2 class="visually-hidden" id="home-panel-memory-title">Memoria</h2>

        <a class="memory-flower" href="/explorar">
          <span class="memory-flower__bloom" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="memory-flower__content">
            <strong>Reconstruír</strong>
            <span>Reconocé las prendas de un período y armá su sala.</span>
            <span class="memory-flower__cta">Descubrir <span aria-hidden="true">↗</span></span>
          </span>
        </a>

        <a class="memory-flower" href="/historia">
          <span class="memory-flower__bloom" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="memory-flower__content">
            <strong>Leer</strong>
            <span>Conocé la historia de las épocas icónicas para la moda.</span>
            <span class="memory-flower__cta">Descubrir <span aria-hidden="true">↗</span></span>
          </span>
        </a>

        <a class="memory-flower" href="/guardarropas">
          <span class="memory-flower__bloom" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </span>
          <span class="memory-flower__content">
            <strong>Vestir</strong>
            <span>Conocé los vestuarios de personalidades icónicas.</span>
            <span class="memory-flower__cta">Descubrir <span aria-hidden="true">↗</span></span>
          </span>
        </a>
      </div>
    </section>

    <section
      class="flower-panel flower-panel--agenda"
      id="home-panel-agenda"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-agenda-title"
      data-home-panel="agenda"
      hidden
      inert
    >
      <button class="flower-panel__close" type="button" data-panel-close>
        <span aria-hidden="true">←</span>
        Volver
      </button>

      <div class="flower-panel__single">
        <div class="flower-panel__bloom" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="flower-panel__content flower-panel__content--agenda">
          <p class="flower-panel__section">Charla · 18hs · Auditorio</p>
          <h2 id="home-panel-agenda-title">Vestir el siglo XIX</h2>
          <div class="flower-panel__actions flower-panel__actions--centered">
            <a class="flower-link" href="/agenda">
              <span>Ver agenda completa</span>
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </section>
</MainLayout>

<script>
  const initializeFlowerHome = () => {
    const home = document.querySelector<HTMLElement>('[data-flower-home]');

    if (!home || home.dataset.initialized === 'true') return;

    home.dataset.initialized = 'true';

    const stage = home.querySelector<HTMLElement>('[data-home-stage]');
    const lens = home.querySelector<HTMLElement>('[data-home-lens]');
    const triggers = Array.from(home.querySelectorAll<HTMLButtonElement>('[data-panel-trigger]'));
    const panels = Array.from(home.querySelectorAll<HTMLElement>('[data-home-panel]'));
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const finePointer = window.matchMedia('(pointer: fine)');
    const controller = new AbortController();
    const { signal } = controller;

    let activePanel: HTMLElement | null = null;
    let returnFocus: HTMLButtonElement | null = null;
    let lensPinned = false;
    let animationFrame = 0;
    let closeTimer = 0;

    if (!stage || !lens) return;

    const setLensPosition = (clientX: number, clientY: number) => {
      const bounds = stage.getBoundingClientRect();
      const x = Math.max(0, Math.min(bounds.width, clientX - bounds.left));
      const y = Math.max(0, Math.min(bounds.height, clientY - bounds.top));
      const xPercent = (x / bounds.width) * 100;
      const yPercent = (y / bounds.height) * 100;
      const parallaxX = (x / bounds.width - 0.5) * -88;
      const parallaxY = (y / bounds.height - 0.5) * -64;

      cancelAnimationFrame(animationFrame);
      animationFrame = requestAnimationFrame(() => {
        home.style.setProperty('--lens-x', `${xPercent}%`);
        home.style.setProperty('--lens-y', `${yPercent}%`);
        home.style.setProperty('--pattern-x', `${parallaxX}px`);
        home.style.setProperty('--pattern-y', `${parallaxY}px`);
      });
    };

    const centerLens = () => {
      const bounds = stage.getBoundingClientRect();
      setLensPosition(bounds.left + bounds.width / 2, bounds.top + bounds.height / 2);
    };

    const moveLensToTrigger = (trigger: HTMLButtonElement) => {
      const mark = trigger.querySelector<HTMLElement>('.flower-trigger__mark');
      const bounds = (mark ?? trigger).getBoundingClientRect();
      setLensPosition(bounds.left + bounds.width / 2, bounds.top + bounds.height / 2);
    };

    const closePanel = () => {
      if (!activePanel) return;

      const panelToClose = activePanel;
      const triggerToFocus = returnFocus;
      const transitionDuration = reducedMotion.matches ? 0 : 420;

      window.clearTimeout(closeTimer);
      panelToClose.classList.remove('is-visible');
      panelToClose.inert = true;
      stage.inert = false;
      home.removeAttribute('data-panel-open');

      triggers.forEach((trigger) => trigger.setAttribute('aria-expanded', 'false'));
      activePanel = null;
      returnFocus = null;
      lensPinned = false;
      centerLens();
      triggerToFocus?.focus({ preventScroll: true });

      closeTimer = window.setTimeout(() => {
        panelToClose.hidden = true;
      }, transitionDuration);
    };

    const openPanel = (trigger: HTMLButtonElement) => {
      const panelName = trigger.dataset.panelTrigger;
      const panel = panels.find((item) => item.dataset.homePanel === panelName);

      if (!panel) return;
      if (activePanel) closePanel();

      window.clearTimeout(closeTimer);
      returnFocus = trigger;
      activePanel = panel;
      stage.inert = true;
      panel.hidden = false;
      panel.inert = false;
      home.dataset.panelOpen = panelName ?? '';

      triggers.forEach((item) => {
        item.setAttribute('aria-expanded', String(item === trigger));
      });

      requestAnimationFrame(() => {
        panel.classList.add('is-visible');
        panel.querySelector<HTMLButtonElement>('[data-panel-close]')?.focus({
          preventScroll: true,
        });
      });
    };

    stage.addEventListener(
      'pointermove',
      (event) => {
        if (!finePointer.matches || lensPinned || activePanel) return;
        setLensPosition(event.clientX, event.clientY);
      },
      { signal }
    );

    stage.addEventListener(
      'pointerleave',
      () => {
        if (!lensPinned && !activePanel) centerLens();
      },
      { signal }
    );

    stage.addEventListener(
      'pointerdown',
      (event) => {
        if (event.pointerType === 'touch' && !activePanel) {
          setLensPosition(event.clientX, event.clientY);
        }
      },
      { signal }
    );

    triggers.forEach((trigger) => {
      trigger.addEventListener(
        'pointerenter',
        () => {
          lensPinned = true;
          moveLensToTrigger(trigger);
        },
        { signal }
      );

      trigger.addEventListener(
        'pointerleave',
        () => {
          if (document.activeElement === trigger) return;
          lensPinned = false;
          centerLens();
        },
        { signal }
      );

      trigger.addEventListener(
        'focus',
        () => {
          lensPinned = true;
          moveLensToTrigger(trigger);
        },
        { signal }
      );

      trigger.addEventListener(
        'blur',
        () => {
          lensPinned = false;
          if (!activePanel) centerLens();
        },
        { signal }
      );

      trigger.addEventListener('click', () => openPanel(trigger), { signal });
    });

    home.querySelectorAll<HTMLButtonElement>('[data-panel-close]').forEach((button) => {
      button.addEventListener('click', closePanel, { signal });
    });

    document.addEventListener(
      'keydown',
      (event) => {
        if (event.key === 'Escape' && activePanel) closePanel();
      },
      { signal }
    );

    window.addEventListener(
      'resize',
      () => {
        if (!activePanel && !lensPinned) centerLens();
      },
      { signal }
    );

    document.addEventListener(
      'astro:before-swap',
      () => {
        window.clearTimeout(closeTimer);
        cancelAnimationFrame(animationFrame);
        controller.abort();
      },
      { once: true, signal }
    );

    centerLens();
  };

  initializeFlowerHome();
  document.addEventListener('astro:page-load', initializeFlowerHome);
</script>

<style>
  :global(body) {
    background: var(--color-cream);
    overflow: hidden;
  }

  :global(#main-content) {
    min-height: 100svh;
  }

  .flower-home {
    --lens-x: 50%;
    --lens-y: 50%;
    --pattern-x: 0px;
    --pattern-y: 0px;
    --home-cream: #f3eee1;
    --home-orange: #fd6500;
    --home-blue: #adc6e0;
    position: relative;
    height: 100svh;
    min-height: 42rem;
    overflow: hidden;
    color: var(--color-ink);
    background: var(--home-cream);
    isolation: isolate;
  }

  .flower-home__stage {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--home-cream);
  }

  .flower-home__lens {
    position: absolute;
    z-index: 1;
    top: var(--lens-y);
    left: var(--lens-x);
    width: clamp(18rem, 25vw, 30rem);
    aspect-ratio: 1;
    border-radius: 50%;
    background-color: var(--home-blue);
    opacity: 0.96;
    transform: translate(-50%, -50%);
    transition:
      top 220ms var(--ease-out),
      left 220ms var(--ease-out),
      width 350ms var(--ease-expo);
    mask-image: radial-gradient(circle, #000 0 42%, transparent 71%);
    pointer-events: none;
    will-change: top, left;
  }

  .flower-home__lens::before {
    position: absolute;
    inset: 0;
    background-image: url('/images/site/home-pattern-outline.svg');
    background-repeat: no-repeat;
    background-position: calc(50% + var(--pattern-x)) calc(50% + var(--pattern-y));
    background-size: 250% 250%;
    content: '';
    filter: drop-shadow(0.7px 0 0 rgb(243 238 225 / 0.92))
      drop-shadow(-0.7px 0 0 rgb(243 238 225 / 0.92)) drop-shadow(0 0.7px 0 rgb(243 238 225 / 0.92))
      drop-shadow(0 -0.7px 0 rgb(243 238 225 / 0.92));
    will-change: background-position;
  }

  .flower-home__title {
    position: absolute;
    z-index: 2;
    top: 51.4%;
    left: 50%;
    display: flex;
    width: min-content;
    margin: 0;
    color: var(--home-orange);
    font-family: var(--font-display);
    font-size: clamp(7rem, 10.42vw, 12.5rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.045em;
    text-align: center;
    flex-direction: column;
    transform: translate(-50%, -50%) scaleX(0.79);
    pointer-events: none;
  }

  .flower-map {
    position: absolute;
    z-index: 3;
    inset: 0;
  }

  .flower-trigger {
    --trigger-x: 50%;
    --trigger-y: 50%;
    position: absolute;
    top: var(--trigger-y);
    left: var(--trigger-x);
    width: 12rem;
    height: 7rem;
    padding: 0;
    border: 0;
    color: var(--home-cream);
    background: transparent;
    cursor: pointer;
    transform: translate(-50%, -50%);
    touch-action: manipulation;
  }

  .flower-trigger--archive {
    --trigger-x: 22.5%;
    --trigger-y: 64.7%;
  }

  .flower-trigger--exhibition {
    --trigger-x: 40%;
    --trigger-y: 82.7%;
  }

  .flower-trigger--memory {
    --trigger-x: 51.5%;
    --trigger-y: 22.7%;
  }

  .flower-trigger--agenda {
    --trigger-x: 86.7%;
    --trigger-y: 55.5%;
  }

  .flower-trigger__mark {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1.7rem;
    height: 1.7rem;
    border: 1.5px solid var(--home-orange);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition:
      width 280ms var(--ease-expo),
      height 280ms var(--ease-expo),
      border-color 180ms ease;
  }

  .flower-trigger__mark span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1rem;
    height: 1.45rem;
    border-radius: 50%;
    background: var(--home-cream);
    opacity: 0;
    transform: translate(-50%, -105%) scale(0.35);
    transform-origin: 50% 105%;
    transition:
      opacity 160ms ease,
      transform 280ms var(--ease-expo);
  }

  .flower-trigger__mark span:nth-child(2) {
    transform: translate(-50%, -105%) rotate(72deg) scale(0.35);
  }

  .flower-trigger__mark span:nth-child(3) {
    transform: translate(-50%, -105%) rotate(144deg) scale(0.35);
  }

  .flower-trigger__mark span:nth-child(4) {
    transform: translate(-50%, -105%) rotate(216deg) scale(0.35);
  }

  .flower-trigger__mark span:nth-child(5) {
    transform: translate(-50%, -105%) rotate(288deg) scale(0.35);
  }

  .flower-trigger__label {
    position: absolute;
    top: 50%;
    left: calc(50% + 2.15rem);
    color: var(--home-cream);
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 1.65vw, 2rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1;
    opacity: 0;
    transform: translateY(-50%) translateX(-0.5rem);
    transition:
      opacity 180ms ease,
      transform 280ms var(--ease-expo);
    white-space: nowrap;
  }

  .flower-trigger--exhibition .flower-trigger__label,
  .flower-trigger--memory .flower-trigger__label {
    top: calc(50% + 2.5rem);
    left: 50%;
    transform: translate(-50%, -0.5rem);
  }

  .flower-trigger--agenda .flower-trigger__label {
    right: calc(50% + 2.15rem);
    left: auto;
    transform: translateY(-50%) translateX(0.5rem);
  }

  .flower-trigger:is(:hover, :focus-visible) .flower-trigger__mark {
    width: 3.25rem;
    height: 3.25rem;
    border-color: transparent;
  }

  .flower-trigger:is(:hover, :focus-visible) .flower-trigger__mark span {
    opacity: 1;
    transform: translate(-50%, -105%) scale(1);
  }

  .flower-trigger:is(:hover, :focus-visible) .flower-trigger__mark span:nth-child(2) {
    transform: translate(-50%, -105%) rotate(72deg) scale(1);
  }

  .flower-trigger:is(:hover, :focus-visible) .flower-trigger__mark span:nth-child(3) {
    transform: translate(-50%, -105%) rotate(144deg) scale(1);
  }

  .flower-trigger:is(:hover, :focus-visible) .flower-trigger__mark span:nth-child(4) {
    transform: translate(-50%, -105%) rotate(216deg) scale(1);
  }

  .flower-trigger:is(:hover, :focus-visible) .flower-trigger__mark span:nth-child(5) {
    transform: translate(-50%, -105%) rotate(288deg) scale(1);
  }

  .flower-trigger:is(:hover, :focus-visible) .flower-trigger__label {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .flower-trigger--exhibition:is(:hover, :focus-visible) .flower-trigger__label,
  .flower-trigger--memory:is(:hover, :focus-visible) .flower-trigger__label {
    transform: translate(-50%, 0);
  }

  .flower-trigger--agenda:is(:hover, :focus-visible) .flower-trigger__label {
    transform: translateY(-50%) translateX(0);
  }

  .flower-trigger:focus-visible {
    outline: 2px solid var(--home-orange);
    outline-offset: 0.4rem;
  }

  .flower-panel {
    position: absolute;
    z-index: 10;
    inset: 0;
    overflow: hidden auto;
    color: var(--color-ink);
    background: var(--home-blue);
    opacity: 0;
    transform: scale(1.015);
    transition:
      opacity 380ms ease,
      transform 520ms var(--ease-expo);
  }

  .flower-panel[hidden] {
    display: none;
  }

  .flower-panel.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  .flower-panel::before {
    position: fixed;
    z-index: -2;
    inset: -14%;
    background-image: url('/images/site/home-pattern-outline.svg');
    background-position: center;
    background-repeat: no-repeat;
    background-size: 140% 140%;
    content: '';
    opacity: 1;
    filter: drop-shadow(0.7px 0 0 rgb(243 238 225 / 0.92))
      drop-shadow(-0.7px 0 0 rgb(243 238 225 / 0.92)) drop-shadow(0 0.7px 0 rgb(243 238 225 / 0.92))
      drop-shadow(0 -0.7px 0 rgb(243 238 225 / 0.92));
    transform: rotate(-4deg);
  }

  .flower-panel::after {
    position: fixed;
    z-index: -1;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--home-cream) 0%,
      rgb(243 238 225 / 0.78) 12%,
      transparent 32%,
      transparent 68%,
      rgb(243 238 225 / 0.78) 88%,
      var(--home-cream) 100%
    );
    content: '';
    pointer-events: none;
  }

  .flower-panel__close {
    position: fixed;
    z-index: 5;
    top: 9vh;
    left: clamp(1rem, 24vw, 30rem);
    display: inline-flex;
    width: 2.75rem;
    min-height: 2.75rem;
    padding: 0;
    border: 1px solid currentcolor;
    border-radius: 999px;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 0;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgb(243 238 225 / 0.9);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(10px);
  }

  .flower-panel__close:hover {
    color: var(--home-cream);
    background: var(--color-ink);
  }

  .flower-panel__close span {
    font-size: 1.2rem;
