---
import MainLayout from '@layouts/MainLayout.astro';
---

<MainLayout
  title="Palais Galliera"
  description="Explorá la colección, las exposiciones, la memoria y la agenda del Palais Galliera."
  immersive
>
  <section class="home" data-home aria-label="Palais Galliera: recorridos del museo">
    <div class="home-canvas" data-home-canvas>
      <h1 class="visually-hidden">Palais Galliera</h1>

      <div class="home-initial" aria-hidden="true">
        <img
          class="home-reference home-reference--initial"
          src="/images/home/figma/initial.png"
          alt=""
          width="1920"
          height="1080"
          fetchpriority="high"
        />

        <div class="home-dynamic">
          <div class="home-dynamic__lens"></div>

          <div class="home-dynamic__pattern-window">
            <div class="home-dynamic__pattern">
              <img
                class="home-dynamic__pattern-piece home-dynamic__pattern-piece--a"
                src="/images/home/figma/pattern-a.svg"
                alt=""
                width="964"
                height="874"
                draggable="false"
              />
              <img
                class="home-dynamic__pattern-piece home-dynamic__pattern-piece--b"
                src="/images/home/figma/pattern-b.svg"
                alt=""
                width="972"
                height="873"
                draggable="false"
              />
              <img
                class="home-dynamic__pattern-piece home-dynamic__pattern-piece--c"
                src="/images/home/figma/pattern-c.svg"
                alt=""
                width="972"
                height="873"
                draggable="false"
              />
              <img
                class="home-dynamic__pattern-piece home-dynamic__pattern-piece--d"
                src="/images/home/figma/pattern-d.svg"
                alt=""
                width="972"
                height="873"
                draggable="false"
              />
            </div>
          </div>

          <img
            class="home-dynamic__title"
            src="/images/home/figma/title.png"
            alt=""
            width="511"
            height="339"
            draggable="false"
          />

          <span class="home-dynamic__dot home-dynamic__dot--archive"></span>
          <span class="home-dynamic__dot home-dynamic__dot--exhibition"></span>
          <span class="home-dynamic__dot home-dynamic__dot--memory"></span>
          <span class="home-dynamic__dot home-dynamic__dot--agenda"></span>
        </div>
      </div>

      <div class="home-hover-states" aria-hidden="true">
        <img
          class="home-reference home-reference--hover"
          src="/images/home/figma/collections-hover.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          data-hover-reference="archive"
        />
        <img
          class="home-reference home-reference--hover"
          src="/images/home/figma/exhibitions-hover.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          data-hover-reference="exhibition"
        />
        <img
          class="home-reference home-reference--hover"
          src="/images/home/figma/memory-hover.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          data-hover-reference="memory"
        />
        <img
          class="home-reference home-reference--hover"
          src="/images/home/figma/agenda-hover.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          data-hover-reference="agenda"
        />
      </div>

      <nav class="home-map" aria-label="Explorar el Palais Galliera">
        <button
          class="home-trigger home-trigger--archive"
          type="button"
          aria-controls="home-panel-archive"
          aria-expanded="false"
          data-panel-trigger="archive"
        >
          <span class="visually-hidden">Colecciones</span>
        </button>
        <button
          class="home-trigger home-trigger--exhibition"
          type="button"
          aria-controls="home-panel-exhibition"
          aria-expanded="false"
          data-panel-trigger="exhibition"
        >
          <span class="visually-hidden">Exposiciones</span>
        </button>
        <button
          class="home-trigger home-trigger--memory"
          type="button"
          aria-controls="home-panel-memory"
          aria-expanded="false"
          data-panel-trigger="memory"
        >
          <span class="visually-hidden">Memoria</span>
        </button>
        <button
          class="home-trigger home-trigger--agenda"
          type="button"
          aria-controls="home-panel-agenda"
          aria-expanded="false"
          data-panel-trigger="agenda"
        >
          <span class="visually-hidden">Agenda</span>
        </button>
      </nav>
    </div>

    <section
      class="home-panel"
      id="home-panel-archive"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-archive-title"
      data-home-panel="archive"
      hidden
      inert
    >
      <div class="home-canvas">
        <img
          class="home-reference"
          src="/images/home/figma/collections-open.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          aria-hidden="true"
        />
        <div class="visually-hidden">
          <h2 id="home-panel-archive-title">El acervo</h2>
          <p>
            200.000 piezas de indumentaria y accesorios, del siglo XVIII a hoy. La totalidad del
            acervo del Palais Galliera, ordenada, buscable y accesible.
          </p>
          <p>Recorré la colección por objeto o por relato. Dos caminos, un mismo patrimonio.</p>
        </div>
        <button class="panel-hotspot panel-hotspot--back" type="button" data-panel-close>
          <span class="visually-hidden">Volver</span>
        </button>
        <a class="panel-hotspot panel-hotspot--archive-collection" href="/coleccion-permanente">
          <span class="visually-hidden">Colección permanente</span>
        </a>
        <a class="panel-hotspot panel-hotspot--archive-timeline" href="/linea-de-tiempo">
          <span class="visually-hidden">Línea de tiempo</span>
        </a>
      </div>
    </section>

    <section
      class="home-panel"
      id="home-panel-exhibition"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-exhibition-title"
      data-home-panel="exhibition"
      hidden
      inert
    >
      <div class="home-canvas">
        <img
          class="home-reference"
          src="/images/home/figma/exhibitions-open.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          aria-hidden="true"
        />
        <div class="visually-hidden">
          <p>15 marzo – 28 julio · Salas del jardín bajo</p>
          <h2 id="home-panel-exhibition-title">New Look</h2>
          <p>
            La moda parisina abrió paso a una nueva etapa. Esta muestra recorre la década del New
            Look a través de prendas, figurines y documentos del acervo del Galliera.
          </p>
        </div>
        <button class="panel-hotspot panel-hotspot--back" type="button" data-panel-close>
          <span class="visually-hidden">Volver</span>
        </button>
        <a class="panel-hotspot panel-hotspot--single-cta" href="/muestra">
          <span class="visually-hidden">Ver exposición</span>
        </a>
      </div>
    </section>

    <section
      class="home-panel"
      id="home-panel-memory"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-memory-title"
      data-home-panel="memory"
      hidden
      inert
    >
      <div class="home-canvas">
        <img
          class="home-reference"
          src="/images/home/figma/memory-open.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          aria-hidden="true"
        />
        <h2 class="visually-hidden" id="home-panel-memory-title">Memoria</h2>
        <button class="panel-hotspot panel-hotspot--back" type="button" data-panel-close>
          <span class="visually-hidden">Volver</span>
        </button>
        <a class="panel-hotspot panel-hotspot--memory-rebuild" href="/explorar">
          <span class="visually-hidden">Reconstruir: descubrir</span>
        </a>
        <a class="panel-hotspot panel-hotspot--memory-read" href="/historia">
          <span class="visually-hidden">Leer: descubrir</span>
        </a>
        <a class="panel-hotspot panel-hotspot--memory-dress" href="/guardarropas">
          <span class="visually-hidden">Vestir: descubrir</span>
        </a>
      </div>
    </section>

    <section
      class="home-panel"
      id="home-panel-agenda"
      role="dialog"
      aria-modal="true"
      aria-labelledby="home-panel-agenda-title"
      data-home-panel="agenda"
      hidden
      inert
    >
      <div class="home-canvas">
        <img
          class="home-reference"
          src="/images/home/figma/agenda-open.png"
          alt=""
          width="1920"
          height="1080"
          loading="eager"
          aria-hidden="true"
        />
        <div class="visually-hidden">
          <p>Charla · 18hs · Auditorio</p>
          <h2 id="home-panel-agenda-title">Vestir el siglo XIX</h2>
        </div>
        <button class="panel-hotspot panel-hotspot--back" type="button" data-panel-close>
          <span class="visually-hidden">Volver</span>
        </button>
        <a class="panel-hotspot panel-hotspot--single-cta" href="/agenda">
          <span class="visually-hidden">Ver agenda completa</span>
        </a>
      </div>
    </section>
  </section>
</MainLayout>

<script>
  type HomePanelName = 'archive' | 'exhibition' | 'memory' | 'agenda';

  const initializeHome = () => {
    const home = document.querySelector<HTMLElement>('[data-home]');

    if (!home || home.dataset.initialized === 'true') return;

    const stage = home.querySelector<HTMLElement>('[data-home-canvas]');
    const triggers = Array.from(home.querySelectorAll<HTMLButtonElement>('[data-panel-trigger]'));
    const panels = Array.from(home.querySelectorAll<HTMLElement>('[data-home-panel]'));

    if (!stage) return;

    home.dataset.initialized = 'true';

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const finePointer = window.matchMedia('(pointer: fine)');
    const controller = new AbortController();
    const { signal } = controller;

    let activePanel: HTMLElement | null = null;
    let returnFocus: HTMLButtonElement | null = null;
    let animationFrame = 0;
    let closeTimer = 0;

    const clearHoverState = () => {
      delete home.dataset.hoverState;
    };

    const setHoverState = (panelName: HomePanelName) => {
      home.dataset.hoverState = panelName;
      delete home.dataset.dynamic;
    };

    const setLensPosition = (clientX: number, clientY: number) => {
      const bounds = stage.getBoundingClientRect();

      if (!bounds.width || !bounds.height) return;

      const x = Math.max(0, Math.min(bounds.width, clientX - bounds.left));
      const y = Math.max(0, Math.min(bounds.height, clientY - bounds.top));
      const normalizedX = x / bounds.width;
      const normalizedY = y / bounds.height;
      const designScale = bounds.width / 1920;
      const parallaxX = reducedMotion.matches ? 0 : (normalizedX - 0.5) * -48 * designScale;
      const parallaxY = reducedMotion.matches ? 0 : (normalizedY - 0.5) * -36 * designScale;

      cancelAnimationFrame(animationFrame);
      animationFrame = requestAnimationFrame(() => {
        home.style.setProperty('--lens-x', String(normalizedX * 100) + '%');
        home.style.setProperty('--lens-y', String(normalizedY * 100) + '%');
        home.style.setProperty('--pattern-x', String(parallaxX) + 'px');
        home.style.setProperty('--pattern-y', String(parallaxY) + 'px');
        stage.style.setProperty('--lens-local-x', String(x) + 'px');
        stage.style.setProperty('--lens-local-y', String(y) + 'px');
        stage.style.setProperty('--lens-radius-x', String(bounds.width * 0.1203125) + 'px');
        stage.style.setProperty('--lens-radius-y', String(bounds.height * 0.216667) + 'px');
        home.dataset.dynamic = 'true';
      });
    };

    const closePanel = () => {
      if (!activePanel) return;

      const panelToClose = activePanel;
      const triggerToFocus = returnFocus;
      const transitionDuration = reducedMotion.matches ? 0 : 220;

      window.clearTimeout(closeTimer);
      panelToClose.classList.remove('is-visible');
      panelToClose.inert = true;
      stage.inert = false;
      delete home.dataset.panelOpen;
      activePanel = null;
      returnFocus = null;

      triggers.forEach((trigger) => trigger.setAttribute('aria-expanded', 'false'));
      clearHoverState();
      delete home.dataset.dynamic;
      triggerToFocus?.focus({ preventScroll: true });

      closeTimer = window.setTimeout(() => {
        panelToClose.hidden = true;
      }, transitionDuration);
    };

    const openPanel = (trigger: HTMLButtonElement) => {
      const panelName = trigger.dataset.panelTrigger as HomePanelName | undefined;
      const panel = panels.find((item) => item.dataset.homePanel === panelName);

      if (!panel || !panelName) return;

      window.clearTimeout(closeTimer);
      returnFocus = trigger;
      activePanel = panel;
      clearHoverState();
      delete home.dataset.dynamic;
      stage.inert = true;
      panel.hidden = false;
      panel.inert = false;
      home.dataset.panelOpen = panelName;

      triggers.forEach((item) => {
        item.setAttribute('aria-expanded', String(item === trigger));
      });

      requestAnimationFrame(() => {
        panel.classList.add('is-visible');
        panel.querySelector<HTMLButtonElement>('[data-panel-close]')?.focus({
          preventScroll: true,
        });
      });
    };

    stage.addEventListener(
      'pointermove',
      (event) => {
        if (!finePointer.matches || activePanel || home.dataset.hoverState) return;
        setLensPosition(event.clientX, event.clientY);
      },
      { signal }
    );

    stage.addEventListener(
      'pointerleave',
      () => {
        if (activePanel || home.dataset.hoverState) return;
        delete home.dataset.dynamic;
      },
      { signal }
    );

    triggers.forEach((trigger) => {
      const panelName = trigger.dataset.panelTrigger as HomePanelName;

      trigger.addEventListener('pointerenter', () => setHoverState(panelName), { signal });
      trigger.addEventListener(
        'pointerleave',
        () => {
          if (document.activeElement !== trigger) clearHoverState();
        },
        { signal }
      );
      trigger.addEventListener('focus', () => setHoverState(panelName), { signal });
      trigger.addEventListener(
        'blur',
        () => {
          if (!activePanel) clearHoverState();
        },
        { signal }
      );
      trigger.addEventListener('click', () => openPanel(trigger), { signal });
    });

    home.querySelectorAll<HTMLButtonElement>('[data-panel-close]').forEach((button) => {
      button.addEventListener('click', closePanel, { signal });
    });

    document.addEventListener(
      'keydown',
      (event) => {
        if (!activePanel) return;

        if (event.key === 'Escape') {
          event.preventDefault();
          closePanel();
          return;
        }

        if (event.key !== 'Tab') return;

        const focusable = Array.from(
          activePanel.querySelectorAll<HTMLElement>('button:not([disabled]), a[href]')
        );
        const first = focusable.at(0);
        const last = focusable.at(-1);

        if (!first || !last) return;

        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      },
      { signal }
    );

    document.addEventListener(
      'astro:before-swap',
      () => {
        window.clearTimeout(closeTimer);
        cancelAnimationFrame(animationFrame);
        controller.abort();
      },
      { once: true, signal }
    );
  };

  initializeHome();
  document.addEventListener('astro:page-load', initializeHome);
</script>

<style>
  :global(body) {
    background: #f3eee1;
    overflow: hidden;
  }

  :global(#main-content) {
    min-height: 100svh;
  }

  .home {
    --lens-x: 50%;
    --lens-y: 50.463%;
    --pattern-x: 0px;
    --pattern-y: 0px;
    position: relative;
    width: 100vw;
    height: 100svh;
    overflow: hidden;
    background: #f3eee1;
    color: #141414;
    isolation: isolate;
  }

  .home-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(100vw, 177.7778svh);
    height: min(100svh, 56.25vw);
    overflow: hidden;
    transform: translate(-50%, -50%);
    background: #f3eee1;
    container-type: size;
  }

  .home-canvas[data-home-canvas] {
    overflow: visible;
  }

  .home-reference,
  .home-initial,
  .home-hover-states,
  .home-dynamic,
  .home-map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .home-reference {
    display: block;
    object-fit: fill;
    pointer-events: none;
    user-select: none;
  }

  .home-reference--initial {
    z-index: 0;
  }

  .home-dynamic {
    z-index: 1;
    overflow: visible;
    background: #f3eee1;
    opacity: 0;
    transition: opacity 140ms ease;
  }

  .home[data-dynamic='true'] .home-dynamic {
    opacity: 1;
  }

  .home-dynamic__lens {
    position: absolute;
    z-index: 0;
    top: calc((100cqh - 100dvh) / 2);
    left: calc((100cqw - 100vw) / 2);
    width: 100vw;
    height: 100dvh;
    background: radial-gradient(
      ellipse var(--lens-radius-x) var(--lens-radius-y) at
        calc(var(--lens-local-x) - ((100cqw - 100vw) / 2))
        calc(var(--lens-local-y) - ((100cqh - 100dvh) / 2)),
      #b0c8df 0 48%,
      rgb(176 200 223 / 72%) 68%,
      transparent 100%
    );
    pointer-events: none;
    will-change: background;
  }

  .home-dynamic__pattern-window {
    position: absolute;
    z-index: 1;
    inset: 0;
    overflow: hidden;
    clip-path: ellipse(12.03125% 21.6667% at var(--lens-x) var(--lens-y));
    -webkit-mask-image: radial-gradient(
      ellipse 12.03125% 21.6667% at var(--lens-x) var(--lens-y),
      #000 0 92%,
      transparent 100%
    );
    mask-image: radial-gradient(
      ellipse 12.03125% 21.6667% at var(--lens-x) var(--lens-y),
      #000 0 92%,
      transparent 100%
    );
    pointer-events: none;
    will-change: clip-path;
  }

  .home-dynamic__pattern {
    position: absolute;
    inset: 0;
    transform: translate3d(var(--pattern-x), var(--pattern-y), 0);
    will-change: transform;
  }

  .home-dynamic__pattern-piece {
    position: absolute;
    display: block;
    max-width: none;
    pointer-events: none;
    user-select: none;
  }

  .home-dynamic__pattern-piece--a {
    top: -29.7617%;
    left: -2.6965%;
    width: 50.1397%;
    height: 80.8151%;
  }

  .home-dynamic__pattern-piece--b {
    top: -40.0371%;
    left: 46.6146%;
    width: 50.6163%;
    height: 80.8151%;
  }

  .home-dynamic__pattern-piece--c {
    top: 49.8029%;
    left: -2.6965%;
    width: 50.6163%;
    height: 80.8151%;
  }

  .home-dynamic__pattern-piece--d {
    top: 40.7785%;
    left: 61.5104%;
    width: 50.6163%;
    height: 80.8151%;
  }

  .home-dynamic__title {
    position: absolute;
    z-index: 2;
    top: 35.3704%;
    left: 36.875%;
    width: 26.6146%;
    height: 31.3889%;
    pointer-events: none;
    user-select: none;
  }

  .home-dynamic__dot {
    position: absolute;
    z-index: 3;
    width: 1.4583%;
    height: 2.5926%;
    transform: translate(-50%, -50%);
    border: max(1px, 0.0521cqw) solid #fd6500;
    border-radius: 50%;
    background: #f3eee1;
  }

  .home-dynamic__dot--archive {
    top: 64.6296%;
    left: 22.5%;
  }

  .home-dynamic__dot--exhibition {
    top: 82.6852%;
    left: 40%;
  }

  .home-dynamic__dot--memory {
    top: 22.7778%;
    left: 51.5104%;
  }

  .home-dynamic__dot--agenda {
    top: 55.5556%;
    left: 86.6667%;
  }

  .home-hover-states {
    z-index: 2;
    pointer-events: none;
  }

  .home-reference--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 120ms ease;
  }

  .home[data-hover-state='archive'] [data-hover-reference='archive'],
  .home[data-hover-state='exhibition'] [data-hover-reference='exhibition'],
  .home[data-hover-state='memory'] [data-hover-reference='memory'],
  .home[data-hover-state='agenda'] [data-hover-reference='agenda'] {
    opacity: 1;
  }

  .home-map {
    z-index: 3;
    pointer-events: none;
  }

  .home-trigger {
    position: absolute;
    width: max(6.875%, 44px);
    height: max(12.5%, 44px);
    padding: 0;
    transform: translate(-50%, -50%);
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: transparent;
    cursor: pointer;
    pointer-events: auto;
  }

  .home-trigger--archive {
    top: 64.6296%;
    left: 22.5%;
  }

  .home-trigger--exhibition {
    top: 82.6852%;
    left: 40%;
  }

  .home-trigger--memory {
    top: 22.7778%;
    left: 51.5104%;
  }

  .home-trigger--agenda {
    top: 55.5556%;
    left: 86.6667%;
  }

  .home-trigger:focus-visible,
  .panel-hotspot:focus-visible {
    outline: 2px solid #141414;
    outline-offset: 4px;
  }

  .home-panel {
    position: absolute;
    z-index: 10;
    inset: 0;
    overflow: hidden;
    background: #f3eee1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .home-panel[hidden] {
    display: none;
  }

  .home-panel.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .panel-hotspot {
    position: absolute;
    z-index: 2;
    display: block;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    border: 0;
    background: transparent;
    color: transparent;
    cursor: pointer;
  }

  .panel-hotspot--back {
    top: 9.2593%;
    left: 23.2292%;
    width: 2.1354%;
    height: 3.7963%;
    border-radius: 50%;
  }

  .panel-hotspot--archive-collection {
    top: 61.4438%;
    left: 36.9792%;
    width: 13.6979%;
    height: 4.2006%;
  }

  .panel-hotspot--archive-timeline {
    top: 61.4439%;
    left: 51.7188%;
    width: 11.7188%;
    height: 4.1706%;
  }

  .panel-hotspot--single-cta {
    top: 62.6851%;
    left: 43.1771%;
    width: 13.6979%;
    height: 4.1968%;
  }

  .panel-hotspot--memory-rebuild {
    top: 65.9259%;
    left: 14.0104%;
    width: 10.9375%;
    height: 4.1968%;
  }

  .panel-hotspot--memory-read {
    top: 40.7407%;
    left: 44.5313%;
    width: 10.9375%;
    height: 4.1968%;
  }

  .panel-hotspot--memory-dress {
    top: 65.9259%;
    left: 76.875%;
    width: 10.9375%;
    height: 4.1968%;
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
