<script>
  import { gsap } from '@lib/gsap';

  const intro = document.querySelector<HTMLElement>('[data-home-intro]');
  const introTitle = intro?.querySelector<HTMLElement>('[data-home-intro-title]');
  const hero = document.querySelector<HTMLElement>('[data-home-hero]');
  const heroTitle = hero?.querySelector<HTMLElement>('[data-home-hero-title]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (!reducedMotion.matches) {
    const homeContext = gsap.context(() => {
      if (intro && introTitle) {
        gsap
          .timeline({
            scrollTrigger: {
              trigger: intro,
              start: 'top top',
              end: 'bottom bottom',
              scrub: true,
            },
          })
          .fromTo(
            introTitle,
            { clipPath: 'inset(100% 0 0 0)', opacity: 0 },
            { clipPath: 'inset(0% 0 0 0)', opacity: 1, duration: 0.72, ease: 'none' }
          )
          .to(introTitle, { opacity: 1, duration: 0.12 })
          .to(introTitle, { opacity: 0, duration: 0.16, ease: 'none' });
      }

      if (hero && heroTitle) {
        gsap.fromTo(
          heroTitle,
          { autoAlpha: 0, y: '8svh' },
          {
            autoAlpha: 1,
            y: 0,
            ease: 'none',
            scrollTrigger: {
              trigger: hero,
              start: 'top 35%',
              end: 'top top',
              scrub: true,
            },
          }
        );
      }
    });

    document.addEventListener('astro:before-swap', () => homeContext.revert(), { once: true });
  }

  const portalElements = Array.from(document.querySelectorAll<HTMLElement>('[data-portal]'));

  function activatePortal(target: HTMLElement | null) {
    portalElements.forEach((portal) => {
      const active = portal === target;
      portal.classList.toggle('is-active', active);
      portal
        .querySelector<HTMLButtonElement>('[data-portal-toggle]')
        ?.setAttribute('aria-expanded', String(active));
      const body = portal.querySelector<HTMLElement>('.portal__body');
      body?.setAttribute('aria-hidden', String(!active));
      body?.toggleAttribute('inert', !active);
    });
  }

  portalElements.forEach((portal) => {
    portal
      .querySelector<HTMLButtonElement>('[data-portal-toggle]')
      ?.addEventListener('click', () =>
        activatePortal(portal.classList.contains('is-active') ? null : portal)
      );
  });
</script>
