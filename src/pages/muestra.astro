---
import MainLayout from '@layouts/MainLayout.astro';

const hotspots = [
  {
    id: 'sombrero',
    number: '01',
    label: 'Sombrero',
    title: 'Ala ancha',
    copy: 'Sombrero de rafia con ala redonda que enmarcaba la cabeza y devolvía la formalidad prohibida durante la guerra.',
    x: 50,
    y: 7,
    side: 'right',
  },
  {
    id: 'chaqueta',
    number: '02',
    label: 'Chaqueta',
    title: 'Shantung crudo',
    copy: 'Seda salvaje cruda, ceñida al torso. Ausencia total de hombreras militares —el gran quiebre respecto a los años de guerra.',
    x: 31,
    y: 26.4,
    side: 'left',
  },
  {
    id: 'cintura',
    number: '03',
    label: 'Cintura',
    title: 'Cinchada',
    copy: 'Ajuste extremo. Las clientas debían usar corselete debajo. Una cintura de 55 cm era el estándar.',
    x: 59.1,
    y: 41.6,
    side: 'right',
  },
  {
    id: 'caderas',
    number: '04',
    label: 'Caderas',
    title: 'Relleno',
    copy: 'Caderas redondeadas por un sistema de relleno interno, invisible desde afuera. La curvatura era artificial.',
    x: 31,
    y: 51.2,
    side: 'left',
  },
  {
    id: 'pollera',
    number: '05',
    label: 'Pollera',
    title: 'Corolla plisada',
    copy: 'Lana negra, plisada radialmente. Veinte metros de tela por vestido —un escándalo mientras Europa aún racionaba.',
    x: 59.1,
    y: 74.2,
    side: 'right',
  },
  {
    id: 'largo',
    number: '06',
    label: 'Largo',
    title: '78 centímetros',
    copy: 'Corte a media pantorrilla. Ni cortas ni largas: la nueva medida que ninguna moda había establecido antes.',
    x: 31,
    y: 96.2,
    side: 'left',
  },
];
---

<MainLayout
  immersive
  title="New Look — La revolución del cuerpo vestido"
  description="Una muestra digital sobre el New Look de Christian Dior, la silueta Bar y la década que transformó el cuerpo vestido."
>
  <section class="nl-intro-sequence" data-muestra-intro data-motion-owned>
    <div class="nl-intro">
      <div class="nl-intro__circle" data-muestra-circle aria-hidden="true"></div>
      <div class="nl-intro__cream" data-muestra-cream aria-hidden="true"></div>

      <div class="nl-intro__meta nl-intro__meta--left label" data-muestra-meta>
        <p>Curaduría</p>
        <p>María S. Camargo<br />Conservadora del acervo</p>
      </div>

      <div class="nl-intro__meta nl-intro__meta--right label" data-muestra-meta>
        <p>Piezas en exhibición</p>
        <p>90 modelos originales<br />5 salas · 135 días</p>
      </div>

      <div class="nl-intro__cover" data-muestra-cover-copy>
        <p class="nl-intro__eyebrow">La silueta de posguerra</p>
        <h1>New Look</h1>
        <p class="nl-intro__subtitle type-display-italic">y la revolución del cuerpo vestido</p>
        <p class="nl-intro__date">15 marzo · 28 julio · Salas del jardín bajo</p>
      </div>

      <blockquote class="nl-intro__quote" data-muestra-quote>
        <span class="nl-intro__quote-rule" data-muestra-quote-rule aria-hidden="true"></span>
        <p class="nl-intro__quote-lead type-display-italic">
          “It’s quite a revolution, dear Christian.<br />Your dresses have such a
        </p>
        <strong
          ><span class="nl-intro__quote-word"
            >New Look<span class="nl-intro__closing-quote" aria-hidden="true">”</span></span
          ></strong
        >
        <cite>— Carmel Snow · Harper’s Bazaar · 12 febrero 1947 —</cite>
      </blockquote>
    </div>
  </section>

  <section class="nl-curatorial" data-motion-owned>
    <p class="type-display-italic">
      <span>Christian Dior</span> presentó su primera colección el 12 de febrero de 1947.<br />
      La había bautizado "Corolle" —por la forma de las flores— y estaba<br class="desktop-only" />
      compuesta por vestidos de talle avispa, hombros suaves y faldas amplias<br
        class="desktop-only"
      />
      que devolvían al cuerpo femenino todo lo que la guerra le había<br class="desktop-only" />
      prohibido: telas, curvas, tiempo, ornamento. La colección duró apenas<br
        class="desktop-only"
      />
      dos horas en su nombre original. Al final del defilé, Carmel Snow le dijo a<br
        class="desktop-only"
      />
      Dior la frase que se volvería su epitafio: <span>"New Look".</span><br />
      Ese nombre, dicho al pasar, se quedó para siempre.
    </p>
  </section>

  <section class="nl-decade" data-decade-carousel data-motion-owned>
    <img
      class="nl-decade__vine nl-decade__vine--left"
      src="/images/muestra/decade-vine.png"
      alt=""
    />
    <img
      class="nl-decade__vine nl-decade__vine--right"
      src="/images/muestra/decade-vine.png"
      alt=""
    />
    <img
      class="nl-decade__flower nl-decade__flower--one"
      src="/images/muestra/decade-flower.png"
      alt=""
    />
    <img
      class="nl-decade__flower nl-decade__flower--two"
      src="/images/muestra/decade-flower-small.png"
      alt=""
    />

    <header class="nl-decade__header">
      <h2>Diez años, una casa.</h2>
      <p class="type-display-italic">
        El New Look no fue una colección: fue el punto de partida de una hegemonía absoluta de diez
        años.
      </p>
    </header>

    <div
      class="nl-decade__stage"
      tabindex="0"
      aria-label="Cronología New Look. Usá las flechas o desplazá horizontalmente."
      aria-live="polite"
      data-decade-stage
    >
      <div class="nl-decade__state is-active" data-decade-state="0" aria-hidden="false">
        <figure class="nl-decade__card nl-decade__card--main nl-decade__card--center">
          <img src="/images/muestra/figma-3760.png" alt="1947, presentación de la línea Corolle" />
        </figure>
        <figure class="nl-decade__card nl-decade__card--small nl-decade__card--right">
          <img src="/images/muestra/figma-3740.png" alt="1948, apertura de la boutique Dior" />
        </figure>
      </div>

      <div class="nl-decade__state" data-decade-state="1" aria-hidden="true">
        <figure class="nl-decade__card nl-decade__card--small nl-decade__card--left">
          <img src="/images/muestra/figma-4237.png" alt="1947, presentación de la línea Corolle" />
        </figure>
        <figure class="nl-decade__card nl-decade__card--main nl-decade__card--center">
          <img
            src="/images/muestra/figma-4257.png"
            alt="1948, la expansión internacional de Dior"
          />
        </figure>
        <figure class="nl-decade__card nl-decade__card--small nl-decade__card--right">
          <img src="/images/muestra/figma-4211.png" alt="1951, nueva silueta Dior" />
        </figure>
      </div>

      <div class="nl-decade__state" data-decade-state="2" aria-hidden="true">
        <figure class="nl-decade__card nl-decade__card--small nl-decade__card--left">
          <img src="/images/muestra/figma-4310.png" alt="1948, apertura de la boutique Dior" />
        </figure>
        <figure class="nl-decade__card nl-decade__card--main nl-decade__card--center">
          <img src="/images/muestra/figma-4287.png" alt="1951, nueva silueta Dior" />
        </figure>
        <a
          class="nl-decade__card nl-decade__card--small nl-decade__card--right nl-decade__timeline"
          href="/linea-de-tiempo"
        >
          <span>Recorré otras décadas</span>
          <img src="/images/muestra/figma-4330.png" alt="Línea de tiempo" />
        </a>
      </div>
    </div>

    <button
      class="nl-decade__arrow nl-decade__arrow--previous"
      type="button"
      data-decade-previous
      aria-label="Ver año anterior">←</button
    >
    <button
      class="nl-decade__arrow nl-decade__arrow--next"
      type="button"
      data-decade-next
      aria-label="Ver año siguiente">→</button
    >
  </section>

  <section class="nl-bar" data-bar-explorer data-motion-owned>
    <header class="nl-bar__header">
      <p class="label">La pieza ícono</p>
      <h2>Bar</h2>
      <p class="type-display-italic">El tailleur que redibujó el cuerpo.</p>
      <span class="label">Christian Dior · S/S 1947 · Colección "Corolle"</span>
    </header>

    <div class="nl-bar__stage">
      <img
        class="nl-bar__hat"
        src="/images/muestra/bar-hat.png"
        alt="Sombrero de rafia del conjunto Bar"
      />
      <img
        class="nl-bar__outfit"
        src="/images/muestra/bar-outfit.png"
        alt="Conjunto Bar de Christian Dior, 1947"
      />

      {
        hotspots.map((hotspot) => (
          <button
            class="nl-bar__hotspot"
            type="button"
            style={`--hx:${hotspot.x}%;--hy:${hotspot.y}%;`}
            data-hotspot={hotspot.id}
            aria-label={`${hotspot.number}. ${hotspot.label}: ${hotspot.title}`}
            aria-controls={`callout-${hotspot.id}`}
            aria-pressed="false"
          >
            <img src="/images/muestra/hotspot-flower.png" alt="" />
          </button>
        ))
      }

      {
        hotspots.map((hotspot) => (
          <article
            class:list={['nl-bar__callout', `nl-bar__callout--${hotspot.side}`]}
            id={`callout-${hotspot.id}`}
            style={`--hx:${hotspot.x}%;--hy:${hotspot.y}%;`}
            data-callout={hotspot.id}
            hidden
          >
            <span class="nl-bar__connector" aria-hidden="true" />
            <img class="nl-bar__callout-shape" src="/images/muestra/bar-callout.png" alt="" />
            <p class="nl-bar__callout-label label">
              {hotspot.number}/ {hotspot.label}
            </p>
            <h3>{hotspot.title}</h3>
            <p class="nl-bar__callout-copy type-display-italic">{hotspot.copy}</p>
          </article>
        ))
      }
    </div>

    <a class="nl-bar__cta" href="/coleccion/traje-bar">
      <img src="/images/muestra/bar-cta.png" alt="Ver ficha completa" />
    </a>
  </section>

  <section class="nl-quote" data-motion-owned>
    <img class="nl-quote__desktop" src="/images/muestra/quote-exact.png" alt="" />
    <p class="sr-only">
      “Concibo mi trabajo como una arquitectura efímera dedicada a la belleza del cuerpo femenino.”
      Christian Dior, declaración a la prensa, febrero de 1947.
    </p>
  </section>

  <section class="nl-close" data-motion-owned>
    <img class="nl-close__pattern" src="/images/muestra/close-pattern.png" alt="" />
    <p class="nl-close__kicker label">Explorar las pistas de la colección</p>
    <div class="nl-close__disc">
      <h2>New Look</h2>
      <p class="label">Selección colección Corolle · 1947 — 1957 · 42 piezas</p>
      <a href="/coleccion">
        <span class="label">Ver colección completa</span>
      </a>
    </div>
  </section>
</MainLayout>

<style>
  :global(body) {
    background: #141414;
  }

  .nl-intro-sequence {
    position: relative;
    height: 300svh;
    background: #141414;
  }

  .nl-intro {
    position: sticky;
    top: 0;
    height: 100svh;
    min-height: 42rem;
    overflow: hidden;
    isolation: isolate;
    background: #141414;
    color: #f3eee1;
  }

  .nl-intro__circle {
    --cream-stop: 23.08%;
    position: absolute;
    z-index: 1;
    top: 77.1%;
    left: 50%;
    width: 90.625vw;
    aspect-ratio: 1740 / 1763;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      #f3eee1 0,
      #f3eee1 var(--cream-stop),
      #141414 100%
    );
    transform: translateX(-50%);
    will-change: top, width;
    -webkit-mask-image: radial-gradient(ellipse closest-side at center, #000 72%, transparent 100%);
    mask-image: radial-gradient(ellipse closest-side at center, #000 72%, transparent 100%);
  }

  .nl-intro__cream {
    position: absolute;
    z-index: 2;
    inset: 0;
    background: #f3eee1;
    opacity: 0;
  }

  .nl-intro__meta {
    position: absolute;
    z-index: 6;
    top: 7.2%;
    max-width: 20rem;
    color: #f3eee1;
    font-size: clamp(0.625rem, 0.73vw, 0.875rem);
    line-height: 1.18;
  }

  .nl-intro__meta p + p {
    margin-top: 1.25rem;
  }

  .nl-intro__meta--left {
    left: 3.1%;
  }

  .nl-intro__meta--right {
    right: 3.1%;
    text-align: right;
  }

  .nl-intro__cover {
    position: absolute;
    z-index: 5;
    top: 27.1%;
    left: 50%;
    width: min(66rem, 72vw);
    transform: translateX(-50%);
    text-align: center;
  }

  .nl-intro__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #f3eee1;
    font-size: clamp(0.7rem, 0.94vw, 1.125rem);
    text-transform: uppercase;
  }

  .nl-intro__eyebrow::before,
  .nl-intro__eyebrow::after {
    content: '';
    flex: 1;
    border-top: 1px solid rgba(243, 238, 225, 0.82);
  }

  .nl-intro__cover h1,
  .nl-intro__quote strong {
    display: block;
    color: #fd6500;
    font-family: var(--font-display);
    font-size: clamp(6.4rem, 10.42vw, 12.5rem);
    font-weight: 400;
    line-height: 0.91;
    letter-spacing: -0.055em;
    text-transform: uppercase;
  }

  .nl-intro__quote strong {
    position: relative;
  }

  .nl-intro__quote-word {
    position: relative;
    display: inline-block;
  }

  .nl-intro__closing-quote {
    position: absolute;
    top: -0.1em;
    left: 100%;
    margin-left: 0.06em;
    color: #141414;
    font-size: 0.28em;
    letter-spacing: 0;
  }

  .nl-intro__cover h1 {
    margin-top: clamp(2.2rem, 3.4vw, 4.1rem);
  }

  .nl-intro__subtitle {
    margin-top: clamp(1rem, 1.65vw, 2rem);
    color: #f3eee1;
    font-size: clamp(2.1rem, 3.33vw, 4rem);
    line-height: 1;
  }

  .nl-intro__date {
    width: 86%;
    margin: clamp(2.4rem, 3.6vw, 4.3rem) auto 0;
    padding-top: clamp(2rem, 2.6vw, 3.1rem);
    border-top: 1px solid rgba(243, 238, 225, 0.82);
    font-size: clamp(0.7rem, 0.94vw, 1.125rem);
    text-transform: uppercase;
  }

  .nl-intro__quote {
    position: absolute;
    z-index: 5;
    top: 31%;
    left: 50%;
    width: min(66rem, 74vw);
    margin: 0;
    color: #141414;
    text-align: center;
    transform: translateX(-50%);
    opacity: 0;
  }

  .nl-intro__quote-lead {
    font-size: clamp(2.1rem, 3.33vw, 4rem);
    line-height: 1.08;
  }

  .nl-intro__quote-rule {
    position: absolute;
    top: -1.65rem;
    left: 15%;
    width: 70%;
    border-top: 1px dotted rgba(20, 20, 20, 0.45);
    opacity: 0;
  }

  .nl-intro__quote strong {
    margin-top: 0.35rem;
  }

  .nl-intro__quote cite {
    display: block;
    margin-top: clamp(1.4rem, 2.6vw, 3.1rem);
    color: #520345;
    font-family: var(--font-body);
    font-size: clamp(0.625rem, 0.73vw, 0.875rem);
    font-style: normal;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .nl-curatorial {
    min-height: 100svh;
    display: grid;
    place-items: start center;
    padding: clamp(2rem, 4.5vh, 3.1rem) 3vw 4rem;
    background: linear-gradient(to bottom, #f3eee1 0%, #f3eee1 45%, #b9d6fe 100%);
    color: #141414;
    text-align: center;
  }

  .nl-curatorial p {
    /* Figma spec: 64px / 96px line height on the 1920px-wide 16:9 canvas. */
    max-width: min(98cqw, 118rem);
    font-size: clamp(2.25rem, 3.333cqw, 4rem);
    line-height: 1.5;
  }

  .nl-curatorial span {
    color: #fd6500;
  }

  .nl-decade {
    position: relative;
    height: clamp(48rem, 62.5vw, 75rem);
    overflow: hidden;
    isolation: isolate;
    background: #b9d6fe;
    color: #141414;
  }

  .nl-decade__header {
    position: relative;
    z-index: 4;
  }

  .nl-decade__header h2 {
    position: absolute;
    top: 2.2vw;
    left: 2vw;
    font-size: clamp(5rem, 6.2vw, 7.45rem);
    line-height: 0.98;
  }

  .nl-decade__header p {
    position: absolute;
    top: 7.35vw;
    right: 1.4vw;
    width: 35%;
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.67vw, 2rem);
    line-height: 1.08;
  }

  .nl-decade__vine,
  .nl-decade__flower {
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .nl-decade__vine {
    top: 24.7%;
    left: 0;
    width: 30.1%;
  }

  .nl-decade__vine--right {
    right: 0;
    left: auto;
    transform: scaleX(-1);
  }

  .nl-decade__flower--one {
    left: 23.3%;
    top: 43.5%;
    width: 11.6%;
  }

  .nl-decade__flower--two {
    right: 15.9%;
    top: 26.8%;
    width: 7.9%;
  }

  .nl-decade__stage,
  .nl-decade__state {
    position: absolute;
    inset: 0;
  }

  .nl-decade__stage:focus-visible {
    outline: 2px solid #fd6500;
    outline-offset: -0.35rem;
  }

  .nl-decade__state {
    z-index: 2;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.55s ease;
  }

  .nl-decade__state.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .nl-decade__card {
    position: absolute;
    z-index: 2;
    margin: 0;
    transition: transform 0.55s var(--ease-expo);
  }

  .nl-decade__card img {
    width: 100%;
    height: auto;
  }

  .nl-decade__card--main {
    top: 29%;
    width: 29.3%;
  }

  .nl-decade__card--small {
    top: 35.5%;
    width: 22.66%;
  }

  .nl-decade__card--left {
    left: 3.44%;
  }

  .nl-decade__card--center {
    left: 35.36%;
  }

  .nl-decade__card--right {
    right: 3.12%;
  }

  .nl-decade__timeline {
    color: #b9d6fe;
    text-align: center;
  }

  .nl-decade__timeline span {
    position: absolute;
    z-index: 2;
    top: 38%;
    left: 50%;
    width: 100%;
    transform: translateX(-50%);
    font-size: clamp(1rem, 1.45vw, 1.75rem);
    font-style: italic;
  }

  .nl-decade__arrow {
    position: absolute;
    z-index: 6;
    bottom: 6.9%;
    width: 2.14rem;
    height: 2.14rem;
    display: grid;
    place-items: center;
    padding: 0;
    border: 1px solid #141414;
    border-radius: 50%;
    background: transparent;
    color: #141414;
    cursor: pointer;
  }

  .nl-decade__arrow--previous {
    left: 3.12%;
  }

  .nl-decade__arrow--next {
    right: 3.12%;
  }

  .nl-decade__arrow:disabled {
    visibility: hidden;
  }

  .nl-bar {
    position: relative;
    height: clamp(101rem, 128.18vw, 153.82rem);
    overflow: hidden;
    background: #141414;
    color: #f3eee1;
  }

  .nl-bar__header {
    position: absolute;
    z-index: 2;
    top: 6.9%;
    left: 50%;
    width: min(60rem, 72vw);
    text-align: center;
    transform: translateX(-50%);
  }

  .nl-bar__header > .label:first-child {
    position: absolute;
    top: 1.7rem;
    left: 50%;
    color: #b9d6fe;
    transform: translateX(-50%);
  }

  .nl-bar__header h2 {
    color: #fd6500;
    font-size: clamp(8rem, 10.42vw, 12.5rem);
    line-height: 1;
  }

  .nl-bar__header > p:nth-of-type(2) {
    margin-top: 0.5rem;
    font-size: clamp(2.5rem, 3.33vw, 4rem);
    line-height: 1;
  }

  .nl-bar__header > span {
    display: block;
    margin-top: clamp(1.6rem, 2.1vw, 2.5rem);
  }

  .nl-bar__stage {
    position: absolute;
    z-index: 2;
    top: 30.07%;
    left: 50%;
    width: min(34.32vw, 41.2rem);
    aspect-ratio: 659 / 1310;
    transform: translateX(-50%);
  }

  .nl-bar__hat,
  .nl-bar__outfit {
    position: absolute;
  }

  .nl-bar__hat {
    top: 0;
    left: 14.1%;
    width: 67.07%;
  }

  .nl-bar__outfit {
    top: 15.8%;
    left: 0;
    width: 100%;
  }

  .nl-bar__hotspot {
    position: absolute;
    z-index: 5;
    top: var(--hy);
    left: var(--hx);
    width: clamp(1.25rem, 1.3vw, 1.56rem);
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    transform: translate(-50%, -50%);
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .nl-bar__hotspot img {
    width: 100%;
  }

  .nl-bar__hotspot:hover,
  .nl-bar__hotspot.is-active {
    filter: drop-shadow(0 0 0.7rem rgba(185, 214, 254, 0.85));
    transform: translate(-50%, -50%) scale(1.32);
  }

  .nl-bar__callout {
    position: absolute;
    z-index: 4;
    top: var(--hy);
    width: 66.16%;
    aspect-ratio: 436 / 493;
    color: #141414;
    text-align: center;
