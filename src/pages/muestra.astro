<script>
  const hotspotButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-hotspot]'));
  const callouts = Array.from(document.querySelectorAll<HTMLElement>('[data-callout]'));

  function activateHotspot(id: string) {
    const selectedButton = hotspotButtons.find((button) => button.dataset.hotspot === id);
    const shouldOpen = selectedButton?.getAttribute('aria-pressed') !== 'true';

    hotspotButtons.forEach((button) => {
      const active = shouldOpen && button.dataset.hotspot === id;
      button.classList.toggle('is-active', active);
      button.setAttribute('aria-pressed', String(active));
    });

    callouts.forEach((callout) => {
      const active = shouldOpen && callout.dataset.callout === id;
      callout.hidden = !active;
    });
  }

  hotspotButtons.forEach((button) => {
    button.addEventListener('click', () => activateHotspot(button.dataset.hotspot ?? ''));
  });

  const decadeStates = Array.from(document.querySelectorAll<HTMLElement>('[data-decade-state]'));
  const previousButton = document.querySelector<HTMLButtonElement>('[data-decade-previous]');
  const nextButton = document.querySelector<HTMLButtonElement>('[data-decade-next]');
  const decadeStage = document.querySelector<HTMLElement>('[data-decade-stage]');
  let decadeIndex = 0;

  function renderDecade() {
    decadeStates.forEach((state, index) => {
      const active = index === decadeIndex;
      state.classList.toggle('is-active', active);
      state.setAttribute('aria-hidden', String(!active));
      state.toggleAttribute('inert', !active);
    });

    if (previousButton) previousButton.disabled = decadeIndex === 0;
    if (nextButton) {
      nextButton.setAttribute(
        'aria-label',
        decadeIndex === decadeStates.length - 1 ? 'Abrir la línea de tiempo' : 'Ver año siguiente'
      );
    }
  }

  previousButton?.addEventListener('click', () => {
    decadeIndex = Math.max(0, decadeIndex - 1);
    renderDecade();
  });

  nextButton?.addEventListener('click', () => {
    if (decadeIndex === decadeStates.length - 1) {
      window.location.assign('/linea-de-tiempo');
      return;
    }

    decadeIndex += 1;
    renderDecade();
  });

  decadeStage?.addEventListener('keydown', (event) => {
    if (event.key === 'ArrowLeft') {
      event.preventDefault();
      decadeIndex = Math.max(0, decadeIndex - 1);
      renderDecade();
    }

    if (event.key === 'ArrowRight') {
      event.preventDefault();
      if (decadeIndex === decadeStates.length - 1) {
        window.location.assign('/linea-de-tiempo');
        return;
      }
      decadeIndex += 1;
      renderDecade();
    }
  });

  decadeStage?.addEventListener(
    'wheel',
    (event) => {
      if (Math.abs(event.deltaX) < Math.abs(event.deltaY) || Math.abs(event.deltaX) < 16) return;
      event.preventDefault();
      decadeIndex = Math.min(
        decadeStates.length - 1,
        Math.max(0, decadeIndex + (event.deltaX > 0 ? 1 : -1))
      );
      renderDecade();
    },
    { passive: false }
  );

  renderDecade();
</script>
