<script>
  const hotspotButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-hotspot]'));
  const callouts = Array.from(document.querySelectorAll<HTMLElement>('[data-callout]'));

  function activateHotspot(id: string) {
    const selectedButton = hotspotButtons.find((button) => button.dataset.hotspot === id);
    const shouldOpen = selectedButton?.getAttribute('aria-pressed') !== 'true';

    hotspotButtons.forEach((button) => {
      const active = shouldOpen && button.dataset.hotspot === id;
      button.classList.toggle('is-active', active);
      button.setAttribute('aria-pressed', String(active));
    });

    callouts.forEach((callout) => {
      const active = shouldOpen && callout.dataset.callout === id;
      callout.hidden = !active;
    });
  }

  hotspotButtons.forEach((button) => {
    button.addEventListener('click', () => activateHotspot(button.dataset.hotspot ?? ''));
  });

  const decadeScroller = document.querySelector<HTMLElement>('[data-decade-scroller]');
  const previousButton = document.querySelector<HTMLButtonElement>('[data-decade-previous]');
  const nextButton = document.querySelector<HTMLButtonElement>('[data-decade-next]');

  // One card pitch, matching the constant spacing between the `left` values above.
  const DECADE_CARD_PITCH = 0.09375;
  const prefersInstantScroll = window.matchMedia('(prefers-reduced-motion: reduce)');
  let decadeFrame = 0;
  let decadeTarget: number | null = null;

  // Native smooth scrolling clashes with the Lenis RAF loop, so ease manually.
  function glideDecadeTo(target: number) {
    if (!decadeScroller) return;
    const from = decadeScroller.scrollLeft;
    const startedAt = performance.now();
    const duration = 650;

    window.cancelAnimationFrame(decadeFrame);
    const tick = (now: number) => {
      if (!decadeScroller) return;
      const progress = Math.min(1, (now - startedAt) / duration);
      const eased = 1 - Math.pow(1 - progress, 3);
      decadeScroller.scrollLeft = from + (target - from) * eased;
      if (progress < 1) {
        decadeFrame = window.requestAnimationFrame(tick);
      } else {
        decadeTarget = null;
      }
    };
    decadeFrame = window.requestAnimationFrame(tick);
  }

  function stepDecade(direction: 1 | -1) {
    if (!decadeScroller) return;
    const maxScroll = decadeScroller.scrollWidth - decadeScroller.clientWidth;
    const pitch = decadeScroller.scrollWidth * DECADE_CARD_PITCH;
    const from = decadeTarget ?? decadeScroller.scrollLeft;
    decadeTarget = Math.min(maxScroll, Math.max(0, from + direction * pitch));

    if (prefersInstantScroll.matches) {
      decadeScroller.scrollLeft = decadeTarget;
      decadeTarget = null;
      return;
    }

    glideDecadeTo(decadeTarget);
  }

  function syncDecadeArrows() {
    if (!decadeScroller) return;
    const maxScroll = decadeScroller.scrollWidth - decadeScroller.clientWidth;
    if (previousButton) previousButton.disabled = decadeScroller.scrollLeft <= 4;
    if (nextButton) nextButton.disabled = decadeScroller.scrollLeft >= maxScroll - 4;
  }

  previousButton?.addEventListener('click', () => stepDecade(-1));
  nextButton?.addEventListener('click', () => stepDecade(1));
  decadeScroller?.addEventListener('scroll', syncDecadeArrows, { passive: true });

  decadeScroller?.addEventListener(
    'wheel',
    (event) => {
      if (Math.abs(event.deltaX) <= Math.abs(event.deltaY)) return;
      event.preventDefault();
      decadeScroller.scrollLeft += event.deltaX;
    },
    { passive: false }
  );

  syncDecadeArrows();

  // Whichever card overlaps the scroller's center band becomes `.is-center`
  // and scales up via CSS — always three cards on screen, the middle one big.
  const decadeCardEls = Array.from(document.querySelectorAll<HTMLElement>('[data-decade-card]'));

  if (decadeScroller && decadeCardEls.length > 0) {
    const centerObserver = new IntersectionObserver(
      (entries) => {
        let winner: { element: HTMLElement; ratio: number } | null = null;

        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          if (!winner || entry.intersectionRatio > winner.ratio) {
            winner = { element: entry.target as HTMLElement, ratio: entry.intersectionRatio };
          }
        });

        if (winner) {
          decadeCardEls.forEach((card) =>
            card.classList.toggle('is-center', card === winner!.element)
          );
        }
      },
      {
        root: decadeScroller,
        rootMargin: '0px -35% 0px -35%',
        threshold: [0.25, 0.5, 0.75, 1],
      }
    );

    decadeCardEls.forEach((card) => centerObserver.observe(card));
  }
</script>
