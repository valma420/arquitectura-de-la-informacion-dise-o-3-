---
import MainLayout from '@layouts/MainLayout.astro';

const decadeAssets = '/images/muestra/decade';

/**
 * Cards of the "Diez años, una casa" strip (Figma node 202:3956).
 * All cards share one size; whichever sits at the scroller's center is
 * scaled up 1.294x at runtime (see the script below), reproducing the
 * enlarged "lead" card from Figma for whichever year is centered.
 */
const decadeCards = [
  {
    year: '1947',
    title: 'Colección Corolle',
    copy: 'Christian Dior presenta su primera colección en el salón del 30 Avenue Montaigne. Carmel Snow la bautiza "New Look". Ese mismo año, la casa lanza Miss Dior, primer perfume de la marca.',
    image: `${decadeAssets}/photo-1947.jpg`,
    alt: '1947, el tailleur Bar sobre maniquí',
    left: '13.785%',
  },
  {
    year: '1948',
    title: 'La expansión',
    copy: 'Dior abre boutique en la Quinta Avenida. Es la primera casa de couture parisina con presencia formal en Estados Unidos. La ropa francesa se vuelve, otra vez, el estándar mundial.',
    image: `${decadeAssets}/photo-1948.jpg`,
    alt: '1948, Christian Dior en la puerta de su boutique',
    left: '23.16%',
  },
  {
    year: '1951',
    title: 'Línea Oval',
    copy: 'Dior presenta la primera línea con nombre — la "Ligne Ovale". Instala una lógica que definirá el resto de su carrera: cada temporada, una silueta con nombre propio.',
    image: `${decadeAssets}/photo-1951.png`,
    alt: '1951, modelo con sombrero de ala ancha de la línea Oval',
    left: '32.535%',
  },
  {
    year: '1953',
    title: 'Línea Tulipe',
    copy: 'La línea Tulipe abre el busto como una flor invertida. La casa ya concentra más de la mitad de las exportaciones de la alta costura francesa.',
    image: `${decadeAssets}/photo-1953.jpg`,
    alt: '1953, Grace Kelly en el festival de Cannes',
    left: '41.91%',
  },
  {
    year: '1954',
    title: 'El regreso de Chanel',
    copy: 'Chanel reabre su casa y desafía el reinado del New Look. Dior responde con la Línea H: talle alargado y líneas planas.',
    image: `${decadeAssets}/photo-1954.jpg`,
    alt: '1954, recorte de prensa sobre el regreso de Chanel',
    left: '51.285%',
  },
  {
    year: '1955',
    title: 'Un asistente de 19 años',
    copy: 'Dior dicta su célebre conferencia en la Sorbona y suma un asistente de 19 años: Yves Saint Laurent. Nacen las líneas A e Y.',
    image: `${decadeAssets}/photo-1955.jpg`,
    alt: '1955, Yves Saint Laurent presentando bocetos en el taller',
    left: '60.66%',
  },
  {
    year: '1956',
    title: 'Línea Flecha',
    copy: 'La casa presenta las líneas Flèche y Aimant. Más de mil empleados y la mitad de las exportaciones de costura de Francia llevan su firma.',
    image: `${decadeAssets}/photo-1956.jpg`,
    alt: '1956, vestido estampado de la línea Flèche',
    left: '70.035%',
  },
  {
    year: '1957',
    title: 'El final del reinado',
    copy: 'Dior muere en Montecatini a los 52 años, meses después de su portada en Time. Yves Saint Laurent hereda la dirección creativa de la casa.',
    image: `${decadeAssets}/photo-1957.jpg`,
    alt: '1957, Christian Dior retratado en su último año',
    left: '79.41%',
  },
];

/**
 * Floral outline decorations for the "Diez años, una casa" backdrop.
 * Insets below are authored relative to the full 5990px-wide Figma strip
 * (matching `.nl-decade__track`'s 311.98cqw width). Since the flowers now
 * sit in a fixed, non-scrolling layer sized to the visible 16:9 canvas
 * (100cqw), their left/right insets are rescaled by DECADE_TRACK_SCALE so
 * the initial composition keeps its authored proportions; entries that
 * land off-canvas are dropped.
 */
const DECADE_TRACK_SCALE = 311.98 / 100;

/**
 * Rescales a track-relative inset box to the canvas-relative coordinate
 * space. `left` is a straight position rescale, but `right` is a distance
 * from the (now differently-sized) right edge, so it needs the edge-position
 * correction below rather than a plain multiply.
 */
function toFixedVineInset(inset: string): string {
  const [top, right, bottom, left] = inset.split(' ').map((value) => parseFloat(value));
  const fixedLeft = left * DECADE_TRACK_SCALE;
  const fixedRight = right * DECADE_TRACK_SCALE - 100 * (DECADE_TRACK_SCALE - 1);
  return `${top}% ${fixedRight}% ${bottom}% ${fixedLeft}%`;
}

const decadeVines = [
  { image: 'vine-1', inset: '4.17% 0.06% -13% 91.89%', flip: 'x' },
  { image: 'vine-2', inset: '-0.39% 11.93% 82.22% 84.97%', flip: 'y' },
  { image: 'vine-3', inset: '52.44% 12.95% 35.14% 84.93%', flip: 'r' },
  { image: 'vine-4', inset: '18.06% 8.11% 69.53% 89.76%' },
  { image: 'vine-2', inset: '12.53% 14.27% 69.31% 82.63%', flip: 'y' },
  { image: 'vine-5', inset: '25.28% 90.36% -34.11% 0.02%' },
  { image: 'vine-6', inset: '25.31% 61.91% -34.15% 28.46%', flip: 'x' },
  { image: 'vine-6', inset: '-14.63% 42.69% 5.8% 47.68%', flip: 'r' },
  { image: 'vine-5', inset: '16.57% 29.08% -25.41% 61.29%' },
  { image: 'vine-7', inset: '44.15% 88.51% 37.69% 7.79%' },
  { image: 'vine-7', inset: '30.59% 9.26% 51.24% 87.04%', flip: 'y' },
  { image: 'vine-7', inset: '74.48% 74.04% 7.35% 22.26%' },
  { image: 'vine-7', inset: '26.87% 54.82% 54.96% 41.47%', flip: 'y' },
  { image: 'vine-8', inset: '65.74% 22.87% 16.09% 73.42%', flip: 'x' },
  { image: 'vine-9', inset: '27.4% 75.26% 60.19% 22.21%', flip: 'x' },
  { image: 'vine-9', inset: '79.7% 56.04% 7.88% 41.42%', flip: 'r' },
  { image: 'vine-10', inset: '18.66% 22.82% 68.93% 74.64%' },
  { image: 'vine-10', inset: '10.09% 62.71% 77.49% 34.75%' },
  { image: 'vine-10', inset: '18.7% 4.14% 68.88% 93.33%' },
  { image: 'vine-10', inset: '83.89% 18.69% 3.69% 78.78%' },
  { image: 'vine-10', inset: '1.3% 50.2% 86.29% 47.26%' },
  { image: 'vine-10', inset: '83.94% 0% 3.65% 97.46%' },
  { image: 'vine-7', inset: '61.56% 76.84% 20.27% 19.45%' },
  { image: 'vine-7', inset: '39.79% 57.62% 42.05% 38.67%', flip: 'y' },
  { image: 'vine-8', inset: '52.82% 20.07% 29.01% 76.23%', flip: 'x' },
  { image: 'vine-8', inset: '16.48% 58.53% 65.35% 37.77%', flip: 'x' },
  { image: 'vine-8', inset: '52.87% 1.38% 28.96% 94.91%', flip: 'x' },
]
  .map((vine) => ({ ...vine, fixedInset: toFixedVineInset(vine.inset) }))
  .filter((vine) => {
    const [, right, , left] = vine.fixedInset.split(' ').map((value) => parseFloat(value));
    return left < 100 && right < 100;
  });

const hotspots = [
  {
    id: 'sombrero',
    number: '01',
    label: 'Sombrero',
    title: 'Ala ancha',
    copy: 'Sombrero de rafia con ala redonda que enmarcaba la cabeza y devolvía la formalidad prohibida durante la guerra.',
    x: 50,
    y: 7,
    side: 'right',
  },
  {
    id: 'chaqueta',
    number: '02',
    label: 'Chaqueta',
    title: 'Shantung crudo',
    copy: 'Seda salvaje cruda, ceñida al torso. Ausencia total de hombreras militares —el gran quiebre respecto a los años de guerra.',
    x: 31,
    y: 26.4,
    side: 'left',
  },
  {
    id: 'cintura',
    number: '03',
    label: 'Cintura',
    title: 'Cinchada',
    copy: 'Ajuste extremo. Las clientas debían usar corselete debajo. Una cintura de 55 cm era el estándar.',
    x: 59.1,
    y: 41.6,
    side: 'right',
  },
  {
    id: 'caderas',
    number: '04',
    label: 'Caderas',
    title: 'Relleno',
    copy: 'Caderas redondeadas por un sistema de relleno interno, invisible desde afuera. La curvatura era artificial.',
    x: 31,
    y: 51.2,
    side: 'left',
  },
  {
    id: 'pollera',
    number: '05',
    label: 'Pollera',
    title: 'Corolla plisada',
    copy: 'Lana negra, plisada radialmente. Veinte metros de tela por vestido —un escándalo mientras Europa aún racionaba.',
    x: 59.1,
    y: 74.2,
    side: 'right',
  },
  {
    id: 'largo',
    number: '06',
    label: 'Largo',
    title: '78 centímetros',
    copy: 'Corte a media pantorrilla. Ni cortas ni largas: la nueva medida que ninguna moda había establecido antes.',
    x: 31,
    y: 96.2,
    side: 'left',
  },
];
---

<MainLayout
  immersive
  title="New Look — La revolución del cuerpo vestido"
  description="Una muestra digital sobre el New Look de Christian Dior, la silueta Bar y la década que transformó el cuerpo vestido."
>
  <section class="nl-intro-sequence" data-muestra-intro data-motion-owned>
    <div class="nl-intro">
      <div class="nl-intro__circle" data-muestra-circle aria-hidden="true"></div>
      <div class="nl-intro__cream" data-muestra-cream aria-hidden="true"></div>

      <div class="nl-intro__meta nl-intro__meta--left label" data-muestra-meta>
        <p>Curaduría</p>
        <p>María S. Camargo<br />Conservadora del acervo</p>
      </div>

      <div class="nl-intro__meta nl-intro__meta--right label" data-muestra-meta>
        <p>Piezas en exhibición</p>
        <p>90 modelos originales<br />5 salas · 135 días</p>
      </div>

      <div class="nl-intro__cover" data-muestra-cover-copy>
        <p class="nl-intro__eyebrow">La silueta de posguerra</p>
        <h1>New Look</h1>
        <p class="nl-intro__subtitle type-display-italic">y la revolución del cuerpo vestido</p>
        <p class="nl-intro__date">15 marzo · 28 julio · Salas del jardín bajo</p>
      </div>

      <blockquote class="nl-intro__quote" data-muestra-quote>
        <span class="nl-intro__quote-rule" data-muestra-quote-rule aria-hidden="true"></span>
        <p class="nl-intro__quote-lead type-display-italic">
          “It’s quite a revolution, dear Christian.<br />Your dresses have such a
        </p>
        <strong
          ><span class="nl-intro__quote-word"
            >New Look<span class="nl-intro__closing-quote" aria-hidden="true">”</span></span
          ></strong
        >
        <cite>— Carmel Snow · Harper’s Bazaar · 12 febrero 1947 —</cite>
      </blockquote>
    </div>
  </section>

  <section class="nl-curatorial" data-motion-owned>
    <p class="type-display-italic">
      <span>Christian Dior</span> presentó su primera colección el 12 de febrero de 1947.<br />
      La había bautizado "Corolle" —por la forma de las flores— y estaba<br class="desktop-only" />
      compuesta por vestidos de talle avispa, hombros suaves y faldas amplias<br
        class="desktop-only"
      />
      que devolvían al cuerpo femenino todo lo que la guerra le había<br class="desktop-only" />
      prohibido: telas, curvas, tiempo, ornamento. La colección duró apenas<br
        class="desktop-only"
      />
      dos horas en su nombre original. Al final del defilé, Carmel Snow le dijo a<br
        class="desktop-only"
      />
      Dior la frase que se volvería su epitafio: <span>"New Look".</span><br />
      Ese nombre, dicho al pasar, se quedó para siempre.
    </p>
  </section>

  <section class="nl-decade" data-decade-carousel data-motion-owned>
    <div class="nl-decade__backdrop" aria-hidden="true">
      {
        decadeVines.map((vine) => (
          <div
            class:list={['nl-decade__vine', vine.flip && `nl-decade__vine--${vine.flip}`]}
            style={`inset:${vine.fixedInset};`}
          >
            <img src={`${decadeAssets}/${vine.image}.svg`} alt="" />
          </div>
        ))
      }
    </div>

    <div class="nl-decade__heading">
      <h2 class="nl-decade__title">Diez años, una casa</h2>
      <p class="nl-decade__subtitle">
        El New Look no fue una colección: fue el punto de partida de una hegemonía absoluta de diez
        años.
      </p>
    </div>

    <div
      class="nl-decade__scroller"
      tabindex="0"
      aria-label="Cronología 1947 a 1957. Usá las flechas para desplazarte horizontalmente."
      data-decade-scroller
    >
      <div class="nl-decade__track">
        {
          decadeCards.map((card) => (
            <article
              class="nl-decade__card"
              style={`left:${card.left};`}
              tabindex="0"
              data-decade-card
            >
              <img class="nl-decade__card-back" src={`${decadeAssets}/card-back.svg`} alt="" />
              <div class="nl-decade__card-window">
                <img class="nl-decade__card-photo" src={card.image} alt={card.alt} />
              </div>
              <div class="nl-decade__card-info">
                <span class="nl-decade__info-year" aria-hidden="true">
                  {card.year}
                </span>
                <h3 class="nl-decade__info-title">{card.title}</h3>
                <p class="nl-decade__info-copy">{card.copy}</p>
                <img
                  class="nl-decade__info-icon"
                  src={`${decadeAssets}/card-icon-dark.svg`}
                  alt=""
                />
              </div>
              <img
                class="nl-decade__card-outline"
                src={`${decadeAssets}/card-outline.svg`}
                alt=""
              />
              <span class="nl-decade__card-year">{card.year}</span>
              <img class="nl-decade__card-icon" src={`${decadeAssets}/card-icon.svg`} alt="" />
            </article>
          ))
        }

        <a
          class="nl-decade__card nl-decade__card--timeline"
          href="/linea-de-tiempo"
          data-decade-card
        >
          <img class="nl-decade__card-back" src={`${decadeAssets}/card-back-timeline.svg`} alt="" />
          <img
            class="nl-decade__card-outline"
            src={`${decadeAssets}/card-outline-timeline.svg`}
            alt=""
          />
          <span class="nl-decade__timeline-pill">
            <span class="nl-decade__timeline-label">Línea de tiempo</span>
          </span>
        </a>
      </div>
    </div>

    <button
      class="nl-decade__arrow nl-decade__arrow--previous"
      type="button"
      data-decade-previous
      aria-label="Ver años anteriores"
    >
      <img src={`${decadeAssets}/arrow-prev.svg`} alt="" />
    </button>
    <button
      class="nl-decade__arrow nl-decade__arrow--next"
      type="button"
      data-decade-next
      aria-label="Ver años siguientes"
    >
      <img src={`${decadeAssets}/arrow-next.svg`} alt="" />
    </button>
  </section>

  <section class="nl-bar" data-bar-explorer data-motion-owned>
    <header class="nl-bar__header">
      <p class="label">La pieza ícono</p>
      <h2>Bar</h2>
      <p class="type-display-italic">El tailleur que redibujó el cuerpo.</p>
      <span class="label">Christian Dior · S/S 1947 · Colección "Corolle"</span>
    </header>

    <div class="nl-bar__stage">
      <img
        class="nl-bar__hat"
        src="/images/muestra/bar-hat.png"
        alt="Sombrero de rafia del conjunto Bar"
      />
      <img
        class="nl-bar__outfit"
        src="/images/muestra/bar-outfit.png"
        alt="Conjunto Bar de Christian Dior, 1947"
      />

      {
        hotspots.map((hotspot) => (
          <button
            class="nl-bar__hotspot"
            type="button"
            style={`--hx:${hotspot.x}%;--hy:${hotspot.y}%;`}
            data-hotspot={hotspot.id}
            aria-label={`${hotspot.number}. ${hotspot.label}: ${hotspot.title}`}
            aria-controls={`callout-${hotspot.id}`}
            aria-pressed="false"
          >
            <img src="/images/muestra/hotspot-flower.png" alt="" />
          </button>
        ))
      }

      {
        hotspots.map((hotspot) => (
          <article
            class:list={['nl-bar__callout', `nl-bar__callout--${hotspot.side}`]}
            id={`callout-${hotspot.id}`}
            style={`--hx:${hotspot.x}%;--hy:${hotspot.y}%;`}
            data-callout={hotspot.id}
            hidden
          >
            <span class="nl-bar__connector" aria-hidden="true" />
            <img class="nl-bar__callout-shape" src="/images/muestra/bar-callout.png" alt="" />
            <p class="nl-bar__callout-label label">
              {hotspot.number}/ {hotspot.label}
            </p>
            <h3>{hotspot.title}</h3>
            <p class="nl-bar__callout-copy type-display-italic">{hotspot.copy}</p>
          </article>
        ))
      }
    </div>

    <a class="nl-bar__cta" href="/coleccion/traje-bar">
      <img src="/images/muestra/bar-cta.png" alt="Ver ficha completa" />
    </a>
  </section>

  <section class="nl-quote" data-motion-owned>
    <img class="nl-quote__desktop" src="/images/muestra/quote-exact.png" alt="" />
    <p class="sr-only">
      “Concibo mi trabajo como una arquitectura efímera dedicada a la belleza del cuerpo femenino.”
      Christian Dior, declaración a la prensa, febrero de 1947.
    </p>
  </section>

  <section class="nl-close" data-motion-owned>
    <img class="nl-close__pattern" src="/images/muestra/close-pattern.png" alt="" />
    <p class="nl-close__kicker label">Explorar las pistas de la colección</p>
    <div class="nl-close__disc">
      <h2>New Look</h2>
      <p class="label">Selección colección Corolle · 1947 — 1957 · 42 piezas</p>
      <a href="/coleccion">
        <span class="label">Ver colección completa</span>
      </a>
    </div>
  </section>
</MainLayout>

<style>
  :global(body) {
    background: #141414;
  }

  .nl-intro-sequence {
    position: relative;
    height: 300svh;
    background: #141414;
  }

  .nl-intro {
    position: sticky;
    top: 0;
    height: 100svh;
    min-height: 42rem;
    overflow: hidden;
    isolation: isolate;
    background: #141414;
    color: #f3eee1;
  }

  .nl-intro__circle {
    --cream-stop: 23.08%;
    position: absolute;
    z-index: 1;
    top: 77.1%;
    left: 50%;
    width: 90.625vw;
    aspect-ratio: 1740 / 1763;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      #f3eee1 0,
      #f3eee1 var(--cream-stop),
      #141414 100%
    );
    transform: translateX(-50%);
    will-change: top, width;
    -webkit-mask-image: radial-gradient(ellipse closest-side at center, #000 72%, transparent 100%);
    mask-image: radial-gradient(ellipse closest-side at center, #000 72%, transparent 100%);
  }

  .nl-intro__cream {
    position: absolute;
    z-index: 2;
    inset: 0;
    background: #f3eee1;
    opacity: 0;
  }

  .nl-intro__meta {
    position: absolute;
    z-index: 6;
    top: 7.2%;
    max-width: 20rem;
    color: #f3eee1;
    font-size: clamp(0.625rem, 0.73vw, 0.875rem);
    line-height: 1.18;
  }

  .nl-intro__meta p + p {
    margin-top: 1.25rem;
  }

  .nl-intro__meta--left {
    left: 3.1%;
  }

  .nl-intro__meta--right {
    right: 3.1%;
    text-align: right;
  }

  .nl-intro__cover {
    position: absolute;
    z-index: 5;
    top: 27.1%;
    left: 50%;
    width: min(66rem, 72vw);
    transform: translateX(-50%);
    text-align: center;
  }

  .nl-intro__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #f3eee1;
    font-size: clamp(0.7rem, 0.94vw, 1.125rem);
    text-transform: uppercase;
  }

  .nl-intro__eyebrow::before,
  .nl-intro__eyebrow::after {
    content: '';
    flex: 1;
    border-top: 1px solid rgba(243, 238, 225, 0.82);
  }

  .nl-intro__cover h1,
  .nl-intro__quote strong {
    display: block;
    color: #fd6500;
    font-family: var(--font-display);
    font-size: clamp(6.4rem, 10.42vw, 12.5rem);
    font-weight: 400;
    line-height: 0.91;
    letter-spacing: -0.055em;
    text-transform: uppercase;
  }

  .nl-intro__quote strong {
    position: relative;
  }

  .nl-intro__quote-word {
    position: relative;
    display: inline-block;
  }

  .nl-intro__closing-quote {
    /* Sized/positioned so the quote ink matches the Figma reference glyph. */
    position: absolute;
    top: -0.05em;
    left: 100%;
    margin-left: -0.06em;
    color: #141414;
    font-size: 0.7em;
    letter-spacing: 0;
  }

  .nl-intro__cover h1 {
    margin-top: clamp(2.2rem, 3.4vw, 4.1rem);
  }

  .nl-intro__subtitle {
    margin-top: clamp(1rem, 1.65vw, 2rem);
    color: #f3eee1;
    font-size: clamp(2.1rem, 3.33vw, 4rem);
    line-height: 1;
  }

  .nl-intro__date {
    width: 86%;
    margin: clamp(2.4rem, 3.6vw, 4.3rem) auto 0;
    padding-top: clamp(2rem, 2.6vw, 3.1rem);
    border-top: 1px solid rgba(243, 238, 225, 0.82);
    font-size: clamp(0.7rem, 0.94vw, 1.125rem);
    text-transform: uppercase;
  }

  .nl-intro__quote {
    position: absolute;
    z-index: 5;
    top: 31%;
    left: 50%;
    width: min(66rem, 74vw);
    margin: 0;
    color: #141414;
    text-align: center;
    transform: translateX(-50%);
    opacity: 0;
  }

  .nl-intro__quote-lead {
    font-size: clamp(2.1rem, 3.33vw, 4rem);
    line-height: 1.08;
  }

  .nl-intro__quote-rule {
    position: absolute;
    top: -1.65rem;
    left: 15%;
    width: 70%;
    border-top: 1px dotted rgba(20, 20, 20, 0.45);
    opacity: 0;
  }

  .nl-intro__quote strong {
    margin-top: 0.35rem;
  }

  .nl-intro__quote cite {
    display: block;
    margin-top: clamp(1.4rem, 2.6vw, 3.1rem);
    color: #520345;
