---
import MainLayout from '@layouts/MainLayout.astro';

const overviewEntries = [
  {
    year: '1715',
    title: 'Rococó',
    tone: 'orange',
    image: '/images/timeline-adli/rococo-1.png',
    alt: 'Silueta de moda del período rococó',
  },
  {
    year: '1789',
    title: 'La revolución',
    tone: 'cream',
    description:
      'En cinco años, Francia destruye su propia moda. Los brocados de Lyon, los paniers, los corsés de corte se vuelven símbolo del régimen caído.\n\nVestir a la francesa pasa de motivo de orgullo a motivo de sospecha. Los aristócratas queman sus vestidos o los cortan en pedazos. Marie Antoinette muere en la guillotina con una túnica blanca puesta. El sistema del rococó no sobrevive a su reina.',
  },
  {
    year: '1795',
    title: 'Neoclásico',
    tone: 'purple',
    image: '/images/timeline-adli/neoclasico-1.png',
    alt: 'Silueta de moda del período neoclásico',
  },
  {
    year: '1820',
    title: 'El regreso\ndel corsé',
    tone: 'cream',
    description:
      'Con la Restauración borbónica, las estructuras rígidas vuelven poco a poco al vestir femenino. El talle baja del pecho a la cintura natural, los corsés se ajustan otra vez, las mangas se hinchan hasta volverse enormes.\n\nLas telas se oscurecen y engrosan. La libertad neoclásica dura menos que las guerras napoleónicas: en una década, el cuerpo femenino vuelve a estar comprimido y esculpido. Sin revolución, sin escándalo, empieza un siglo entero de moda como arquitectura.',
  },
  {
    year: '1830',
    title: 'Siglo XIX',
    tone: 'blue',
    image: '/images/timeline-adli/siglo-xix-1.png',
    alt: 'Silueta de moda del siglo XIX',
  },
  {
    year: '1890',
    title: 'Anticipatoria',
    tone: 'cream',
    description:
      'El siglo XIX no muere en 1900. Se estira, se envuelve en más seda, en más plumas, en más lujo. El polisón desaparece pero el corsé se aprieta más que nunca, deformando el torso en una curva imposible.\n\nParís vive una euforia sostenida: cafés-conciertos, teatros llenos, salones aristocráticos. Nadie sabe todavía que lo están viviendo por última vez. El nombre "Belle Époque" se lo pondrán después, desde las trincheras, en 1918, cuando ya no exista.',
  },
];

const detailEras = [
  {
    id: 'rococo',
    tone: 'orange',
    cards: [
      {
        year: '1745',
        title: 'La era de Pompadour',
        image: '/images/timeline-adli/rococo-2.png',
        copy: 'Madame de Pompadour, amante oficial de Luis XV, se convierte en árbitro absoluto del gusto.\n\nLa robe à la française se consolida como uniforme de la corte: escote cuadrado, pliegues Watteau, paniers cada vez más anchos. Los talleres de Lyon producen brocados y damascos con hilos de oro y plata.\n\nUn solo vestido puede requerir veinte metros de seda tejida a mano.',
        silhouette: 'Robe à la francesa · panier ancho · brocado de Lyon · damasco',
        figures: 'Marquesa de Pompadour · François Boucher · Talleres de Lyon',
      },
      {
        year: '1774',
        title: 'Marie Antoinette y Rose Bertin',
        image: '/images/timeline-adli/rococo-3.png',
        copy: 'Marie Antoinette llega al trono con diecinueve años y contrata a la modista Rose Bertin.\n\nLa corte la llama "ministra de la moda". La reina propone siluetas nuevas casi cada semana: peinados torres, plumas de avestruz, colores pastel.\n\nLa haute couture pre-industrial nace en las trastiendas del rue Saint-Honoré, donde Bertin recibe a las clientas más poderosas de Europa.',
        silhouette: 'Robe à la polonaise · pouf · peinado alto · plumas · panier reducido',
        figures: 'Marie Antoinette · Rose Bertin · Léonard Autié',
      },
    ],
  },
  {
    id: 'neoclasico',
    tone: 'purple',
    cards: [
      {
        year: '1804',
        title: 'El Imperio de Josefina',
        image: '/images/timeline-adli/neoclasico-2.png',
        copy: 'Napoleón corona a Josefina emperatriz. Ella instala el estilo imperio como uniforme de una nueva aristocracia. Talle bajo el pecho, corte columna, mangas cortas abullonadas, bordados dorados en el pecho y el bajo. Louis-Hippolyte Leroy se vuelve su modisto exclusivo: el primer diseñador con nombre desde Rose Bertin. Napoleón, obsesionado con reactivar la industria francesa, prohíbe importar telas inglesas. Las sedas de Lyon vuelven a producir para la corte.',
        silhouette:
          'Talle imperio · bordado dorado · manga corta abullonada · chal cachemir · zapato plano',
        figures: 'Emperatriz Josefina · Louis-Hippolyte Leroy · Jacques David',
      },
      {
        year: '1815',
        title: 'La Restauración',
        image: '/images/timeline-adli/neoclasico-3.png',
        copy: 'Waterloo termina con Napoleón y con el Imperio. Los Borbones vuelven al trono, y con ellos, poco a poco, las estructuras que la Revolución había prohibido. El talle empieza a bajar del pecho hacia la cintura natural. Los corsés reaparecen tímidamente. Las mangas se hinchan. Los colores oscuros ganan terreno sobre el blanco imperial. El cuerpo se prepara, sin saberlo, para volver a encerrarse. El romanticismo está por empezar.',
        silhouette: 'Talle bajando · corsé ligero · manga jamón · falda campana · color oscuro',
        figures: 'Duquesa de Berry · Herbault · Victorine',
      },
    ],
  },
  {
    id: 'siglo-xix',
    tone: 'blue',
    cards: [
      {
        year: '1856',
        title: 'La crinolina y Worth',
        image: '/images/timeline-adli/siglo-xix-2.png',
        copy: 'La ingeniería textil inventa la crinolina de aros de acero: una jaula liviana que reemplaza las enaguas y ensancha la falda hasta diámetros imposibles. Bajo el Segundo Imperio, la emperatriz Eugenia de Montijo se convierte en el ícono internacional del vestir. Su modisto exclusivo es un inglés recién llegado a París: Charles Frederick Worth. En su casa de Rue de la Paix inventa un sistema nuevo: colecciones dos veces al año, modelos vivas para exhibir la ropa, firma del diseñador en cada pieza. Nace la haute couture como sistema.',
        silhouette:
          'Crinolina de aros · falda máxima · corpiño ajustado · hombro caído · escote descubierto',
        figures: 'Emperatriz Eugenia de Montijo · Charles Frederick Worth · Winterhalter',
      },
      {
        year: '1870',
        title: 'El polisón',
        image: '/images/timeline-adli/siglo-xix-3.png',
        copy: 'Cae el Segundo Imperio con la guerra franco-prusiana. La crinolina redonda desaparece y en su lugar aparece el polisón: una estructura acolchada que empuja el volumen hacia atrás, transformando la silueta en un perfil quebrado. La falda cae plana adelante y explota atrás en pliegues y colas arrastradas. Bajo la Tercera República, la moda francesa se recupera y se profesionaliza. Aparecen las revistas ilustradas de moda: La Mode Illustrée, Le Moniteur de la Mode. París consolida su condición de capital mundial del vestir.',
        silhouette:
          'Polisón · falda plana adelante · cola arrastrada · corsé cinchado · sombrero pequeño',
        figures: 'Charles Frederick Worth · Jacques Doucet · Émile Pingat',
      },
    ],
  },
];

const detailByYear = new Map([
  ['1715', detailEras[0]],
  ['1795', detailEras[1]],
  ['1830', detailEras[2]],
]);
---

<MainLayout
  immersive
  title="Línea de tiempo"
  description="Un recorrido por las transformaciones de la moda francesa entre 1715 y 1890."
>
  <div class="timeline-page" data-timeline>
    <header class="timeline-nav">
      <img src="/images/timeline-adli/nav-bar.svg" alt="Palais Galliera" />
      <nav class="sr-only" aria-label="Principal">
        <a href="/">Inicio</a>
        <a href="/agenda">Visitar</a>
        <a href="/muestra">Exposiciones</a>
        <a href="/coleccion">Colecciones</a>
        <a href="/historia">El museo</a>
        <a href="/agenda">Agenda y entradas</a>
      </nav>
    </header>

    <section class="timeline-overview" aria-label="Recorrido histórico">
      <div class="timeline-pattern" aria-hidden="true"></div>
      <aside class="timeline-overview__rail" aria-hidden="true">
        <span class="timeline-overview__rail-track"></span>
        <div class="timeline-date" data-timeline-date data-date-group="orange">
          <div class="timeline-date__group is-orange" data-date-group="orange">
            <span class="timeline-date__prefix">17</span>
            <span class="timeline-date__wheel"><span>15</span><span>89</span></span>
          </div>
          <div class="timeline-date__group is-purple" data-date-group="purple">
            <span class="timeline-date__prefix">1</span>
            <span class="timeline-date__wheel"><span>795</span><span>820</span></span>
          </div>
          <div class="timeline-date__group is-blue" data-date-group="blue">
            <span class="timeline-date__prefix">18</span>
            <span class="timeline-date__wheel"><span>30</span><span>90</span></span>
          </div>
        </div>
        <span class="timeline-overview__rail-progress"></span>
      </aside>
      <div class="timeline-overview__entries">
        {
          overviewEntries.map((entry) => {
            const detail = detailByYear.get(entry.year);

            return (
              <article
                class:list={[
                  'timeline-overview__entry',
                  `is-${entry.tone}`,
                  { 'is-expandable': Boolean(detail) },
                ]}
                data-horizontal-era={detail ? '' : undefined}
                data-lenis-prevent-wheel={detail ? '' : undefined}
                tabindex={detail ? '0' : undefined}
                aria-label={
                  detail
                    ? `${entry.title}. Deslizá horizontalmente para recorrer este período.`
                    : undefined
                }
              >
                <div class="timeline-overview__entry-track">
                  <div class="timeline-overview__stage">
                    <div class="timeline-overview__content">
                      <span class="timeline-overview__line" aria-hidden="true" />
                      <h1>{entry.title}</h1>
                      {entry.image && (
                        <img
                          src={entry.image}
                          alt={entry.alt}
                          loading={entry.year === '1715' ? 'eager' : 'lazy'}
                        />
                      )}
                      {entry.description && <p>{entry.description}</p>}
                    </div>
                  </div>
                  {detail && (
                    <section
                      class:list={['timeline-inline-detail', `is-${detail.tone}`]}
                      aria-label={`Recorrido horizontal: ${entry.title}`}
                    >
                      <div class="timeline-detail__track">
                        <span
                          class="timeline-detail__line timeline-detail__line--top"
                          aria-hidden="true"
                        />
                        <span
                          class="timeline-detail__line timeline-detail__line--bottom"
                          aria-hidden="true"
                        />
                        {detail.cards.map((card, index) => (
                          <article class:list={['timeline-card', `is-card-${index}`]}>
                            {card.year && <p class="timeline-card__year">{card.year}</p>}
                            <h3>{card.title}</h3>
                            <img
                              src={card.image}
                              alt={`Referencia visual: ${card.title}`}
                              loading="lazy"
                            />
                            <p class="timeline-card__copy">{card.copy}</p>
                            <dl>
                              <div>
                                <dt>Silueta</dt>
                                <dd>{card.silhouette}</dd>
                              </div>
                              <div>
                                <dt>Figuras clave</dt>
                                <dd>{card.figures}</dd>
                              </div>
                            </dl>
                          </article>
                        ))}
                      </div>
                    </section>
                  )}
                </div>
              </article>
            );
          })
        }
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .timeline-page {
    --black: #141414;
    --cream: #f3eee1;
    --orange: #fd6500;
    --purple: #520345;
    --blue: #b9d6fe;
    --overview-content-left: 969px;
    color: var(--cream);
    background: var(--black);
    overflow: clip;
  }

  .timeline-nav {
    position: fixed;
    top: 57px;
    left: 60px;
    z-index: 100;
    display: flex;
    align-items: stretch;
    width: 1345px;
    height: 61px;
  }
  .timeline-nav > img {
    display: block;
    width: 1345px;
    height: 61px;
  }
  .timeline-page.is-detail-active .timeline-nav,
  .timeline-page.is-detail-active .timeline-overview__rail {
    opacity: 0;
    pointer-events: none;
  }

  .timeline-pattern {
    position: sticky;
    top: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    margin-bottom: -100vh;
    background: url('/images/timeline-agenda/timeline-pattern.svg') -365px 55px / 2145px 7086px
      no-repeat;
    pointer-events: none;
  }

  .timeline-overview {
    position: relative;
    min-height: 7086px;
  }

  .timeline-overview__rail {
    position: absolute;
    top: 176px;
    bottom: 180px;
    left: 139px;
    z-index: 1;
    width: 34px;
  }

  .timeline-overview__rail-track {
    position: absolute;
    inset: 0;
    background: rgb(243 238 225 / 5%);
  }
  .timeline-overview__rail-progress {
    position: absolute;
    top: var(--rail-progress-position, 143px);
    display: block;
    width: 100%;
    height: 155px;
    background: rgb(253 101 0 / 30%);
  }

  .timeline-date {
    position: sticky;
    top: 208px;
    margin-left: 148px;
    width: 390px;
    height: 200px;
    overflow: hidden;
  }
  .timeline-date__group {
    position: absolute;
    inset: 0;
    color: var(--orange);
    opacity: 0;
    transition: opacity 160ms linear;
  }
  .timeline-date[data-date-group='orange'] .timeline-date__group.is-orange,
  .timeline-date[data-date-group='purple'] .timeline-date__group.is-purple,
  .timeline-date[data-date-group='blue'] .timeline-date__group.is-blue {
    opacity: 1;
  }
  .timeline-date__prefix,
  .timeline-date__wheel span {
    display: block;
    height: 200px;
    font-family: var(--font-display);
    font-size: 200px;
    font-weight: 100;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .timeline-date__prefix {
    position: absolute;
    top: 0;
    left: 0;
  }
  .timeline-date__wheel {
    position: absolute;
    top: 0;
    left: 114px;
    transform: translateY(var(--date-wheel-shift, 0px));
    will-change: transform;
  }
  .timeline-date__group.is-purple {
    color: var(--purple);
  }
  .timeline-date__group.is-purple .timeline-date__wheel {
    left: 96px;
  }
  .timeline-date__group.is-blue {
    color: var(--blue);
  }

  .timeline-overview__entries {
    position: relative;
    z-index: 1;
  }
  .timeline-overview__entry {
    position: relative;
    height: 1218px;
  }
  .timeline-overview__entry.is-expandable {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    cursor: grab;
    scroll-snap-type: x mandatory;
  }
  .timeline-overview__entry.is-expandable::-webkit-scrollbar {
    display: none;
  }
  .timeline-overview__entry.is-expandable.is-dragging {
    cursor: grabbing;
    user-select: none;
  }
  .timeline-overview__entry-track {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .timeline-overview__entry.is-expandable .timeline-overview__entry-track {
    width: calc(100vw + 3801px);
  }
  .timeline-overview__stage {
    position: relative;
    width: 100vw;
    height: 100%;
    scroll-snap-align: start;
  }
  .timeline-overview__entry:nth-child(1) {
    height: 1285px;
  }
  .timeline-overview__entry:nth-child(2) {
    height: 953px;
  }
  .timeline-overview__entry:nth-child(3) {
    height: 1256px;
  }
  .timeline-overview__entry:nth-child(4) {
    height: 1196px;
  }
  .timeline-overview__entry:nth-child(5) {
    height: 1278px;
  }

  .timeline-overview__content {
    position: absolute;
    top: 339px;
    left: var(--overview-content-left);
    width: 666px;
  }
  .timeline-overview__line {
    position: absolute;
    top: -42px;
    left: 0;
    display: block;
    width: calc(100vw - var(--overview-content-left));
    height: 9px;
    background: currentColor;
    mask: url('/images/timeline-adli/line.svg') center / 100% 100% no-repeat;
    -webkit-mask: url('/images/timeline-adli/line.svg') center / 100% 100% no-repeat;
  }
  .timeline-overview h1 {
    margin: 0;
    font-family: var(--font-body);
    font-size: 115px;
    font-weight: 450;
    letter-spacing: 0;
    line-height: 0.95;
    white-space: pre-line;
  }
  .timeline-overview__content > h1,
  .timeline-overview__content > img,
  .timeline-overview__content > p {
    margin-left: 0;
  }
  .timeline-overview img {
    display: block;
    width: 666px;
    height: 643px;
    margin-top: 70px;
    object-fit: fill;
  }
  .timeline-overview__content > p {
    margin: 64px 0 0;
    font-family: var(--font-body);
    font-size: 32px;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.01em;
    white-space: pre-line;
  }
  .timeline-overview__entry.is-cream .timeline-overview__content {
    top: 339px;
  }
  .timeline-overview__entry.is-cream .timeline-overview__content > p {
    margin-top: 65px;
  }
  .timeline-overview__entry.is-cream h1 + p {
    margin-top: 65px;
  }
  .timeline-overview__entry.is-orange {
    color: var(--orange);
  }
  .timeline-overview__entry.is-purple {
    color: var(--purple);
  }
  .timeline-overview__entry.is-blue {
    color: var(--blue);
  }
  .timeline-overview__entry.is-cream {
    color: var(--cream);
  }
  .timeline-overview__entry.is-cream .timeline-overview__content > p {
    color: var(--cream);
  }
  .timeline-overview__entry:nth-child(2) .timeline-overview__content,
  .timeline-overview__entry:nth-child(3) .timeline-overview__content {
    top: 339px;
  }
  .timeline-overview__entry:nth-child(4) .timeline-overview__content,
  .timeline-overview__entry:nth-child(5) .timeline-overview__content,
  .timeline-overview__entry:nth-child(6) .timeline-overview__content {
    top: 361px;
  }

  .timeline-inline-detail {
    position: absolute;
    top: 0;
    left: calc(100vw + 54px);
    width: 3747px;
    height: 1080px;
    scroll-snap-align: start;
  }
  .timeline-detail__track {
    position: relative;
    width: 3747px;
    height: 1080px;
  }
  .timeline-detail__line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 9px;
    background: currentColor;
    mask: url('/images/timeline-adli/line.svg') center / 100% 100% no-repeat;
    -webkit-mask: url('/images/timeline-adli/line.svg') center / 100% 100% no-repeat;
  }
  .timeline-detail__line--top {
    top: 117px;
  }
  .timeline-detail__line--bottom {
    top: 1023px;
    background-color: var(--cream);
  }
  .timeline-inline-detail.is-orange {
    color: var(--orange);
  }
  .timeline-inline-detail.is-purple {
    color: var(--purple);
  }
  .timeline-inline-detail.is-blue {
    color: var(--blue);
  }

  .timeline-card {
    position: absolute;
    top: 0;
    width: 970px;
    height: 1080px;
    color: var(--cream);
    scroll-snap-align: start;
  }
  .timeline-card.is-card-0 {
    left: 340px;
  }
  .timeline-card.is-card-1 {
    left: 1963px;
  }
  .timeline-card h3 {
    position: absolute;
    top: 437px;
    left: 695px;
    width: 435px;
    margin: 0;
    color: var(--blue);
    font-family: var(--font-display);
    font-size: 64px;
    font-style: italic;
    font-weight: 100;
    line-height: 0.94;
  }
  .timeline-card__year {
    position: absolute;
    top: 188px;
    left: 16px;
    margin: 0;
    color: var(--cream);
    font-family: var(--font-display);
    font-size: 64px;
    font-style: italic;
    line-height: 1;
  }
  .timeline-card img {
    position: absolute;
    top: 337px;
    left: 0;
    display: block;
    width: 666px;
    height: 643px;
    object-fit: fill;
  }
  .timeline-card__copy {
    position: absolute;
    top: 610px;
    left: 695px;
    width: 435px;
    margin: 0;
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1;
    white-space: pre-line;
  }
  .timeline-card dl {
    position: absolute;
    top: 876px;
    left: 695px;
    width: 435px;
    margin: 0;
  }
  .timeline-card dl div + div {
    margin-top: 31px;
  }
  .timeline-card dt {
    color: var(--orange);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 1;
    text-transform: uppercase;
  }
  .timeline-card dd {
    margin: 17px 0 0;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1;
  }
  .timeline-card::before {
    position: absolute;
    top: 120px;
    left: 0;
    width: 1px;
    height: 147px;
    background: currentColor;
    content: '';
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-date__group {
      transition: none;
    }
  }
</style>

<script>
  const timelinePage = document.querySelector<HTMLElement>('[data-timeline]');
  const overview = document.querySelector<HTMLElement>('.timeline-overview');
  const date = document.querySelector<HTMLElement>('[data-timeline-date]');
  const rail = document.querySelector<HTMLElement>('.timeline-overview__rail');
  const railProgress = document.querySelector<HTMLElement>('.timeline-overview__rail-progress');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const clamp = (value: number) => Math.min(1, Math.max(0, value));

  const updateTimelineDate = () => {
    if (!overview || !date) return;

    const overviewTop = overview.getBoundingClientRect().top + window.scrollY;
    const position = window.scrollY - overviewTop;
    const overviewProgress = clamp(
      position / Math.max(1, overview.offsetHeight - window.innerHeight)
    );
    const groups = [
      { name: 'orange', start: 0, end: 1285 },
      { name: 'purple', start: 2238, end: 3494 },
      { name: 'blue', start: 4690, end: 5968 },
    ] as const;
    const active = position < 2238 ? groups[0] : position < 4690 ? groups[1] : groups[2];
    const progress = clamp((position - active.start) / (active.end - active.start));
    const shift = reduceMotion ? (progress > 0.5 ? -200 : 0) : -200 * progress;
    const activeGroup = date.querySelector<HTMLElement>(`[data-date-group="${active.name}"]`);

    date.dataset.dateGroup = active.name;
    activeGroup?.style.setProperty('--date-wheel-shift', `${shift}px`);

    if (rail && railProgress) {
      const start = 143;
      const end = Math.max(start, rail.clientHeight - railProgress.offsetHeight);
      railProgress.style.setProperty(
        '--rail-progress-position',
        `${start + (end - start) * overviewProgress}px`
      );
    }
  };

  updateTimelineDate();
  window.addEventListener('scroll', updateTimelineDate, { passive: true });

  document.querySelectorAll<HTMLElement>('[data-horizontal-era]').forEach((scroller) => {
    let startX = 0;
    let startScroll = 0;

    scroller.addEventListener('pointerdown', (event) => {
      startX = event.clientX;
      startScroll = scroller.scrollLeft;
      scroller.setPointerCapture(event.pointerId);
      scroller.classList.add('is-dragging');
    });

    scroller.addEventListener('pointermove', (event) => {
      if (!scroller.classList.contains('is-dragging')) return;
      scroller.scrollLeft = startScroll - (event.clientX - startX);
    });

    const release = () => scroller.classList.remove('is-dragging');
    scroller.addEventListener('pointerup', release);
    scroller.addEventListener('pointercancel', release);

    const syncDetailState = () => {
      const isDetailOpen = Array.from(
        document.querySelectorAll<HTMLElement>('[data-horizontal-era]')
      ).some((era) => era.scrollLeft > 8);
      timelinePage?.classList.toggle('is-detail-active', isDetailOpen);
    };

    scroller.addEventListener('scroll', syncDetailState, { passive: true });

    const openDetail = () => {
      if (scroller.scrollLeft > 0) return;
      scroller.scrollTo({
        left: window.innerWidth + 54,
        behavior: reduceMotion ? 'auto' : 'smooth',
      });
    };

    scroller.addEventListener('click', (event) => {
      if (Math.abs(event.clientX - startX) > 8) return;
      openDetail();
    });

    scroller.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      openDetail();
    });
  });
</script>
