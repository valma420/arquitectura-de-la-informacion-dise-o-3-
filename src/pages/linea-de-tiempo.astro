    top: 262px;
    left: 0;
    width: 100%;
    height: 155px;
    background: linear-gradient(180deg, rgba(253, 101, 0, 0.3), rgba(82, 3, 69, 0.3));
    transform: translateY(var(--tl-rail-shift));
    will-change: transform;
  }

  .timeline-chevron {
    position: absolute;
    top: 472px;
    left: calc(7.29vw + 34px);
    width: 38px;
    height: 14px;
  }

  .timeline-chevron::before,
