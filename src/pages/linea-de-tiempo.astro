---
/**
 * Línea de tiempo (/linea-de-tiempo) — period viewer + timeline scrubber.
 * The selected period's name/year and its pieces carousel update client-side;
 * supports deep-linking via ?periodo=<id>.
 */
import MainLayout from '@layouts/MainLayout.astro';
import { periods, pieces } from '@data/collection';

const defaultPeriod = periods.find((p) => p.id === 'new-look') ?? periods[0];

const piecesLite = pieces.map((p) => ({
  slug: p.slug,
  title: p.title,
  yearLabel: p.yearLabel,
  year: p.year,
  periodId: p.periodId,
  image: p.image,
  imageKind: p.imageKind,
}));
---

<MainLayout
  title="Línea de tiempo"
  description="Navegá la colección del Palais Galliera por período: del siglo XVIII al posmoderno."
>
  <section class="tl">
    <p class="label tl__kicker">Período seleccionado</p>

    <header class="tl__head">
      <h1 class="tl__name type-display-italic" data-tl-name>{defaultPeriod.name}</h1>
      <p class="tl__year type-display-italic" data-tl-year>{defaultPeriod.year}</p>
    </header>

    <p class="tl__desc" data-tl-desc>{defaultPeriod.description}</p>

    <div class="tl__carousel" data-tl-carousel></div>

    <p class="label tl__hint">
      Deslizá para recorrer las piezas del período <span aria-hidden="true">→</span>
    </p>

    <div class="tl__scrubber">
      <p class="label tl__scrubber-title">Línea de tiempo — navegá la colección por período</p>
      <div class="tl__periods">
        {
          periods.map((p) => (
            <button
              class="tl__period"
              data-tl-period={p.id}
              aria-pressed={p.id === defaultPeriod.id ? 'true' : 'false'}
            >
              <figure class="tl__period-thumb">
                <img src={p.image} alt="" loading="lazy" />
              </figure>
              <span class="tl__tick" aria-hidden="true" />
              <span class="tl__period-year">{p.year}</span>
              <span class="tl__period-name label">{p.name}</span>
            </button>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>

<script
  is:inline
  type="application/json"
  id="tl-data"
  set:html={JSON.stringify({ periods, pieces: piecesLite })}
/>

<style>
  .tl {
    background: var(--color-black);
    color: var(--color-cream);
    padding: var(--space-xl) 0 var(--space-2xl);
    overflow: hidden;
  }

  .tl__kicker {
    color: var(--color-muted);
    padding-inline: var(--layout-gutter);
  }

  .tl__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-lg);
    padding-inline: var(--layout-gutter);
    margin-top: var(--space-md);
  }

  .tl__name {
    font-size: var(--font-size-display-md);
  }

  .tl__year {
    font-size: var(--font-size-display-md);
  }

  .tl__desc {
    padding-inline: var(--layout-gutter);
    margin-top: var(--space-sm);
    max-width: 52ch;
    font-size: var(--font-size-sm);
    line-height: 1.7;
    color: var(--color-cream);
  }

  /* ---------------------------------------------------------------- */
  /* Pieces carousel                                                   */
  /* ---------------------------------------------------------------- */
  .tl__carousel {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-inline: var(--layout-gutter);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .tl__carousel::-webkit-scrollbar {
    display: none;
  }

  .tl__carousel :global(.tl-card) {
    flex: 0 0 clamp(16rem, 24vw, 27rem);
    scroll-snap-align: start;
    display: block;
  }

  .tl__carousel :global(.tl-card figure) {
    margin: 0;
    aspect-ratio: 1 / 1.05;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(243, 238, 225, 0.08), transparent 70%),
      var(--color-surface-dark);
    display: grid;
    place-items: center;
    padding: var(--space-lg);
    transition: background var(--duration-fast) var(--ease-standard);
  }

  .tl__carousel :global(.tl-card:hover figure) {
    background:
      radial-gradient(ellipse at 50% 30%, rgba(243, 238, 225, 0.14), transparent 70%),
      #232120;
  }

  .tl__carousel :global(.tl-card img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 14px 26px rgba(0, 0, 0, 0.7));
  }

  .tl__carousel :global(.tl-card.is-photo figure) {
    padding: 0;
  }

  .tl__carousel :global(.tl-card.is-photo img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tl__carousel :global(.tl-card .tl-card__title) {
    margin-top: var(--space-sm);
    font-size: var(--font-size-sm);
  }

  .tl__carousel :global(.tl-card .tl-card__year) {
    margin-top: 2px;
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }

  .tl__hint {
    padding-inline: var(--layout-gutter);
    margin-top: var(--space-lg);
    color: var(--color-muted);
  }

  /* ---------------------------------------------------------------- */
  /* Scrubber                                                          */
  /* ---------------------------------------------------------------- */
  .tl__scrubber {
    margin-top: var(--space-3xl);
    padding-inline: var(--layout-gutter);
  }

  .tl__scrubber-title {
    color: var(--color-muted);
  }

  .tl__periods {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    position: relative;
  }

  .tl__period {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    color: var(--color-cream);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
    font-family: var(--font-body);
  }

  .tl__period-thumb {
    margin: 0 0 var(--space-2xs);
    width: clamp(3.5rem, 6vw, 6.5rem);
    aspect-ratio: 1;
    background: var(--color-surface-dark);
    display: grid;
    place-items: center;
    padding: 12%;
    opacity: 0.5;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .tl__period-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .tl__tick {
    width: 100%;
    height: 9px;
    position: relative;
  }

  .tl__tick::before {
    content: '';
    position: absolute;
    left: -0.5rem;
    right: -0.5rem;
    top: 4px;
    height: 1px;
    background: rgba(243, 238, 225, 0.3);
  }

  .tl__tick::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    width: 1.5px;
    height: 9px;
    background: var(--color-cream);
    transform: translateX(-50%);
    transition: background var(--duration-fast) var(--ease-standard);
  }

  .tl__period-year {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw, 2.2rem);
    line-height: 1.1;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .tl__period-name {
    color: var(--color-muted);
    font-size: var(--label-size-sm);
  }

  .tl__period:hover .tl__period-thumb,
  .tl__period[aria-pressed='true'] .tl__period-thumb {
    opacity: 1;
  }

  .tl__period[aria-pressed='true'] .tl__period-year {
    color: var(--color-red-bright);
  }

  .tl__period[aria-pressed='true'] .tl__tick::after {
    background: var(--color-red-bright);
    width: 2.5px;
  }

  @media (max-width: 900px) {
    .tl__periods {
      grid-template-columns: repeat(4, 1fr);
      row-gap: var(--space-lg);
    }

    .tl__head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  interface TlPeriod {
    id: string;
    year: number;
    name: string;
    description: string;
    image: string;
  }

  interface TlPiece {
    slug: string;
    title: string;
    yearLabel: string;
    year: number;
    periodId: string;
    image: string;
    imageKind: 'cutout' | 'photo';
  }

  const data = JSON.parse(document.getElementById('tl-data')?.textContent ?? '{}') as {
    periods: TlPeriod[];
    pieces: TlPiece[];
  };

  const nameEl = document.querySelector<HTMLElement>('[data-tl-name]');
  const yearEl = document.querySelector<HTMLElement>('[data-tl-year]');
  const descEl = document.querySelector<HTMLElement>('[data-tl-desc]');
  const carousel = document.querySelector<HTMLElement>('[data-tl-carousel]');
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-tl-period]');

  function render(periodId: string) {
    const period = data.periods.find((p) => p.id === periodId);
    if (!period || !carousel) return;

    if (nameEl) nameEl.textContent = period.name;
    if (yearEl) yearEl.textContent = String(period.year);
    if (descEl) descEl.textContent = period.description;

    const items = data.pieces
      .filter((p) => p.periodId === periodId)
      .sort((a, b) => a.year - b.year);

    carousel.innerHTML = items
      .map(
        (p) => `
        <a href="/coleccion/${p.slug}" class="tl-card${p.imageKind === 'photo' ? ' is-photo' : ''}">
          <figure><img src="${p.image}" alt="${p.title}" loading="lazy" /></figure>
          <p class="tl-card__title">${p.title}</p>
          <p class="tl-card__year">${p.yearLabel}</p>
        </a>`,
      )
      .join('');

    carousel.scrollTo({ left: 0 });

    buttons.forEach((b) =>
      b.setAttribute('aria-pressed', b.dataset.tlPeriod === periodId ? 'true' : 'false'),
    );

    const url = new URL(window.location.href);
    url.searchParams.set('periodo', periodId);
    history.replaceState(null, '', url);
  }

  buttons.forEach((b) => b.addEventListener('click', () => render(b.dataset.tlPeriod ?? '')));

  const initial = new URLSearchParams(window.location.search).get('periodo') ?? 'new-look';
  render(data.periods.some((p) => p.id === initial) ? initial : 'new-look');
</script>
