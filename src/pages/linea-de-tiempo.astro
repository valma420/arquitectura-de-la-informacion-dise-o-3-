---
import MainLayout from '@layouts/MainLayout.astro';
import { getPeriod, piecesByPeriod } from '@data/collection';

const belleDescription =
  'La moda de la opulencia y el refinamiento. El corsé esculpe una silueta en S, pecho hacia adelante, cintura de avispa, cadera atrás, y el vestido se cubre de encajes, bordados y volúmenes.';

const belleDetailDescription =
  'La moda de la opulencia y el refinamiento. El corsé esculpe una silueta en S, pecho hacia adelante, cintura de avispa, cadera atrás, y el vestido se cubre de encajes, bordados y volúmenes. París se consagra como capital de la moda y nace la alta costura moderna; hacia el final del período, Poiret empieza a liberar el cuerpo del corsé.';

const anneesFolles = getPeriod('annees-folles');
const anneesPieces = piecesByPeriod('annees-folles');

const overviewEras = [
  {
    name: 'Belle Époque',
    range: '1871-1914',
    image: '/images/timeline-agenda/timeline-1870.png',
    tone: 'orange',
    description: belleDescription,
  },
  {
    name: anneesFolles?.name ?? 'Années Folles',
    range: '1918-1929',
    image: '/images/timeline-agenda/timeline-1918.png',
    tone: 'blue',
    description: anneesFolles?.description ?? '',
  },
];

const detailEras = [
  {
    id: 'belle-epoque',
    name: 'Belle Époque',
    ghostYear: '1870',
    tone: 'orange',
    cards: [
      {
        year: '1871-1914',
        title: 'Belle Époque',
        image: '/images/timeline-agenda/timeline-1870.png',
      },
      { year: '1890s', image: '/images/timeline-agenda/timeline-1890.png' },
      { year: '1900s', image: '/images/timeline-agenda/timeline-1900.png' },
    ].map((card) => ({
      ...card,
      description: belleDetailDescription,
      meta: [
        {
          label: 'SILUETA',
          value: 'Corsé · silueta en S · cintura de avispa · falda con cola y volumen',
        },
        {
          label: 'FIGURAS CLAVE',
          value: 'Charles Frederick Worth · Jacques Doucet · Jeanne Paquin · Callot Soeurs',
        },
      ],
    })),
  },
  {
    id: 'annees-folles',
    name: anneesFolles?.name ?? 'Années Folles',
    ghostYear: '1918',
    tone: 'blue',
    cards: [
      {
        year: '1918-1929',
        title: anneesFolles?.name ?? 'Années Folles',
        image: '/images/timeline-agenda/timeline-1918.png',
        description: anneesFolles?.description ?? '',
        meta: [
          { label: 'PERÍODO', value: '1918-1929' },
          {
            label: 'PIEZAS',
            value: anneesPieces.map((piece) => piece.title).join(' · '),
          },
        ],
      },
      ...anneesPieces.map((piece) => ({
        year: piece.yearLabel,
        title: piece.title,
        image: piece.image,
        imageKind: piece.imageKind,
        description: piece.description,
        meta: [
          { label: 'MATERIALES', value: piece.material ?? '—' },
          { label: 'TÉCNICA', value: piece.technique ?? '—' },
        ],
      })),
    ],
  },
];
---

<MainLayout
  immersive
  title="Línea de tiempo"
  description="Un recorrido por las transformaciones de la silueta entre 1870 y 1929."
>
  <div class="timeline-page" data-timeline>
    <section class="timeline-overview" data-timeline-overview aria-label="Recorrido histórico">
      <div class="timeline-overview__pattern" aria-hidden="true"></div>

      <div class="timeline-left" aria-hidden="true">
        <div class="timeline-left__sticky">
          <div class="timeline-rail">
            <span class="timeline-rail__progress"></span>
          </div>
          <span class="timeline-chevron"></span>
          <span class="timeline-century">1</span>
          <div class="timeline-wheel">
            <span class="timeline-wheel__year is-1870">870</span>
            <span class="timeline-wheel__year is-1914">914</span>
            <span class="timeline-wheel__year is-1918">918</span>
          </div>
        </div>
      </div>

      <div class="timeline-flow">
        {
          overviewEras.map((era) => (
            <article class:list={['timeline-era', `is-${era.tone}`]}>
              <span class="timeline-era__line timeline-era__line--top" aria-hidden="true" />
              <h1>{era.name}</h1>
              <p class="timeline-era__range">{era.range}</p>
              <img class="timeline-era__image" src={era.image} alt="" />
              <span class="timeline-era__line timeline-era__line--bottom" aria-hidden="true" />
              <p class="timeline-era__description">{era.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    {
      detailEras.map((era) => (
        <section
          class:list={['timeline-detail-shell', `is-${era.tone}`]}
          aria-labelledby={`timeline-detail-${era.id}`}
          data-detail-shell
        >
          <h2 class="sr-only" id={`timeline-detail-${era.id}`}>
            {era.name}
          </h2>

          <div
            class="timeline-details"
            data-timeline-details
            data-lenis-prevent-wheel
            tabindex="0"
            aria-label={`${era.name}. Deslizá horizontalmente para recorrer sus tarjetas.`}
          >
            <span class="timeline-details__ghost" aria-hidden="true">
              {era.ghostYear}
            </span>
            <div class="timeline-details__track">
              <span class="timeline-details__line timeline-details__line--top" aria-hidden="true" />
              <span
                class="timeline-details__line timeline-details__line--bottom"
                aria-hidden="true"
              />

              {era.cards.map((card, index) => (
                <article
                  class="timeline-card"
                  data-detail-card
                  data-card-label={`${card.title ?? era.name}, ${card.year}`}
                  aria-label={`${card.title ?? era.name}, ${card.year}`}
                  aria-current={index === 0 ? 'true' : undefined}
                >
                  {card.title && <h3>{card.title}</h3>}
                  <p class="timeline-card__year">{card.year}</p>
                  <img
                    class:list={[
                      'timeline-card__image',
                      { 'is-cutout': 'imageKind' in card && card.imageKind === 'cutout' },
                    ]}
                    src={card.image}
                    alt={`Referencia visual de ${card.title ?? era.name}, ${card.year}`}
                    loading={index ? 'lazy' : 'eager'}
                  />
                  <p class="timeline-card__copy">{card.description}</p>
                  {card.meta.map((item, metaIndex) => (
                    <div
                      class:list={['timeline-card__meta', `timeline-card__meta--${metaIndex + 1}`]}
                    >
                      <strong>{item.label}</strong>
                      <span>{item.value}</span>
                    </div>
                  ))}
                </article>
              ))}
            </div>
          </div>

          <div class="timeline-details__controls" aria-label={`Navegar ${era.name}`}>
            <button
              type="button"
              data-detail-previous
              aria-label={`Tarjeta anterior de ${era.name}`}
            >
              <span aria-hidden="true">←</span>
            </button>
            <p aria-live="polite" data-detail-status>
              01 / {String(era.cards.length).padStart(2, '0')}
            </p>
            <button type="button" data-detail-next aria-label={`Tarjeta siguiente de ${era.name}`}>
              <span aria-hidden="true">→</span>
            </button>
          </div>
        </section>
      ))
    }
  </div>
</MainLayout>

<style>
  .timeline-page {
    --tl-black: #141414;
    --tl-cream: #f3eee1;
    --tl-orange: #fd6500;
    --tl-purple: #520345;
    --tl-blue: #b9d6fe;
    --tl-year-shift: 0px;
    --tl-rail-shift: 0px;
    --tl-pattern-x: -161px;
    --tl-pattern-y: -76px;
    --tl-detail-scroll: 0px;
    --tl-detail-pattern-x: -251px;
    position: relative;
    isolation: isolate;
    overflow: clip;
    color: var(--tl-cream);
    background: var(--tl-black);
  }

  .timeline-overview__pattern {
    position: sticky;
    top: 0;
    z-index: 10;
    width: 100vw;
    height: 100vh;
    margin-bottom: -100vh;
    background-image: url('/images/timeline-agenda/timeline-pattern.svg');
    background-position: var(--tl-pattern-x) var(--tl-pattern-y);
    background-size: max(111.73vw, 1340px) max(204.81vw, 2457px);
    background-repeat: no-repeat;
    pointer-events: none;
  }

  .timeline-overview {
    position: relative;
    z-index: 1;
    height: 2618px;
  }

  .timeline-left {
    position: absolute;
    inset: 0 auto 0 0;
    width: 50.52vw;
    pointer-events: none;
  }

  .timeline-left__sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .timeline-rail {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 7.29vw;
    width: 34px;
    background: rgba(243, 238, 225, 0.05);
  }

  .timeline-rail__progress {
    position: absolute;
    top: 262px;
    left: 0;
    width: 100%;
    height: 155px;
    background: linear-gradient(180deg, rgba(253, 101, 0, 0.3), rgba(82, 3, 69, 0.3));
    transform: translateY(var(--tl-rail-shift));
    will-change: transform;
  }

  .timeline-chevron {
    position: absolute;
    top: 472px;
    left: calc(7.29vw + 34px);
    width: 38px;
    height: 14px;
  }

  .timeline-chevron::before,
  .timeline-chevron::after {
    position: absolute;
    left: 0;
    width: 38px;
    height: 1px;
    background: var(--tl-orange);
    content: '';
    transform-origin: right;
  }

  .timeline-chevron::before {
    top: 0;
    transform: rotate(20deg);
  }

  .timeline-chevron::after {
    bottom: 0;
    transform: rotate(-20deg);
  }

  .timeline-century,
  .timeline-wheel__year,
  .timeline-details__ghost {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .timeline-century {
    position: absolute;
    top: 219px;
    left: calc(15vw - 34px);
    width: 130px;
    font-size: 200px;
    color: transparent;
    background: linear-gradient(180deg, var(--tl-orange) 0%, var(--tl-purple) 86%);
    background-clip: text;
  }

  .timeline-wheel {
    position: absolute;
    top: 219px;
    left: 17.66vw;
    width: 521px;
    height: 299px;
    transform: translateY(calc(-1 * var(--tl-year-shift)));
    will-change: transform;
  }

  .timeline-wheel__year {
    position: absolute;
    left: 0;
    width: 521px;
    height: 299px;
    font-size: 200px;
  }

  .timeline-wheel__year.is-1870 {
    top: 0;
    color: var(--tl-orange);
  }

  .timeline-wheel__year.is-1914 {
    top: 663px;
    color: transparent;
    background: linear-gradient(180deg, var(--tl-orange), var(--tl-purple));
    background-clip: text;
  }

  .timeline-wheel__year.is-1918 {
    top: 1326px;
    color: transparent;
    background: linear-gradient(180deg, var(--tl-purple), var(--tl-blue));
    background-clip: text;
  }

  .timeline-flow {
    width: 49.48vw;
    margin-left: 50.52vw;
  }

  .timeline-era {
    position: relative;
    height: 1309px;
  }

  .timeline-era__line {
    position: absolute;
    left: -20px;
    width: calc(100% + 20px);
    height: 4px;
    background: currentColor;
    clip-path: polygon(
      0 34%,
      2% 62%,
      4% 40%,
      6% 66%,
      8% 37%,
      10% 60%,
      12% 39%,
      14% 64%,
      16% 36%,
      18% 61%,
      20% 40%,
      22% 63%,
      24% 39%,
      26% 61%,
      28% 37%,
      30% 64%,
      32% 39%,
      34% 62%,
      36% 38%,
      38% 64%,
      40% 36%,
      42% 62%,
      44% 40%,
      46% 63%,
      48% 37%,
      50% 64%,
      52% 38%,
      54% 61%,
      56% 40%,
      58% 64%,
      60% 37%,
      62% 62%,
      64% 40%,
      66% 64%,
      68% 37%,
      70% 61%,
      72% 40%,
      74% 63%,
      76% 38%,
      78% 64%,
      80% 36%,
      82% 62%,
      84% 40%,
      86% 64%,
      88% 37%,
      90% 62%,
      92% 39%,
      94% 64%,
      96% 37%,
      98% 62%,
      100% 40%
    );
  }

  .timeline-era__line--top {
    top: 193px;
  }

  .timeline-era__line--bottom {
    top: 878px;
  }

  .timeline-era.is-orange .timeline-era__line--top,
  .timeline-era.is-orange .timeline-era__range {
    color: var(--tl-orange);
  }

  .timeline-era.is-orange .timeline-era__line--bottom {
    color: var(--tl-purple);
  }

  .timeline-era.is-blue .timeline-era__line,
  .timeline-era.is-blue .timeline-era__range {
    color: var(--tl-blue);
  }

  .timeline-era h1 {
    position: absolute;
    top: 210px;
    left: 0;
    font-family: var(--font-body);
    font-size: 64px;
    font-style: italic;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .timeline-era__range {
    position: absolute;
    top: 319px;
    left: 0;
    font-size: 32px;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .timeline-era__image {
    position: absolute;
    top: 440px;
    left: 0;
    width: 435px;
    height: 421px;
    max-width: none;
    object-fit: fill;
  }

  .timeline-era__description {
    position: absolute;
    top: 905px;
    left: 0;
    width: 500px;
    font-size: 32px;
    font-style: italic;
    line-height: 1.12;
    letter-spacing: -0.035em;
    text-align: justify;
    transform: scaleX(0.868);
    transform-origin: left top;
  }

  .timeline-detail-shell {
    --detail-accent: var(--tl-orange);
    position: relative;
    z-index: 2;
    height: 1080px;
  }

  .timeline-details {
    position: relative;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    color: var(--tl-cream);
    background: transparent;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    cursor: grab;
  }

  .timeline-details::after {
    position: absolute;
    top: 0;
    left: var(--tl-detail-scroll);
    z-index: 10;
    width: 100vw;
    height: 100%;
    content: '';
    background-image: url('/images/timeline-agenda/timeline-pattern.svg');
    background-position: var(--tl-detail-pattern-x) -87px;
    background-size: max(111.73vw, 1340px) max(204.81vw, 2457px);
    background-repeat: no-repeat;
    pointer-events: none;
  }

  .timeline-details::-webkit-scrollbar {
    display: none;
  }

  .timeline-details.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    user-select: none;
  }

  .timeline-details__track {
    position: relative;
    display: flex;
    width: max-content;
    min-width: 100%;
    height: 1080px;
  }

  .timeline-details__track::after {
    width: max(0px, calc(100vw - 1137px));
    flex: 0 0 max(0px, calc(100vw - 1137px));
    content: '';
  }

  .timeline-details__line {
    position: absolute;
    left: 288px;
    z-index: 3;
    width: calc(100% - 288px);
    height: 4px;
    background: currentColor;
    clip-path: polygon(
      0 35%,
      2% 62%,
      4% 38%,
      6% 65%,
      8% 36%,
      10% 61%,
      12% 39%,
      14% 64%,
      16% 37%,
      18% 62%,
      20% 39%,
      22% 63%,
      24% 38%,
      26% 62%,
      28% 36%,
      30% 64%,
      32% 39%,
      34% 62%,
      36% 38%,
      38% 64%,
      40% 36%,
      42% 62%,
      44% 40%,
      46% 63%,
      48% 37%,
      50% 64%,
      52% 38%,
      54% 61%,
      56% 40%,
      58% 64%,
      60% 37%,
      62% 62%,
      64% 40%,
      66% 64%,
      68% 37%,
      70% 61%,
      72% 40%,
      74% 63%,
      76% 38%,
      78% 64%,
      80% 36%,
      82% 62%,
      84% 40%,
      86% 64%,
      88% 37%,
      90% 62%,
      92% 39%,
      94% 64%,
      96% 37%,
      98% 62%,
      100% 40%
    );
    pointer-events: none;
  }

  .timeline-details__line--top {
    top: 193px;
    color: var(--tl-orange);
  }

  .timeline-details__line--bottom {
    top: 878px;
    color: var(--tl-cream);
  }

  .timeline-details__ghost {
    position: absolute;
    top: 219px;
    left: -385px;
    z-index: 4;
    font-size: 268px;
    color: var(--tl-orange);
    pointer-events: none;
  }

  .timeline-card {
    position: relative;
    flex: 0 0 1137px;
    height: 1080px;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .timeline-card:not(:first-of-type)::before {
    position: absolute;
    top: 197px;
    left: 288px;
    width: 1px;
    height: 135px;
    background: var(--tl-orange);
    content: '';
  }

  .timeline-card h3 {
    position: absolute;
    top: 210px;
    left: 288px;
    font-family: var(--font-body);
    font-size: 64px;
    font-style: italic;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .timeline-card__year {
    position: absolute;
    top: 301px;
    left: 288px;
    color: var(--tl-orange);
    font-size: 32px;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .timeline-card:not(:first-of-type) .timeline-card__year {
    left: 268px;
  }

  .timeline-card__image {
    position: absolute;
    top: 440px;
    left: 288px;
    width: 435px;
    height: 421px;
    max-width: none;
  }

  .timeline-card__image.is-cutout {
    object-fit: contain;
    object-position: center bottom;
  }

  .timeline-card__copy {
    position: absolute;
    top: 440px;
    left: 744px;
    width: 460px;
    font-size: 18px;
    line-height: 1.16;
    transform: scaleX(0.833);
    transform-origin: left top;
  }

  .timeline-card__meta {
    position: absolute;
    left: 744px;
    width: 383px;
    font-size: 16px;
    line-height: 1.15;
  }

  .timeline-card__meta--1 {
    top: 660px;
  }

  .timeline-card__meta--2 {
    top: 730px;
  }

  .timeline-card__meta strong,
  .timeline-card__meta span {
    display: block;
  }

  .timeline-card__meta strong {
    margin-bottom: 3px;
    color: var(--tl-orange);
    font-size: 14px;
    letter-spacing: 0.035em;
  }

  .timeline-detail-shell.is-blue .timeline-details__line,
  .timeline-detail-shell.is-blue .timeline-details__ghost,
  .timeline-detail-shell.is-blue .timeline-card__year,
  .timeline-detail-shell.is-blue .timeline-card__meta strong {
    color: var(--tl-blue);
  }

  .timeline-detail-shell.is-blue {
    --detail-accent: var(--tl-blue);
  }

  .timeline-details__controls {
    position: absolute;
    right: 3.125vw;
    bottom: 2.5rem;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--detail-accent);
  }

  .timeline-details__controls button {
    display: grid;
    width: 3rem;
    height: 3rem;
    padding: 0;
    place-items: center;
    color: inherit;
    background: var(--tl-black);
    border: 1px solid currentColor;
    border-radius: 50%;
    cursor: pointer;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      opacity 180ms ease;
  }

  .timeline-details__controls button:hover:not(:disabled),
  .timeline-details__controls button:focus-visible {
    color: var(--tl-black);
    background: var(--detail-accent);
  }

  .timeline-details__controls button:disabled {
    cursor: not-allowed;
    opacity: 0.3;
  }

  .timeline-details__controls p {
    min-width: 4.75rem;
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-align: center;
  }

  @media (max-width: 920px) {
    .timeline-overview__pattern,
    .timeline-details::after {
      background-size: 200vw 366.61vw;
    }

    .timeline-overview {
      height: 2240px;
    }

    .timeline-left {
      width: 100%;
    }

    .timeline-rail {
      left: 1rem;
      width: 16px;
    }

    .timeline-chevron {
      left: 2rem;
    }

    .timeline-century {
      top: 5.5rem;
      left: 2.5rem;
      font-size: clamp(7rem, 28vw, 11rem);
      opacity: 0.45;
    }

    .timeline-wheel {
      top: 5.5rem;
      left: 4.9rem;
      opacity: 0.45;
    }

    .timeline-wheel__year {
      font-size: clamp(7rem, 28vw, 11rem);
    }

    .timeline-flow {
      position: relative;
      z-index: 2;
      width: auto;
      margin-left: 26vw;
      padding-right: 1.25rem;
    }

    .timeline-era {
      height: 1120px;
    }

    .timeline-era__line--top {
      top: 180px;
    }

    .timeline-era h1 {
      top: 200px;
      font-size: clamp(2.6rem, 9vw, 4.5rem);
    }

    .timeline-era__range {
      top: 280px;
      font-size: 1.65rem;
    }

    .timeline-era__image {
      top: 350px;
      width: min(435px, 68vw);
      height: auto;
    }

    .timeline-era__line--bottom {
      top: 790px;
    }

    .timeline-era__description {
      top: 815px;
      width: min(28rem, 68vw);
      font-size: clamp(1.35rem, 4.6vw, 2rem);
      text-align: left;
      transform: none;
    }

    .timeline-detail-shell,
    .timeline-details,
    .timeline-details__track,
    .timeline-card {
      height: 980px;
    }

    .timeline-details__track {
      width: max-content;
    }

    .timeline-details__track::after {
      width: 0;
      flex-basis: 0;
    }

    .timeline-card {
      flex-basis: 100vw;
    }

    .timeline-details__line--top {
      top: 88px;
    }

    .timeline-details__line--bottom {
      top: 900px;
    }

    .timeline-details__ghost {
      display: none;
    }

    .timeline-card h3 {
      top: 108px;
      left: 1.25rem;
      font-size: clamp(2.8rem, 11vw, 4.5rem);
    }

    .timeline-card__year {
      top: 185px;
      left: 1.25rem;
    }

    .timeline-card__image {
      top: 245px;
      left: 1.25rem;
      width: min(435px, calc(100vw - 2.5rem));
      height: auto;
    }

    .timeline-card__image.is-cutout {
      height: 400px;
    }

    .timeline-card__copy {
      top: 680px;
      left: 1.25rem;
      width: calc(100vw - 2.5rem);
      transform: none;
    }

    .timeline-card__meta {
      display: none;
    }

    .timeline-details__controls {
      right: 1.25rem;
      bottom: 1.5rem;
    }

    .timeline-details__controls button {
      width: 2.75rem;
      height: 2.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline-details {
      scroll-behavior: auto;
    }

    .timeline-details__controls button {
      transition: none;
    }
  }
</style>

<script>
  const timeline = document.querySelector<HTMLElement>('[data-timeline]');
  const overview = timeline?.querySelector<HTMLElement>('[data-timeline-overview]');
  const detailSections = Array.from(
    timeline?.querySelectorAll<HTMLElement>('[data-timeline-details]') ?? []
  );
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (timeline && overview) {
    let ticking = false;

    const renderTimeline = () => {
      const rect = overview.getBoundingClientRect();
      const scroll = Math.max(0, Math.min(1326, -rect.top));
      let railShift = 0;
      let patternX = -103;
      let patternY = 0;

      if (scroll < 180) railShift = scroll * (224 / 180);
      else if (scroll <= 648) railShift = 224;
      else railShift = 224 + Math.min(202, ((scroll - 648) / 225) * 202);

      if (scroll <= 224) {
        const progress = scroll / 224;
        patternX = -161 + 58 * progress;
        patternY = -76 + 70 * progress;
      } else if (scroll <= 648) {
        patternY = -6 + 6 * ((scroll - 224) / 424);
      } else if (scroll <= 873) {
        patternY = -1000 * ((scroll - 648) / 225);
      } else {
        patternY = -1000;
      }

      const yearShift = reducedMotion.matches
        ? scroll < 332
          ? 0
          : scroll < 995
            ? 663
            : 1326
        : scroll;

      timeline.style.setProperty('--tl-year-shift', `${yearShift}px`);
      timeline.style.setProperty('--tl-rail-shift', `${railShift}px`);
      timeline.style.setProperty('--tl-pattern-x', `${patternX}px`);
      timeline.style.setProperty('--tl-pattern-y', `${patternY}px`);
      ticking = false;
    };

    const requestRender = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(renderTimeline);
    };

    renderTimeline();
    window.addEventListener('scroll', requestRender, { passive: true });
    window.addEventListener('resize', requestRender);
  }

  detailSections.forEach((details) => {
    const shell = details.closest<HTMLElement>('[data-detail-shell]');
    const cards = Array.from(details.querySelectorAll<HTMLElement>('[data-detail-card]'));
    const previousButton = shell?.querySelector<HTMLButtonElement>('[data-detail-previous]');
    const nextButton = shell?.querySelector<HTMLButtonElement>('[data-detail-next]');
    const status = shell?.querySelector<HTMLElement>('[data-detail-status]');
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let currentIndex = 0;
    let wheelLocked = false;
    let wheelTimer = 0;
    let renderFrame = 0;

    const normalizedIndex = (index: number) => Math.max(0, Math.min(cards.length - 1, index));

    const findClosestIndex = () => {
      let closestIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      cards.forEach((card, index) => {
        const distance = Math.abs(card.offsetLeft - details.scrollLeft);
        if (distance >= closestDistance) return;
        closestDistance = distance;
        closestIndex = index;
      });

      return closestIndex;
    };

    const renderDetailsPattern = () => {
      const maxScroll = Math.max(1, details.scrollWidth - details.clientWidth);
      const progress = Math.min(1, details.scrollLeft / maxScroll);
      details.style.setProperty('--tl-detail-scroll', `${details.scrollLeft}px`);
      details.style.setProperty('--tl-detail-pattern-x', `${-251 + 250 * progress}px`);

      currentIndex = findClosestIndex();
      cards.forEach((card, index) => {
        if (index === currentIndex) card.setAttribute('aria-current', 'true');
        else card.removeAttribute('aria-current');
      });

      if (previousButton) previousButton.disabled = currentIndex === 0;
      if (nextButton) nextButton.disabled = currentIndex === cards.length - 1;
      if (status) {
        status.textContent = `${String(currentIndex + 1).padStart(2, '0')} / ${String(cards.length).padStart(2, '0')}`;
        status.setAttribute(
          'aria-label',
          `Tarjeta ${currentIndex + 1} de ${cards.length}: ${cards[currentIndex]?.dataset.cardLabel ?? ''}`
        );
      }

      renderFrame = 0;
    };

    const requestDetailsRender = () => {
      if (renderFrame) return;
      renderFrame = requestAnimationFrame(renderDetailsPattern);
    };

    const goToCard = (index: number) => {
      currentIndex = normalizedIndex(index);
      details.scrollTo({
        left: cards[currentIndex]?.offsetLeft ?? 0,
        behavior: reducedMotion.matches ? 'auto' : 'smooth',
      });
      if (reducedMotion.matches) renderDetailsPattern();
    };

    renderDetailsPattern();
    details.addEventListener('scroll', requestDetailsRender, { passive: true });

    previousButton?.addEventListener('click', () => goToCard(currentIndex - 1));
    nextButton?.addEventListener('click', () => goToCard(currentIndex + 1));

    details.addEventListener(
      'wheel',
      (event) => {
        if (Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;
        const direction = Math.sign(event.deltaY);
        const targetIndex = currentIndex + direction;
        if (targetIndex < 0 || targetIndex >= cards.length) return;
        event.preventDefault();
        if (wheelLocked) return;

        wheelLocked = true;
        goToCard(targetIndex);
        window.clearTimeout(wheelTimer);
        wheelTimer = window.setTimeout(
          () => {
            wheelLocked = false;
          },
          reducedMotion.matches ? 80 : 480
        );
      },
      { passive: false }
    );

    details.addEventListener('pointerdown', (event) => {
      // Touch already has native momentum scrolling; duplicating it here doubles the travel.
      if (event.pointerType === 'touch') return;
      dragging = true;
      startX = event.clientX;
      startScroll = details.scrollLeft;
      details.classList.add('is-dragging');
      details.setPointerCapture(event.pointerId);
    });

    details.addEventListener('pointermove', (event) => {
      if (!dragging) return;
      details.scrollLeft = startScroll - (event.clientX - startX);
    });

    const stopDragging = () => {
      dragging = false;
      details.classList.remove('is-dragging');
    };

    details.addEventListener('pointerup', stopDragging);
    details.addEventListener('pointercancel', stopDragging);
    details.addEventListener('keydown', (event) => {
      const targetIndex =
        event.key === 'ArrowLeft'
          ? currentIndex - 1
          : event.key === 'ArrowRight'
            ? currentIndex + 1
            : event.key === 'Home'
              ? 0
              : event.key === 'End'
                ? cards.length - 1
                : null;

      if (targetIndex === null) return;
      event.preventDefault();
      goToCard(targetIndex);
    });

    window.addEventListener('resize', requestDetailsRender);
  });
</script>
