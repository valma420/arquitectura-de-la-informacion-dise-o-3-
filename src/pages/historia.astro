    width: 12.5%;
    height: 7.2%;
  }

  .rococo-article__mobile {
    display: none;
  }

  @media (max-width: 47.99rem) {
    :global(body) {
      background: #b9d6fe;
    }

    .era-selector--desktop,
    .rococo-article__desktop {
      display: none;
    }

    .era-selector--mobile {
      display: grid;
      grid-template-rows: auto 1fr;
      min-height: 100svh;
      padding: 1.15rem 1.15rem 2.25rem;
      color: #141414;
      background: #fd6500;
    }

    .mobile-nav {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .mobile-nav__logo {
      width: 3rem;
      height: 3rem;
      flex: 0 0 auto;
    }

    .mobile-nav__toggle {
      position: relative;
      z-index: 2;
      display: grid;
      place-content: center;
      gap: 0.35rem;
      width: 3rem;
      height: 3rem;
