      transform: translateY(0.18rem) rotate(45deg);
    }

    .mobile-nav__toggle[aria-expanded='true'] span:last-child {
      transform: translateY(-0.18rem) rotate(-45deg);
    }

    .mobile-nav__menu {
      position: absolute;
      top: -0.25rem;
      right: -0.25rem;
      left: -0.25rem;
      display: grid;
      gap: 0;
      padding: 4.5rem 1.25rem 1.15rem;
      color: #f3eee1;
      background: #141414;
      border-radius: 1.25rem;
      box-shadow: 0 1.25rem 4rem rgb(20 20 20 / 22%);
    }

    .mobile-nav__menu[hidden] {
      display: none;
    }

    .mobile-nav__menu a {
      padding: 0.72rem 0;
      border-top: 1px solid rgb(243 238 225 / 20%);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .mobile-nav__menu .mobile-nav__ticket {
      margin-top: 0.6rem;
      padding: 0.75rem 0.9rem;
      color: #141414;
      background: #fd6500;
      border-top: 0;
      border-radius: 0.15rem;
      text-align: center;
    }

    .mobile-era-rail {
      align-self: start;
      display: grid;
      grid-template-columns: 1fr auto auto auto 1fr;
      align-items: center;
      gap: 0.55rem;
      margin-top: clamp(4.5rem, 14vh, 7rem);
      font-family: var(--font-display);
      font-size: 0.85rem;
