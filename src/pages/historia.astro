    }

    .mobile-gallery-photo img {
      position: absolute;
      top: -14.88%;
      left: -14.65%;
      width: 129.37%;
      height: 114.87%;
      max-width: none;
      object-fit: cover;
    }

    .mobile-gallery-frame {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .mobile-article-copy__body {
      display: grid;
      gap: 1.45rem;
      font-size: 1rem;
      font-style: italic;
      line-height: 1.25;
    }

    .mobile-article-copy__body a {
      color: #fd6500;
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 0.08em;
    }

    .mobile-article-copy__body a.is-purple {
