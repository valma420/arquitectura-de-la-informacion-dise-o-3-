---
/**
 * Historia (/historia) — recorrido Rococó.
 *
 * Desktop reproduces the two authored Figma frames at their native proportions.
 * Mobile has no authored board, so it keeps the same palette, hierarchy and
 * ornamental language while reflowing the content into one readable column.
 */
import MainLayout from '@layouts/MainLayout.astro';

const navigation = [
  { label: 'Visitar', href: '/' },
  { label: 'Exposiciones', href: '/muestra' },
  { label: 'Colecciones', href: '/coleccion' },
  { label: 'El museo', href: '/historia' },
  { label: 'Agenda', href: '/agenda' },
];
---

<MainLayout
  immersive
  title="Rococó — 1715–1789"
  description="Texto curatorial sobre el Rococó, la robe à la française y la memoria de la indumentaria del siglo XVIII."
>
  <section
    id="selector-de-epoca"
    class="era-selector era-selector--desktop"
    aria-label="Seleccionar época: Rococó, 1715 a 1789"
    data-motion-owned
  >
    <img
      class="era-selector__figma"
      src="/images/history-fidelity/selector.png"
      alt=""
      width="1920"
      height="1080"
      fetchpriority="high"
      aria-hidden="true"
    />

    <nav class="desktop-hit-nav" aria-label="Principal">
      <a class="desktop-hit desktop-hit--logo" href="/" aria-label="Palais Galliera — Inicio"></a>
      <a class="desktop-hit desktop-hit--visitar" href="/" aria-label="Visitar"></a>
      <a class="desktop-hit desktop-hit--exposiciones" href="/muestra" aria-label="Exposiciones"
      ></a>
      <a class="desktop-hit desktop-hit--colecciones" href="/coleccion" aria-label="Colecciones"
      ></a>
      <a class="desktop-hit desktop-hit--museo" href="/historia" aria-label="El museo"></a>
      <a class="desktop-hit desktop-hit--agenda" href="/agenda" aria-label="Agenda"></a>
      <a class="desktop-hit desktop-hit--entradas" href="/agenda" aria-label="Entradas"></a>
      <a
        class="desktop-hit desktop-hit--search"
        href="/coleccion"
        aria-label="Buscar en la colección"></a>
    </nav>

    <a
      class="desktop-hit desktop-hit--read"
      href="#historia-rococo"
      aria-label="Leer el texto curatorial sobre el Rococó"
      data-read-history></a>
  </section>

  <section
    class="era-selector era-selector--mobile"
    aria-labelledby="mobile-era-title"
    data-motion-owned
  >
    <header class="mobile-nav" data-mobile-history-nav>
      <a class="mobile-nav__logo" href="/" aria-label="Palais Galliera — Inicio">
        <svg viewBox="0 0 61 61" aria-hidden="true">
          <circle cx="30.5" cy="30.5" r="30.5" fill="#141414"></circle>
          <g fill="none" stroke="#f3eee1" stroke-width="2">
            <path d="M14 25.5h33M14 39h33M17 28v8m7-8v8m7-8v8m7-8v8m7-8v8"></path>
            <path d="m15 23 15.5-6L46 23Z"></path>
          </g>
        </svg>
      </a>
      <button
        class="mobile-nav__toggle"
        type="button"
        aria-label="Abrir menú"
        aria-controls="history-mobile-menu"
        aria-expanded="false"
        data-mobile-history-toggle
      >
        <span></span><span></span>
      </button>
      <nav class="mobile-nav__menu" id="history-mobile-menu" aria-label="Principal" hidden>
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="mobile-nav__ticket" href="/agenda">Entradas</a>
      </nav>
    </header>

    <div class="mobile-era-rail" aria-label="Épocas disponibles">
      <span>1700–1715</span>
      <span class="mobile-era-rail__arrow" aria-hidden="true">←</span>
      <strong>1715–1789</strong>
      <span class="mobile-era-rail__arrow" aria-hidden="true">→</span>
      <span>1795–1830</span>
    </div>

    <div class="mobile-era-copy">
      <h1 id="mobile-era-title">Rococó</h1>
      <p>
        Del reinado de Luis XV al estallido de la Revolución. Robe à la française, panier, pliegue
        Watteau, sedas de Lyon.
      </p>
      <a class="mobile-read" href="#historia-rococo" data-read-history>
        <img src="/images/history-fidelity/read-button.svg" alt="" aria-hidden="true" />
        <span>Leer</span>
      </a>
    </div>
  </section>

  <article
    id="historia-rococo"
    class="rococo-article"
    aria-label="Texto curatorial: Rococó, 1715 a 1789"
    data-motion-owned
  >
    <div class="rococo-article__desktop">
      <img
        class="rococo-article__figma"
        src="/images/history-fidelity/article.png"
        alt=""
        width="1920"
        height="2314"
        loading="eager"
        aria-hidden="true"
      />
      <a class="article-hit article-hit--back" href="#selector-de-epoca">Ver más épocas</a>
      <a class="article-hit article-hit--discover" href="/coleccion">Descubrir la selección</a>
    </div>

    <div class="rococo-article__mobile">
      <header class="mobile-article-hero">
        <img
          class="mobile-article-hero__floral"
          src="/images/history-fidelity/header-floral.svg"
          alt=""
          aria-hidden="true"
        />
        <a href="#selector-de-epoca">Ver más épocas</a>
        <div class="mobile-article-hero__title">
          <p>1715 — 1789</p>
          <h2>Rococó</h2>
        </div>
        <div class="mobile-article-hero__byline">
          <span>17 de julio, 2026</span>
          <em>María S. Camargo</em>
        </div>
      </header>

      <section class="mobile-article-copy">
        <blockquote>
          “Cada época deja atrás una manera de estar en el cuerpo. La del siglo XVIII no cabe en
          ningún cuerpo actual.”
        </blockquote>
        <p class="mobile-article-copy__credit">
          — Pascale Gorguet-Ballesteros, conservadora · Palais Galliera
        </p>

        <div class="mobile-article-copy__gallery">
          <div class="mobile-gallery-photo">
            <img
              src="/images/history-fidelity/gallery.jpg"
              alt="Vestidos del siglo XVIII exhibidos en el Palais Galliera"
            />
          </div>
          <img
            class="mobile-gallery-frame"
            src="/images/history-fidelity/gallery-frame.svg"
            alt=""
            aria-hidden="true"
          />
        </div>

        <div class="mobile-article-copy__body">
          <p>
            En los retratos de <a href="/coleccion">Élisabeth Vigée Le Brun</a>, la vestimenta ocupa
            tanto espacio como el rostro. La pintura terminó preservando aquello que el tiempo no
            pudo conservar: la caída de una tela, el brillo de un bordado, el volumen de unos
            paniers. Cuando los textiles originales desaparecen, las pinturas continúan actuando
            como archivos visuales capaces de mantener viva la memoria de formas, colores y
            texturas.
          </p>
          <p>
            Con el paso de los siglos, gran parte de ese universo desapareció. Permanecieron algunos
            vestidos, fragmentos textiles, retratos y documentos capaces de reconstruir apenas una
            parte del relato. Cada pieza conservada por el
            <a class="is-purple" href="/">Palais Galliera</a> funciona como un fragmento de memoria: no
            cuenta toda la historia, pero permite activar conexiones entre personas, materiales y contextos
            que continúan dialogando con el presente.
          </p>
          <p>
            Quizás por eso observar una prenda del siglo XVIII nunca consiste únicamente en mirar un
            objeto antiguo. Cada costura, cada pliegue y cada bordado siguen conteniendo información
            que espera ser recordada. La memoria no permanece inmóvil dentro del museo: vuelve a
            activarse cada vez que alguien decide detenerse sobre un detalle y descubrir que, detrás
            de una tela aparentemente silenciosa, todavía sobreviven historias que continúan
            resonando en el presente.
          </p>
        </div>
      </section>

      <footer class="mobile-discover">
        <h2>Robe à la française</h2>
        <p>Una selección de piezas exclusivas de esta época</p>
        <a href="/coleccion">
          <img src="/images/history-fidelity/discover-arrow.svg" alt="" aria-hidden="true" />
          <span>Descubrir</span>
        </a>
      </footer>
    </div>
  </article>
</MainLayout>

<style>
