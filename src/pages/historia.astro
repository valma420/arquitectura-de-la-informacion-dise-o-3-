      z-index: 1;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.06em;
    }

    .rococo-article__mobile {
      display: block;
      color: #141414;
      background: linear-gradient(to bottom, #f3eee1 13rem, #b9d6fe 48rem);
    }

    .mobile-article-hero {
      position: relative;
      isolation: isolate;
      min-height: 25rem;
      padding: 2.2rem 1.2rem 1.5rem;
      overflow: hidden;
      background: #b9d6fe;
      border-bottom: 1px solid #141414;
    }

    .mobile-article-hero__floral {
      position: absolute;
      top: -1rem;
      right: -5rem;
      z-index: -1;
      width: 42rem;
      max-width: none;
      opacity: 0.8;
      transform: scaleX(-1);
    }

    .mobile-article-hero > a {
      display: inline-block;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .mobile-article-hero__title {
      position: absolute;
      right: 1.2rem;
      bottom: 2.25rem;
      left: 1.2rem;
    }

    .mobile-article-hero__title p {
      font-family: var(--font-display);
      font-size: clamp(2.6rem, 13vw, 4rem);
      font-style: italic;
      line-height: 0.9;
    }

    .mobile-article-hero__title h2 {
      margin-top: 0.2rem;
      color: #fd6500;
      font-size: clamp(5.5rem, 27vw, 8rem);
      font-weight: 400;
      line-height: 0.78;
      letter-spacing: -0.055em;
    }

    .mobile-article-hero__byline {
      position: absolute;
      right: 1.2rem;
      bottom: 1.2rem;
