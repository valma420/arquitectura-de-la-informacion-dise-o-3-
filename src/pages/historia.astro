---
/**
 * Historia (/historia) — recorrido Rococó.
 *
 * Desktop reproduces the two authored Figma frames at their native proportions.
 * Mobile has no authored board, so it keeps the same palette, hierarchy and
 * ornamental language while reflowing the content into one readable column.
 */
import MainLayout from '@layouts/MainLayout.astro';

const navigation = [
  { label: 'Visitar', href: '/' },
  { label: 'Exposiciones', href: '/muestra' },
  { label: 'Colecciones', href: '/coleccion' },
  { label: 'El museo', href: '/historia' },
  { label: 'Agenda', href: '/agenda' },
];
---

<MainLayout
  immersive
  title="Rococó — 1715–1789"
  description="Texto curatorial sobre el Rococó, la robe à la française y la memoria de la indumentaria del siglo XVIII."
>
  <section
    id="selector-de-epoca"
    class="era-selector era-selector--desktop"
    aria-label="Seleccionar época: Rococó, 1715 a 1789"
    data-motion-owned
  >
    <img
      class="era-selector__figma"
      src="/images/history-fidelity/selector.png"
      alt=""
      width="1920"
      height="1080"
      fetchpriority="high"
      aria-hidden="true"
    />

    <nav class="desktop-hit-nav" aria-label="Principal">
      <a class="desktop-hit desktop-hit--logo" href="/" aria-label="Palais Galliera — Inicio"></a>
      <a class="desktop-hit desktop-hit--visitar" href="/" aria-label="Visitar"></a>
      <a class="desktop-hit desktop-hit--exposiciones" href="/muestra" aria-label="Exposiciones"
      ></a>
      <a class="desktop-hit desktop-hit--colecciones" href="/coleccion" aria-label="Colecciones"
      ></a>
      <a class="desktop-hit desktop-hit--museo" href="/historia" aria-label="El museo"></a>
      <a class="desktop-hit desktop-hit--agenda" href="/agenda" aria-label="Agenda"></a>
      <a class="desktop-hit desktop-hit--entradas" href="/agenda" aria-label="Entradas"></a>
      <a
        class="desktop-hit desktop-hit--search"
        href="/coleccion"
        aria-label="Buscar en la colección"></a>
    </nav>

    <a
      class="desktop-hit desktop-hit--read"
      href="#historia-rococo"
      aria-label="Leer el texto curatorial sobre el Rococó"
      data-read-history></a>
  </section>

  <section
    class="era-selector era-selector--mobile"
    aria-labelledby="mobile-era-title"
    data-motion-owned
  >
    <header class="mobile-nav" data-mobile-history-nav>
      <a class="mobile-nav__logo" href="/" aria-label="Palais Galliera — Inicio">
        <svg viewBox="0 0 61 61" aria-hidden="true">
          <circle cx="30.5" cy="30.5" r="30.5" fill="#141414"></circle>
          <g fill="none" stroke="#f3eee1" stroke-width="2">
            <path d="M14 25.5h33M14 39h33M17 28v8m7-8v8m7-8v8m7-8v8m7-8v8"></path>
            <path d="m15 23 15.5-6L46 23Z"></path>
          </g>
        </svg>
      </a>
      <button
        class="mobile-nav__toggle"
        type="button"
        aria-label="Abrir menú"
        aria-controls="history-mobile-menu"
        aria-expanded="false"
        data-mobile-history-toggle
      >
        <span></span><span></span>
      </button>
      <nav class="mobile-nav__menu" id="history-mobile-menu" aria-label="Principal" hidden>
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="mobile-nav__ticket" href="/agenda">Entradas</a>
      </nav>
    </header>

    <div class="mobile-era-rail" aria-label="Épocas disponibles">
      <span>1700–1715</span>
      <span class="mobile-era-rail__arrow" aria-hidden="true">←</span>
      <strong>1715–1789</strong>
      <span class="mobile-era-rail__arrow" aria-hidden="true">→</span>
      <span>1795–1830</span>
    </div>

    <div class="mobile-era-copy">
      <h1 id="mobile-era-title">Rococó</h1>
      <p>
        Del reinado de Luis XV al estallido de la Revolución. Robe à la française, panier, pliegue
        Watteau, sedas de Lyon.
      </p>
      <a class="mobile-read" href="#historia-rococo" data-read-history>
        <img src="/images/history-fidelity/read-button.svg" alt="" aria-hidden="true" />
        <span>Leer</span>
      </a>
    </div>
  </section>

  <article
    id="historia-rococo"
    class="rococo-article"
    aria-label="Texto curatorial: Rococó, 1715 a 1789"
    data-motion-owned
  >
    <div class="rococo-article__desktop">
      <header class="desktop-reader-header">
        <img
          class="desktop-reader-header__floral"
          src="/images/history-fidelity/header-floral.svg"
          alt=""
          aria-hidden="true"
        />
        <a href="#selector-de-epoca">Ver más épocas</a>
        <div class="desktop-reader-header__title">
          <p>1715 — 1789</p>
          <h2>Rococó</h2>
        </div>
        <div class="desktop-reader-header__byline">
          <span>17 de julio, 2026</span>
          <em>María S. Camargo</em>
        </div>
      </header>

      <div
        class="desktop-reader-scroll"
        tabindex="0"
        aria-label="Texto curatorial. Desplazá para continuar la lectura."
        data-history-reader
      >
        <section class="desktop-reader-copy">
          <div class="desktop-reader-copy__lead">
            <blockquote>
              “Cada época deja atrás una manera de estar en el cuerpo. La del siglo XVIII no cabe en
              ningún cuerpo actual.”
            </blockquote>
            <p>— Pascale Gorguet-Ballesteros, conservadora · Palais Galliera</p>
          </div>

          <figure class="desktop-reader-media">
            <div class="desktop-reader-media__image">
              <img
                src="/images/history-fidelity/gallery.jpg"
                alt="Vestidos del siglo XVIII exhibidos en el Palais Galliera"
                data-related-preview
              />
            </div>
            <img
              class="desktop-reader-media__frame"
              src="/images/history-fidelity/gallery-frame.svg"
              alt=""
              aria-hidden="true"
            />
            <figcaption data-related-caption>Vestidos del siglo XVIII en exhibición</figcaption>
          </figure>

          <div class="desktop-reader-copy__body">
            <p>
              En los retratos de
              <button
                class="related-word"
                type="button"
                data-related-image="/images/history-fidelity/gallery.jpg"
                data-related-alt="Vestidos del siglo XVIII exhibidos en el Palais Galliera"
                data-related-caption="Élisabeth Vigée Le Brun · retratos como archivo visual"
                aria-pressed="true">Élisabeth Vigée Le Brun</button
              >, la vestimenta ocupa tanto espacio como el rostro. La pintura terminó preservando
              aquello que el tiempo no pudo conservar: la caída de una tela, el brillo de un
              bordado, el volumen de unos paniers. Cuando los textiles originales desaparecen, las
              pinturas continúan actuando como archivos visuales capaces de mantener viva la memoria
              de formas, colores y texturas.
            </p>
            <p>
              Con el paso de los siglos, gran parte de ese universo desapareció. Permanecieron
              algunos vestidos, fragmentos textiles, retratos y documentos capaces de reconstruir
              apenas una parte del relato. Cada pieza conservada por el
              <button
                class="related-word related-word--purple"
                type="button"
                data-related-image="/images/prendas/1730.png"
                data-related-alt="Robe à la française de 1730"
                data-related-caption="Robe à la française · c. 1730"
                aria-pressed="false">Palais Galliera</button
              > funciona como un fragmento de memoria: no cuenta toda la historia, pero permite activar
              conexiones entre personas, materiales y contextos que continúan dialogando con el presente.
            </p>
            <p>
              Quizás por eso observar una prenda del siglo XVIII nunca consiste únicamente en mirar
              un objeto antiguo. Cada costura, cada pliegue y cada bordado siguen conteniendo
              información que espera ser recordada. La memoria no permanece inmóvil dentro del
              museo: vuelve a activarse cada vez que alguien decide detenerse sobre un detalle y
              descubrir que, detrás de una tela aparentemente silenciosa, todavía sobreviven
              historias que continúan resonando en el presente.
            </p>
          </div>
        </section>

        <footer class="desktop-discover">
          <h2>Robe à la française</h2>
          <p>Una selección de piezas exclusivas de esta época</p>
          <a href="/coleccion">
            <img src="/images/history-fidelity/discover-arrow.svg" alt="" aria-hidden="true" />
            <span>Descubrir</span>
          </a>
        </footer>
      </div>
    </div>

    <div class="rococo-article__mobile">
      <header class="mobile-article-hero">
        <img
          class="mobile-article-hero__floral"
          src="/images/history-fidelity/header-floral.svg"
          alt=""
          aria-hidden="true"
        />
        <a href="#selector-de-epoca">Ver más épocas</a>
        <div class="mobile-article-hero__title">
          <p>1715 — 1789</p>
          <h2>Rococó</h2>
        </div>
        <div class="mobile-article-hero__byline">
          <span>17 de julio, 2026</span>
          <em>María S. Camargo</em>
        </div>
      </header>

      <section class="mobile-article-copy">
        <blockquote>
          “Cada época deja atrás una manera de estar en el cuerpo. La del siglo XVIII no cabe en
          ningún cuerpo actual.”
        </blockquote>
        <p class="mobile-article-copy__credit">
          — Pascale Gorguet-Ballesteros, conservadora · Palais Galliera
        </p>

        <div class="mobile-article-copy__gallery">
          <div class="mobile-gallery-photo">
            <img
              src="/images/history-fidelity/gallery.jpg"
              alt="Vestidos del siglo XVIII exhibidos en el Palais Galliera"
            />
          </div>
          <img
            class="mobile-gallery-frame"
            src="/images/history-fidelity/gallery-frame.svg"
            alt=""
            aria-hidden="true"
          />
        </div>

        <div class="mobile-article-copy__body">
          <p>
            En los retratos de <a href="/coleccion">Élisabeth Vigée Le Brun</a>, la vestimenta ocupa
            tanto espacio como el rostro. La pintura terminó preservando aquello que el tiempo no
            pudo conservar: la caída de una tela, el brillo de un bordado, el volumen de unos
            paniers. Cuando los textiles originales desaparecen, las pinturas continúan actuando
            como archivos visuales capaces de mantener viva la memoria de formas, colores y
            texturas.
          </p>
          <p>
            Con el paso de los siglos, gran parte de ese universo desapareció. Permanecieron algunos
            vestidos, fragmentos textiles, retratos y documentos capaces de reconstruir apenas una
            parte del relato. Cada pieza conservada por el
            <a class="is-purple" href="/">Palais Galliera</a> funciona como un fragmento de memoria: no
            cuenta toda la historia, pero permite activar conexiones entre personas, materiales y contextos
            que continúan dialogando con el presente.
          </p>
          <p>
            Quizás por eso observar una prenda del siglo XVIII nunca consiste únicamente en mirar un
            objeto antiguo. Cada costura, cada pliegue y cada bordado siguen conteniendo información
            que espera ser recordada. La memoria no permanece inmóvil dentro del museo: vuelve a
            activarse cada vez que alguien decide detenerse sobre un detalle y descubrir que, detrás
            de una tela aparentemente silenciosa, todavía sobreviven historias que continúan
            resonando en el presente.
          </p>
        </div>
      </section>

      <footer class="mobile-discover">
        <h2>Robe à la française</h2>
        <p>Una selección de piezas exclusivas de esta época</p>
        <a href="/coleccion">
          <img src="/images/history-fidelity/discover-arrow.svg" alt="" aria-hidden="true" />
          <span>Descubrir</span>
        </a>
      </footer>
    </div>
  </article>
</MainLayout>

<style>
  :global(body) {
    background: #fd6500;
  }

  .era-selector {
    position: relative;
    width: 100%;
    overflow: clip;
  }

  .era-selector--desktop {
    aspect-ratio: 16 / 9;
    min-height: 100svh;
    background: #fd6500;
  }

  .era-selector__figma {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
  }

  .desktop-hit,
  .article-hit {
    position: absolute;
    z-index: 2;
    display: block;
    color: transparent;
    font-size: 0;
  }

  .desktop-hit:focus-visible,
  .article-hit:focus-visible {
    outline: 3px solid #f3eee1;
    outline-offset: 3px;
  }

  .desktop-hit--logo {
    top: 3.61%;
    left: 3.125%;
    width: 3.18%;
    height: 5.65%;
    border-radius: 50%;
  }

  .desktop-hit--visitar,
  .desktop-hit--exposiciones,
  .desktop-hit--colecciones,
  .desktop-hit--museo,
  .desktop-hit--agenda,
  .desktop-hit--entradas,
  .desktop-hit--search {
    top: 3.61%;
    height: 5.65%;
  }

  .desktop-hit--visitar {
    left: 28.2%;
    width: 4.25%;
  }

  .desktop-hit--exposiciones {
    left: 32.5%;
    width: 7.25%;
  }

  .desktop-hit--colecciones {
    left: 39.75%;
    width: 7.2%;
  }

  .desktop-hit--museo {
    left: 46.95%;
    width: 5.75%;
  }

  .desktop-hit--agenda {
    left: 52.7%;
    width: 5.2%;
  }

  .desktop-hit--entradas {
    left: 61.45%;
    width: 5.75%;
  }

  .desktop-hit--search {
    left: 68.35%;
    width: 4.3%;
  }

  .desktop-hit--read {
    top: 77.78%;
    left: 44.79%;
    width: 10.42%;
    height: 4.2%;
    border-radius: 999px;
  }

  .era-selector--mobile {
    display: none;
  }

  .rococo-article {
    position: relative;
    width: 100%;
    scroll-margin-top: 0;
    background: #b9d6fe;
  }

  .rococo-article__desktop {
    display: grid;
    width: 100%;
    height: 100svh;
    grid-template-rows: clamp(17rem, 30svh, 21rem) minmax(0, 1fr);
    color: #141414;
    overflow: hidden;
  }

  .desktop-reader-header {
    position: relative;
    z-index: 2;
    min-height: 0;
    padding: 2.1rem 3.125vw;
    overflow: hidden;
    background: #b9d6fe;
    border-bottom: 1px solid #141414;
  }

  .desktop-reader-header__floral {
    position: absolute;
    top: -48%;
    right: -1%;
    width: 61%;
    max-width: none;
    opacity: 0.82;
    transform: scaleX(-1);
  }

  .desktop-reader-header > a {
    position: relative;
    z-index: 2;
    display: inline-block;
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .desktop-reader-header__title {
    position: absolute;
    bottom: 1.7rem;
    left: 3.125vw;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
  }

  .desktop-reader-header__title p {
    padding-bottom: 0.45rem;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 3.8vw, 4.25rem);
    font-style: italic;
    line-height: 0.8;
  }

  .desktop-reader-header__title h2 {
    color: #fd6500;
    font-size: clamp(6rem, 10.8vw, 12rem);
    font-weight: 400;
    line-height: 0.68;
    letter-spacing: -0.055em;
  }

  .desktop-reader-header__byline {
    position: absolute;
    right: 3.125vw;
    bottom: 2.2rem;
    z-index: 1;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }

  .desktop-reader-header__byline span {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .desktop-reader-header__byline em {
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
  }

  .desktop-reader-scroll {
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    scroll-behavior: smooth;
    scrollbar-color: #141414 transparent;
    scrollbar-width: thin;
    background: linear-gradient(to bottom, #f3eee1 0 26%, #b9d6fe 78%);
  }

  .desktop-reader-scroll:focus-visible {
    outline: 3px solid #fd6500;
    outline-offset: -3px;
  }

  .desktop-reader-copy {
    display: grid;
    max-width: 96rem;
    min-height: 82rem;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 9rem) 5vw;
    grid-template-columns: minmax(18rem, 0.82fr) minmax(24rem, 1.18fr);
    grid-template-areas:
      'lead lead'
      'media body';
    align-content: start;
    gap: clamp(4rem, 7vw, 8rem) clamp(3rem, 7vw, 8rem);
  }

  .desktop-reader-copy__lead {
    grid-area: lead;
  }

  .desktop-reader-copy__lead blockquote {
    max-width: 66rem;
    margin: 0;
    color: #fd6500;
    font-family: var(--font-display);
    font-size: clamp(3.1rem, 5.7vw, 6.2rem);
    font-style: italic;
    line-height: 0.94;
    letter-spacing: -0.035em;
  }

  .desktop-reader-copy__lead p {
    margin-top: 1.25rem;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .desktop-reader-media {
    position: sticky;
    top: 2.5rem;
    grid-area: media;
    width: min(100%, 33rem);
    margin: 0 auto;
    aspect-ratio: 722.582 / 880;
  }

  .desktop-reader-media__image {
    position: absolute;
    inset: 2.4% 3%;
    overflow: hidden;
    -webkit-mask: url('/images/history-fidelity/gallery-mask.svg') center / 100% 100% no-repeat;
    mask: url('/images/history-fidelity/gallery-mask.svg') center / 100% 100% no-repeat;
  }

  .desktop-reader-media__image img {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    transition: opacity 180ms ease;
  }

  .desktop-reader-media__image img[src$='1730.png'] {
    padding: 8%;
    object-fit: contain;
    background: #f3eee1;
  }

  .desktop-reader-media__frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .desktop-reader-media figcaption {
    position: absolute;
    right: 4%;
    bottom: -1.7rem;
    left: 4%;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-align: center;
    text-transform: uppercase;
  }

  .desktop-reader-copy__body {
    display: grid;
    grid-area: body;
    gap: 2.1rem;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 2vw, 2.25rem);
    font-style: italic;
    line-height: 1.18;
  }

  .related-word {
    display: inline;
    padding: 0;
    color: #fd6500;
    background: transparent;
    border: 0;
    font: inherit;
    text-decoration: underline;
    text-decoration-thickness: 0.06em;
    text-underline-offset: 0.12em;
    cursor: pointer;
  }

  .related-word--purple {
    color: #520345;
  }

  .related-word:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 0.15em;
  }

  .desktop-discover {
    display: flex;
    min-height: 38rem;
    padding: 5rem 3rem 3.5rem;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background:
      radial-gradient(circle at 50% 82%, #fd6500 0 15%, rgb(253 101 0 / 62%) 25%, transparent 58%),
      #b9d6fe;
    border-top: 2px solid #141414;
  }

  .desktop-discover h2 {
    font-size: clamp(5rem, 9.5vw, 10.5rem);
    font-weight: 400;
    line-height: 0.85;
    letter-spacing: -0.055em;
  }

  .desktop-discover p {
    margin-top: 1.8rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .desktop-discover a {
    display: flex;
    margin-top: 2.4rem;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .desktop-discover a img {
    width: 3rem;
  }

  .rococo-article__mobile {
    display: none;
  }

  @media (max-width: 47.99rem) {
    :global(body) {
      background: #b9d6fe;
    }

    .era-selector--desktop,
    .rococo-article__desktop {
      display: none;
    }

    .era-selector--mobile {
      display: grid;
      grid-template-rows: auto 1fr;
      min-height: 100svh;
      padding: 1.15rem 1.15rem 2.25rem;
      color: #141414;
      background: #fd6500;
    }

    .mobile-nav {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .mobile-nav__logo {
      width: 3rem;
      height: 3rem;
      flex: 0 0 auto;
    }

    .mobile-nav__toggle {
      position: relative;
      z-index: 2;
      display: grid;
      place-content: center;
      gap: 0.35rem;
      width: 3rem;
      height: 3rem;
      padding: 0;
      color: #f3eee1;
      background: #141414;
      border: 0;
      border-radius: 50%;
    }

    .mobile-nav__toggle span {
      width: 1.15rem;
      height: 1px;
      background: currentColor;
      transition: transform 240ms ease;
    }

    .mobile-nav__toggle[aria-expanded='true'] span:first-child {
      transform: translateY(0.18rem) rotate(45deg);
    }

    .mobile-nav__toggle[aria-expanded='true'] span:last-child {
      transform: translateY(-0.18rem) rotate(-45deg);
    }

    .mobile-nav__menu {
      position: absolute;
      top: -0.25rem;
      right: -0.25rem;
      left: -0.25rem;
      display: grid;
      gap: 0;
      padding: 4.5rem 1.25rem 1.15rem;
      color: #f3eee1;
      background: #141414;
      border-radius: 1.25rem;
      box-shadow: 0 1.25rem 4rem rgb(20 20 20 / 22%);
    }

    .mobile-nav__menu[hidden] {
      display: none;
    }

    .mobile-nav__menu a {
      padding: 0.72rem 0;
      border-top: 1px solid rgb(243 238 225 / 20%);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .mobile-nav__menu .mobile-nav__ticket {
      margin-top: 0.6rem;
      padding: 0.75rem 0.9rem;
      color: #141414;
      background: #fd6500;
      border-top: 0;
      border-radius: 0.15rem;
