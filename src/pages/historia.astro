    }

    .mobile-discover {
      display: flex;
      min-height: 29rem;
      padding: 4.5rem 1.2rem 3.5rem;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      text-align: center;
      background:
        radial-gradient(
          circle at 50% 80%,
          #fd6500 0 15%,
          rgb(253 101 0 / 58%) 25%,
          transparent 58%
        ),
        #b9d6fe;
      border-top: 2px solid #141414;
    }

    .mobile-discover h2 {
      max-width: 22rem;
      font-size: clamp(4rem, 20vw, 6rem);
      font-weight: 400;
      line-height: 0.86;
      letter-spacing: -0.055em;
    }

    .mobile-discover p {
      margin-top: 2rem;
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .mobile-discover a {
      display: flex;
      margin-top: 2.4rem;
      flex-direction: column;
      align-items: center;
      gap: 0.55rem;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .mobile-discover a img {
      width: 2.55rem;
      height: 2.55rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .era-selector__figma,
    .mobile-era-copy,
    .mobile-era-rail {
      animation: history-arrive 780ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .mobile-era-rail {
      animation-delay: 80ms;
    }

    .mobile-era-copy {
      animation-delay: 140ms;
    }
  }

  @keyframes history-arrive {
    from {
      opacity: 0;
      transform: translateY(0.75rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-nav__toggle span {
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  document.querySelectorAll<HTMLAnchorElement>('[data-read-history]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const target = document.querySelector<HTMLElement>('#historia-rococo');
      if (!target) return;

      event.preventDefault();
      target.scrollIntoView({ behavior: prefersReducedMotion.matches ? 'auto' : 'smooth' });
      history.replaceState(null, '', '#historia-rococo');
    });
  });

  const mobileNav = document.querySelector<HTMLElement>('[data-mobile-history-nav]');
  const mobileToggle = mobileNav?.querySelector<HTMLButtonElement>('[data-mobile-history-toggle]');
  const mobileMenu = mobileNav?.querySelector<HTMLElement>('#history-mobile-menu');

  if (mobileToggle && mobileMenu) {
    const setMenuOpen = (open: boolean) => {
      mobileToggle.setAttribute('aria-expanded', String(open));
      mobileToggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      mobileMenu.hidden = !open;
    };

    mobileToggle.addEventListener('click', () => {
      setMenuOpen(mobileToggle.getAttribute('aria-expanded') !== 'true');
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMenuOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && mobileToggle.getAttribute('aria-expanded') === 'true') {
        setMenuOpen(false);
        mobileToggle.focus();
      }
    });
  }
</script>
