  .desktop-hit--search {
    top: 3.61%;
    height: 5.65%;
  }

  .desktop-hit--visitar {
    left: 28.2%;
    width: 4.25%;
  }

  .desktop-hit--exposiciones {
    left: 32.5%;
    width: 7.25%;
  }

  .desktop-hit--colecciones {
    left: 39.75%;
    width: 7.2%;
  }

  .desktop-hit--museo {
    left: 46.95%;
    width: 5.75%;
  }

  .desktop-hit--agenda {
    left: 52.7%;
    width: 5.2%;
  }

  .desktop-hit--entradas {
    left: 61.45%;
    width: 5.75%;
  }

  .desktop-hit--search {
    left: 68.35%;
    width: 4.3%;
  }

  .desktop-hit--read {
    top: 77.78%;
    left: 44.79%;
    width: 10.42%;
    height: 4.2%;
    border-radius: 999px;
  }

  .era-selector--mobile {
    display: none;
  }

  .rococo-article {
    position: relative;
    width: 100%;
    scroll-margin-top: 0;
    background: #b9d6fe;
  }

  .rococo-article__desktop {
    position: relative;
    width: 100%;
    aspect-ratio: 1920 / 2314;
  }

  .rococo-article__figma {
