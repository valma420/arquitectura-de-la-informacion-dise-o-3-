---
/**
 * Navbar — primary site navigation.
 * Black bar, circular Galliera logo, centered uppercase links, hamburger.
 * The active link is highlighted in red, as in the design.
 */
import { navigationLinks } from '@data/navigation';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="navbar" data-component="navbar">
  <nav class="navbar__inner" aria-label="Principal">
    <a href="/" class="navbar__brand" aria-label="Galliera — Home">
      <span class="navbar__logo">
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
          <g fill="none" stroke="currentColor" stroke-width="1.4">
            <path d="M3.5 9.5 L12 4.5 L20.5 9.5 Z" />
            <line x1="5.5" y1="11.5" x2="5.5" y2="18" />
            <line x1="9.8" y1="11.5" x2="9.8" y2="18" />
            <line x1="14.2" y1="11.5" x2="14.2" y2="18" />
            <line x1="18.5" y1="11.5" x2="18.5" y2="18" />
            <line x1="3" y1="19.5" x2="21" y2="19.5" />
          </g>
        </svg>
      </span>
    </a>

    <ul class="navbar__links">
      {
        navigationLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['navbar__link', 'label', { 'is-active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button class="navbar__burger" aria-label="Abrir menú" aria-expanded="false" data-menu-toggle>
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<div class="menu-overlay" data-menu-overlay aria-hidden="true">
  <ul class="menu-overlay__list">
    {
      navigationLinks.map((link, i) => (
        <li style={`--i:${i}`}>
          <a href={link.href} class="menu-overlay__link">
            <span class="menu-overlay__num">0{i + 1}</span>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: var(--z-navigation);
    background: var(--color-black);
    border-bottom: 1px solid rgba(243, 238, 225, 0.08);
  }

  .navbar__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 92px;
    padding-inline: var(--layout-gutter);
    max-width: var(--layout-max-width);
    margin-inline: auto;
  }

  .navbar__logo {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: var(--radius-full);
    background: var(--color-cream);
    color: var(--color-black);
  }

  .navbar__links {
    display: flex;
    gap: clamp(1.5rem, 4vw, 4.5rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .navbar__link {
    color: var(--color-cream);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .navbar__link:hover,
  .navbar__link.is-active {
    color: var(--color-red-bright);
  }

  .navbar__burger {
    justify-self: end;
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: 0;
    padding: 6px;
    cursor: pointer;
  }

  .navbar__burger span {
    display: block;
    width: 26px;
    height: 1.5px;
    background: var(--color-cream);
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .navbar__burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }
  .navbar__burger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .navbar__burger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* ---------------------------------------------------------------- */
  /* Fullscreen menu overlay                                           */
  /* ---------------------------------------------------------------- */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-navigation) - 1);
    background: var(--color-black);
    display: grid;
    place-items: center;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--duration-base) var(--ease-standard),
      visibility var(--duration-base);
  }

  .menu-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .menu-overlay__list {
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
  }

  .menu-overlay__link {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--color-cream);
    line-height: 1.3;
    display: inline-flex;
    align-items: baseline;
    gap: 1rem;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .menu-overlay__link:hover {
    color: var(--color-red-bright);
  }

  .menu-overlay__num {
    font-family: var(--font-body);
    font-size: var(--label-size-sm);
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-red-bright);
  }

  @media (max-width: 900px) {
    .navbar__links {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const overlay = document.querySelector<HTMLElement>('[data-menu-overlay]');

  toggle?.addEventListener('click', () => {
    const open = overlay?.classList.toggle('is-open') ?? false;
    toggle.setAttribute('aria-expanded', String(open));
    overlay?.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  });
</script>
