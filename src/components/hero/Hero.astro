---
/**
 * Hero — landing / section hero.
 * Placeholder markup only; animation-heavy treatment to be implemented later.
 */
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Digital Exhibition',
  subtitle = 'An interactive journey through graphic design.',
} = Astro.props;
---

<section class="hero" data-component="hero">
  <div class="container">
    <h1 class="hero__title">{title}</h1>
    <p class="hero__subtitle">{subtitle}</p>
  </div>
</section>

<style>
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-3xl);
  }

  .hero__title {
    font-size: var(--font-size-display);
  }

  .hero__subtitle {
    margin-top: var(--space-md);
    max-width: 40ch;
    color: var(--color-muted);
    font-size: var(--font-size-md);
  }
</style>
