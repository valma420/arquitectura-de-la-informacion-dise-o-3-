---
/**
 * Popup — reusable modal / dialog shell.
 * Placeholder markup only; open/close + focus-trap logic to be implemented.
 * Uses the native <dialog> element as an accessible baseline.
 */
interface Props {
  id?: string;
}

const { id = 'popup' } = Astro.props;
---

<dialog class="popup" id={id} data-component="popup">
  <div class="popup__content">
    <button type="button" class="popup__close" data-popup-close aria-label="Close">×</button>
    <div class="popup__body">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .popup {
    z-index: var(--z-popup);
    max-width: min(90vw, 48rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface);
    color: var(--color-foreground);
    padding: 0;
  }

  .popup::backdrop {
    background-color: rgb(0 0 0 / 0.6);
  }

  .popup__content {
    position: relative;
    padding: var(--space-xl);
  }

  .popup__close {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: transparent;
    border: none;
    color: inherit;
    font-size: var(--font-size-lg);
    cursor: pointer;
  }
</style>
