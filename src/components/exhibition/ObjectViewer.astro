---
/**
 * ObjectViewer — detailed viewer for a single exhibition object.
 * Placeholder markup only; interactive/zoom/3D behavior to be implemented.
 */
import type { ExhibitionObject } from '@/types/index';

interface Props {
  object?: ExhibitionObject;
}

const { object } = Astro.props;
---

<section class="object-viewer" data-component="object-viewer">
  <div class="container">
    {
      object ? (
        <article class="object-viewer__inner" data-id={object.id}>
          <div class="object-viewer__stage">
            {/* TODO: render high-resolution / interactive object media */}
          </div>
          <div class="object-viewer__meta">
            <h2 class="object-viewer__title">{object.title}</h2>
            {object.author && <p class="object-viewer__author">{object.author}</p>}
            {object.description && <p>{object.description}</p>}
          </div>
        </article>
      ) : (
        <p class="object-viewer__empty">No object selected.</p>
      )
    }
  </div>
</section>

<style>
  .object-viewer__inner {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr;
  }

  @media (min-width: 60rem) {
    .object-viewer__inner {
      grid-template-columns: 2fr 1fr;
    }
  }

  .object-viewer__stage {
    aspect-ratio: 4 / 3;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
  }

  .object-viewer__author {
    color: var(--color-muted);
  }

  .object-viewer__empty {
    color: var(--color-muted);
  }
</style>
