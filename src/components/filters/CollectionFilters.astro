---
/**
 * CollectionFilters — filter controls for the collection grid.
 * Placeholder markup only; filtering logic to be implemented client-side.
 */
import type { Category } from '@/types/index';

interface Props {
  categories?: Category[];
}

const { categories = [] } = Astro.props;
---

<aside
  class="collection-filters"
  data-component="collection-filters"
  aria-label="Collection filters"
>
  <ul class="collection-filters__list">
    <li>
      <button
        type="button"
        class="collection-filters__button"
        data-filter="all"
        aria-pressed="true"
      >
        All
      </button>
    </li>
    {
      categories.map((category) => (
        <li>
          <button
            type="button"
            class="collection-filters__button"
            data-filter={category.slug}
            aria-pressed="false"
          >
            {category.name}
          </button>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  .collection-filters__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .collection-filters__button {
    padding: var(--space-2xs) var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }
</style>
