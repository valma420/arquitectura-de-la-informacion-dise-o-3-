---
/**
 * PageTransition
 *
 * Full-viewport overlay driven by the shared GSAP motion layer.
 */
---

<div class="page-transition" data-component="page-transition" aria-hidden="true"></div>

<style>
  .page-transition {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 50%;
    width: var(--presentation-width);
    z-index: var(--z-overlay);
    pointer-events: none;
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) scaleY(0);
    transform-origin: bottom center;
    background:
      linear-gradient(to bottom, var(--color-orange) 0 2px, transparent 2px),
      var(--color-background);
    backface-visibility: hidden;
    will-change: transform;
  }
</style>
