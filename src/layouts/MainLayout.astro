---
/**
 * MainLayout
 *
 * The standard page shell: Navbar + main content + Footer, plus the page
 * transition overlay and client-side smooth-scroll bootstrap. Use this for all
 * content pages. Falls back to BaseLayout for bare/special pages.
 */
import BaseLayout from './BaseLayout.astro';
import Navbar from '@components/navigation/Navbar.astro';
import Footer from '@components/layout/Footer.astro';
import PageTransition from '@components/common/PageTransition.astro';
import type { SeoMeta } from '@/types/index';

type Props = Partial<SeoMeta> & {
  /** Hide the global navbar/footer for full-canvas exhibition experiences. */
  immersive?: boolean;
};

const { immersive = false, ...seo } = Astro.props;
---

<BaseLayout {...seo}>
  <div class="presentation-matte">
    <div class="presentation-canvas">
      <PageTransition />
      {!immersive && <Navbar />}
      <main id="main-content">
        <slot />
      </main>
      {!immersive && <Footer />}
    </div>
  </div>
</BaseLayout>

<script>
  // Client-side only: initialize scrolling before scroll-linked site motion.
  import { initSiteMotion } from '@lib/animations';
  import { initSmoothScroll } from '@lib/lenis';

  initSmoothScroll();
  initSiteMotion();
</script>
